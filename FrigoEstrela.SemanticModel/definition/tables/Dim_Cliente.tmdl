	partition Dim_Cliente = calculated
		mode: import
		source =
				
				VAR UltimaData =
				    SUMMARIZECOLUMNS(
				        DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE],
				        "UltimaData", MAX(DCVVQ_VENDAGERALTELEVENDAS[DATA])
				    )
				
				VAR ClienteAtual =
				    ADDCOLUMNS(
				        UltimaData,
				        "CLIENTE",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "GRUPOPESSOA",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPESSOA], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "ATIVIDADE",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "PORTE",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[PORTE], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "CIDADE",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[CIDADE], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "UF",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[UF], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "PAIS",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[PAIS], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            ),
				        "SEQCIDADE",
				            CALCULATE(
				                FIRSTNONBLANK(DCVVQ_VENDAGERALTELEVENDAS[SEQCIDADE], 1),
				                FILTER(
				                    DCVVQ_VENDAGERALTELEVENDAS,
				                    DCVVQ_VENDAGERALTELEVENDAS[DATA] = [UltimaData]
				                )
				            )
				    )
				
				RETURN
				    ClienteAtual

	annotation PBI_Id = ea1a9ea2aca243d5b217741f6900fb5d

