	column 'Cidade Completa' = ```
			
			DCVVQ_VENDAGERALTELEVENDAS[CIDADE] & ", " & 
			DCVVQ_VENDAGERALTELEVENDAS[UF]
			```
		lineageTag: c10f1ae3-451c-41c3-a02e-470967bc628c
		dataCategory: Place
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Categoria derivada do prefixo do TIPODEVOLUCAO. Permite analisar gargalo por area: Comercial, Qualidade, Logistica, Industria, Fiscal, Administrativo, Multi/Misto, Outros.
	column 'Categoria Devolução' =
			VAR _raw = DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]
			VAR _t = SUBSTITUTE(_raw, "–", "-")
			VAR _semSlash = SUBSTITUTE(_t, "/", "")
			VAR _posEspaco = FIND(" ", _semSlash, 1, LEN(_semSlash) + 1)
			VAR _prefixRaw = LEFT(_semSlash, _posEspaco - 1)
			VAR _prefix = SUBSTITUTE(SUBSTITUTE(_prefixRaw, "-", ""), " ", "")
			VAR _temCOM = CONTAINSSTRING(_prefix, "COM")
			VAR _temCQ  = CONTAINSSTRING(_prefix, "CQ")
			VAR _temLOG = CONTAINSSTRING(_prefix, "LOG")
			VAR _temIND = CONTAINSSTRING(_prefix, "IND")
			VAR _temEF  = (LEFT(_prefix, 2) = "EF") && NOT CONTAINSSTRING(_prefix, "COM") && NOT CONTAINSSTRING(_prefix, "CQ") && NOT CONTAINSSTRING(_prefix, "LOG") && NOT CONTAINSSTRING(_prefix, "IND")
			VAR _temADM = (LEFT(_prefix, 3) = "ADM")
			VAR _qtdCat =
			    IF(_temCOM, 1, 0) + IF(_temCQ, 1, 0) + IF(_temLOG, 1, 0) + IF(_temIND, 1, 0)
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_raw) || _t = "", "Sem tipo",
			        _qtdCat >= 2, "Multi/Misto",
			        _temCOM, "Comercial",
			        _temCQ,  "Qualidade",
			        _temLOG, "Logística",
			        _temIND, "Indústria",
			        _temEF,  "Fiscal",
			        _temADM, "Administrativo",
			        "Outros"
			    )
		dataType: string
		lineageTag: 990334e3-b9f2-4cdc-a064-4e8b6ce7b65b

