	/// JS Clientes v4 - card de Recorrencia agora mostra descricao curta da metrica ao inves do MoM.
	measure '_JS Clientes' =
			"<script>" & "(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(v); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fPct(v) { return (Number(v)||0).toFixed(2).replace('.',',') + '%'; }
			  function fDec(v) { return (Number(v)||0).toFixed(2).replace('.',','); }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [
			      {bg:'rgba(184,147,90,.15)',fg:'#8A6740'},
			      {bg:'rgba(78,125,98,.15)',fg:'#3D6049'},
			      {bg:'rgba(74,110,138,.15)',fg:'#3A5872'},
			      {bg:'rgba(192,124,58,.15)',fg:'#995F2C'},
			      {bg:'rgba(58,36,16,.12)',fg:'#3A2410'},
			      {bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}
			    ];
			    return palette[Math.abs(h) % palette.length];
			  }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){ if (!ttEl) return; ttEl.innerHTML = h; ttEl.classList.add('on'); ttEl.style.left = (e.clientX+14)+'px'; ttEl.style.top = (e.clientY-36)+'px'; };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  var kpiIcons = {
			    users: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>"",
			    target: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg>"",
			    bag: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z'/><line x1='3' y1='6' x2='21' y2='6'/><path d='M16 10a4 4 0 0 1-8 0'/></svg>"",
			    refresh: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><polyline points='23 4 23 10 17 10'/><polyline points='1 20 1 14 7 14'/><path d='M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'users',  label:'Clientes Ativos',          val:fN(K.clientes||0),     sub:'MoM = <span class=\''+momCls(K.momClientes)+'\'>'+(K.momClientes||'-')+'</span>'},
			      {icon:'target', label:'Ticket Médio / Cliente',   val:fMK(K.ticketMed||0),   sub:'MoM = <span class=\''+momCls(K.momTicket)+'\'>'+(K.momTicket||'-')+'</span>'},
			      {icon:'bag',    label:'Pedidos / Cliente',        val:fDec(K.pedPorCli||0),  sub:'MoM = <span class=\''+momCls(K.momPed)+'\'>'+(K.momPed||'-')+'</span>'},
			      {icon:'refresh',label:'Taxa de Recorrência',      val:fPct(K.recorrencia||0),sub:'Compraram nos 2 meses anteriores'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  var _modoAt='venda';
			  window.setModoAt=function(m){ _modoAt=m; document.querySelectorAll('#atvModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderAtividade(); };
			  function renderAtividade(){
			    var el=document.getElementById('atvList'); if(!el) return;
			    var data=rJ('jAt')||{venda:[],devolucao:[]};
			    var arr=data[_modoAt]||[];
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var lbl=_modoAt==='venda'?'Faturamento':'Devolução';
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+'</b><br>'+lbl+': '+fMK(v)+'<br>Peso: '+fA(Number(d.peso)||0)+' kg<br>Clientes: '+fN(Number(d.clientes)||0)+'<br>Pedidos: '+fN(Number(d.pedidos)||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoPt='venda';
			  window.setModoPt=function(m){ _modoPt=m; document.querySelectorAll('#prtModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderPorte(); };
			  function renderPorte(){
			    var el=document.getElementById('prtList'); if(!el) return;
			    var data=rJ('jPt')||{venda:[],devolucao:[]};
			    var arr=data[_modoPt]||[];
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var lbl=_modoPt==='venda'?'Faturamento':'Devolução';
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+'</b><br>'+lbl+': '+fMK(v)+'<br>Peso: '+fA(Number(d.peso)||0)+' kg<br>Clientes: '+fN(Number(d.clientes)||0)+'<br>Pedidos: '+fN(Number(d.pedidos)||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoGh='cidade', _modoGr='venda';
			  window.setModoGh=function(m){ _modoGh=m; document.querySelectorAll('#geoHierToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.h===m); }); renderGeografica(); };
			  window.setModoGr=function(m){ _modoGr=m; document.querySelectorAll('#geoModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderGeografica(); };
			  function renderGeografica(){
			    var el=document.getElementById('geoChart'); if(!el) return;
			    var sources={cidade:'jGcd', uf:'jGuf'};
			    var data=rJ(sources[_modoGh])||{venda:[],devolucao:[]};
			    var arr=(data[_modoGr]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var H=500;
			    var P={t:38, r:24, b:70, l:68};
			    var n=arr.length;
			    var containerW = el.clientWidth || 900;
			    var availW = containerW - P.l - P.r;
			    var minBarW = 30;
			    var maxBarW = 56;
			    var defaultGap = 18;
			    var maxGap = 40;
			    var idealBarW = (availW - (n-1)*defaultGap) / Math.max(n,1);
			    var barW, gap, contentW, startX;
			    if (idealBarW >= maxBarW) {
			      barW = maxBarW;
			      var remaining = availW - n*barW;
			      gap = n > 1 ? Math.min(maxGap, remaining / (n-1)) : 0;
			      var totalBarsW = n*barW + (n-1)*gap;
			      startX = P.l + Math.max(0, (availW - totalBarsW) / 2);
			      contentW = containerW;
			    } else if (idealBarW >= minBarW) {
			      barW = idealBarW;
			      gap = defaultGap;
			      startX = P.l;
			      contentW = containerW;
			    } else {
			      barW = minBarW;
			      gap = defaultGap;
			      startX = P.l;
			      contentW = n*barW + (n-1)*gap + P.l + P.r;
			    }
			    var W = Math.max(contentW, containerW);
			    var mx = Math.max.apply(null, arr.map(function(d){ return Number(d.val)||0; }).concat([1])) * 1.10;
			    var lblFn = _modoGr==='venda' ? 'Faturamento' : 'Devolução';
			    var uid = 'g' + Math.floor(Math.random()*99999);
			    var maxWordChars = barW < 40 ? 10 : 14;
			    var svg = ""<defs><linearGradient id='bg""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='1'/><stop offset='100%' stop-color='#1A1A1A' stop-opacity='1'/></linearGradient></defs>"";
			    for (var i=0; i<=4; i++){
			      var y = P.t + (H - P.t - P.b) * i / 4;
			      var v = mx * (1 - i/4);
			      svg += ""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      if (i<4) svg += ""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12.5px;font-family:Segoe UI,system-ui;font-weight:500'>""+fA(v)+""</text>"";
			    }
			    arr.forEach(function(d, i){
			      var v = Number(d.val)||0;
			      var bh = Math.max(2, (v/mx) * (H - P.t - P.b));
			      var bx = startX + i*(barW+gap);
			      var by = H - P.b - bh;
			      var labelX = bx + barW/2;
			      var tt = '<b>'+escT(d.nome)+'</b><br>'+lblFn+': '+fMK(v)+'<br>Clientes: '+fN(Number(d.clientes)||0)+'<br>Pedidos: '+fN(Number(d.pedidos)||0);
			      svg += ""<rect class='vbar' x='""+bx.toFixed(1)+""' y='""+by.toFixed(1)+""' width='""+barW.toFixed(1)+""' height='""+bh.toFixed(1)+""' rx='3' fill='url(#bg""+uid+"")' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(by-8).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:700;font-variant-numeric:tabular-nums;font-family:Segoe UI,system-ui;pointer-events:none'>R$ ""+fA(v)+""</text>"";
			      var words = d.nome.split(/\s+/);
			      var displayWords = words.slice(0, 4).map(function(w){ return w.length > maxWordChars ? w.slice(0, maxWordChars-2) + '..' : w; });
			      var nameY = H - P.b + 16;
			      displayWords.forEach(function(w, j){
			        svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(nameY + j*14)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(w)+""</text>"";
			      });
			    });
			    el.innerHTML = ""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  var _aba='cliente';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabelaBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='cliente'){ data=rJ('jTcl')||[]; cols=[{k:'cliente',t:'Cliente',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'porte',t:'Porte',cls:'tag'},{k:'cidade',t:'Cidade',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='atividade'){ data=rJ('jTat')||[]; cols=[{k:'nome',t:'Atividade',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='porte'){ data=rJ('jTpt')||[]; cols=[{k:'nome',t:'Porte',cls:'name'},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'ticketMedio',t:'Ticket Médio',cls:'num',fmt:fMK},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else { data=rJ('jTcd')||[]; cols=[{k:'nome',t:'Cidade',cls:'name'},{k:'uf',t:'UF',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null, data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>"" + cols.map(function(c){ return ""<th class='th-""+c.cls+""'>""+c.t+""</th>""; }).join('') + ""</tr></thead>"";
			    var body=""<tbody>"" + data.map(function(d){
			      return ""<tr>"" + cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){
			          var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100);
			          return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>"";
			        }
			        if(c.cls==='tag'){
			          var clr=tagColor(v);
			          return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>"";
			        }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('') + ""</tr>"";
			    }).join('') + ""</tbody>"";
			    el.innerHTML=""<table class='tbl'>"" + head + body + ""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderAtividade(); renderPorte(); renderGeografica(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){
			    return ['jKpi','jAt','jPt','jGcd','jGuf','jTcl','jTat','jTpt','jTcd'].map(function(id){
			      var e=document.getElementById(id); if(!e) return '';
			      return e.textContent.length+'|'+e.textContent.slice(0,20);
			    }).join('~');
			  }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();" & "</script>"
		displayFolder: HTML Clientes
		lineageTag: f89f5d7e-835d-4b57-8b47-fe01bf83fa73

	/// Dashboard HTML Content da pagina Clientes - layout completo + JSONs + chama _JS Clientes.
	measure 'HTML Clientes' =
			"<style>:root {
			  --bg:    #EEEAE2;
			  --surf:  #FFFFFF;
			  --surf2: #F7F3EB;
			  --bd:    rgba(26,26,26,.07);
			  --bd2:   rgba(26,26,26,.15);
			  --t1:    #1A1A1A;
			  --t2:    #5A5A5A;
			  --t3:    #8B8B8B;
			  --gold:  #B8935A;
			  --goldS: #EAD9BE;
			  --dark:  #1E1E1E;
			  --grn:   #4E7D62;
			  --org:   #C07C3A;
			  --blu:   #4A6E8A;
			  --red:   #A04848;
			  --sh1:   0 1px 3px rgba(0,0,0,.06);
			  --sh2:   0 2px 10px rgba(0,0,0,.1);
			  --r:     10px;
			  --ease:  cubic-bezier(.4,0,.2,1);
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
			  background: var(--bg);
			  font-family: 'Segoe UI', system-ui, sans-serif;
			  font-size: 14px; color: var(--t1);
			  -webkit-font-smoothing: antialiased;
			  min-height: 100vh;
			}
			.dash { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }
			.hdr { display: flex; align-items: center; justify-content: space-between; padding: 0 2px; }
			.hdr-title { font-size: 25px; font-weight: 700; letter-spacing: -.5px; }
			.hdr-sub { font-size: 13px; color: var(--t3); margin-left: 8px; }
			.kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
			.kpi { background: var(--surf); border-radius: var(--r); padding: 14px 16px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.kpi-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
			.kpi-label { font-size: 12.5px; color: var(--t2); font-weight: 500; }
			.kpi-icon { width: 30px; height: 30px; border-radius: 8px; background: linear-gradient(135deg, var(--goldS), #F0E4CC); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
			.kpi-icon svg { width: 14px; height: 14px; }
			.kpi-val { font-size: 32px; font-weight: 700; letter-spacing: -.6px; line-height: 1.1; font-variant-numeric: tabular-nums; margin-top: 6px; }
			.kpi-sub { font-size: 12.5px; color: var(--t3); margin-top: 4px; }
			.kpi-sub .up { color: var(--grn); font-weight: 600; }
			.kpi-sub .down { color: var(--red); font-weight: 600; }
			.kpi-sub .neu { color: var(--gold); font-weight: 600; }
			.card { background: var(--surf); border-radius: var(--r); padding: 12px 14px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.card-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; gap: 10px; flex-wrap: wrap; }
			.card-title { font-size: 16px; font-weight: 600; letter-spacing: -.2px; }
			.card-sub { font-size: 12px; color: var(--t3); margin-top: 1px; }
			.toggle-group { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
			.mini-toggle, .tri-toggle { display: flex; background: var(--surf2); border: 1px solid var(--bd2); border-radius: 100px; overflow: hidden; }
			.mini-toggle button, .tri-toggle button { padding: 5px 13px; font-size: 12px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; transition: all .15s; }
			.mini-toggle button.on, .tri-toggle button.on { background: var(--dark); color: #fff; border-radius: 100px; }
			.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: stretch; }
			.two-col > .card { display: flex; flex-direction: column; }
			.bars-list-scroll { display: flex; flex-direction: column; gap: 9px; max-height: 380px; overflow-y: auto; padding-right: 6px; }
			.bars-list-scroll::-webkit-scrollbar { width: 6px; }
			.bars-list-scroll::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.bar-row { cursor: default; }
			.bar-head { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
			.bar-name { font-size: 13px; color: #1A1A1A; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
			.bar-val { font-size: 13px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--t1); }
			.bar-track { height: 6px; background: #EAD9BE; border-radius: 100px; overflow: hidden; }
			.bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #1A1A1A, var(--gold)); width: 0; transition: width .8s var(--ease); }
			.chart-vert-wrap { overflow-x: auto; overflow-y: hidden; padding-bottom: 4px; }
			.chart-vert-wrap::-webkit-scrollbar { height: 8px; }
			.chart-vert-wrap::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.chart-vert-wrap svg .vbar { transition: opacity .2s; cursor: pointer; }
			.chart-vert-wrap svg .vbar:hover { opacity: .80; }
			.tabs { display: flex; gap: 4px; background: var(--surf2); padding: 3px; border-radius: 100px; border: 1px solid var(--bd2); flex-wrap: wrap; }
			.tab { padding: 6px 15px; font-size: 12.5px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; border-radius: 100px; transition: all .15s; }
			.tab.on { background: var(--dark); color: #fff; }
			.table-wrap { overflow-x: auto; max-height: 460px; overflow-y: auto; border-radius: 8px; }
			.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
			.tbl th { position: sticky; top: 0; background: var(--surf2); padding: 10px 12px; text-align: left; font-weight: 600; color: var(--t2); border-bottom: 1px solid var(--bd2); font-size: 12px; text-transform: uppercase; letter-spacing: .3px; z-index: 2; }
			.tbl th.th-num { text-align: right; }
			.tbl td { padding: 7px 10px; border-bottom: 1px solid var(--bd); vertical-align: middle; }
			.tbl tr:hover td { background: var(--surf2); }
			.tbl td.td-name { font-weight: 500; color: var(--t1); }
			.tbl td.td-tag { color: var(--t2); font-size: 12px; }
			.tbl td.td-num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: var(--t1); min-width: 100px; }
			.cell-val { display: block; }
			.cell-bar { height: 3px; background: rgba(26,26,26,.04); border-radius: 100px; overflow: hidden; margin-top: 3px; }
			.cell-fill { height: 100%; background: linear-gradient(90deg, #1A1A1A, var(--gold)); border-radius: 100px; }
			.tag-badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 11.5px; font-weight: 600; letter-spacing: .2px; white-space: nowrap; }
			.tt { position: fixed; background: #1E1E1E; color: #fff; padding: 7px 12px; border-radius: 7px; font-size: 12.5px; pointer-events: none; opacity: 0; transition: opacity .15s; z-index: 9999; white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
			.tt.on { opacity: 1; }
			.tt b { color: #D4B687; }
			</style>" &
			"<div class='dash'>
			  <div class='hdr'>
			    <div>
			      <span class='hdr-title'>Clientes</span>
			      <span class='hdr-sub'>Carteira e comportamento de compra</span>
			    </div>
			  </div>
			  <div class='kpi-row' id='kpiGrid'></div>
			  <div class='two-col'>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Distribuição por Atividade</div>
			          <div class='card-sub'>Todas as atividades - rolagem vertical</div>
			        </div>
			        <div class='mini-toggle' id='atvModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoAt(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoAt(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='atvList'></div>
			    </div>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Distribuição por Porte</div>
			          <div class='card-sub'>11 categorias de cliente - rolagem vertical</div>
			        </div>
			        <div class='mini-toggle' id='prtModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoPt(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoPt(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='prtList'></div>
			    </div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div>
			        <div class='card-title'>Top 15 - Análise Geográfica</div>
			        <div class='card-sub'>Barras verticais com rótulo de dados - escolha o nível e o modo</div>
			      </div>
			      <div class='toggle-group'>
			        <div class='mini-toggle' id='geoHierToggle'>
			          <button class='on' data-h='cidade' onclick='setModoGh(&quot;cidade&quot;)'>Cidade</button>
			          <button data-h='uf' onclick='setModoGh(&quot;uf&quot;)'>UF</button>
			        </div>
			        <div class='mini-toggle' id='geoModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoGr(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoGr(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			    </div>
			    <div class='chart-vert-wrap' id='geoChart'></div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Detalhamento</div><div class='card-sub'>Análise por dimensão - mini-barras nas colunas R$</div></div>
			      <div class='tabs' id='abasTabs'>
			        <button class='tab on' data-aba='cliente' onclick='setAba(&quot;cliente&quot;)'>Cliente</button>
			        <button class='tab' data-aba='atividade' onclick='setAba(&quot;atividade&quot;)'>Atividade</button>
			        <button class='tab' data-aba='porte' onclick='setAba(&quot;porte&quot;)'>Porte</button>
			        <button class='tab' data-aba='cidade' onclick='setAba(&quot;cidade&quot;)'>Cidade</button>
			      </div>
			    </div>
			    <div class='table-wrap' id='tabelaBox'></div>
			  </div>
			</div>
			<div class='tt' id='tt'></div>" &
			"<script type='application/json' id='jKpi'>" & [_JSON KPIs Clientes] & "</script>" &
			"<script type='application/json' id='jAt'>"  & [_JSON Distribuicao Atividade Clientes] & "</script>" &
			"<script type='application/json' id='jPt'>"  & [_JSON Distribuicao Porte Clientes] & "</script>" &
			"<script type='application/json' id='jGcd'>" & [_JSON Ranking Cidade Clientes] & "</script>" &
			"<script type='application/json' id='jGuf'>" & [_JSON Ranking UF Clientes] & "</script>" &
			"<script type='application/json' id='jTcl'>" & [_JSON Tabela Cliente Clientes] & "</script>" &
			"<script type='application/json' id='jTat'>" & [_JSON Tabela Atividade Clientes] & "</script>" &
			"<script type='application/json' id='jTpt'>" & [_JSON Tabela Porte Clientes] & "</script>" &
			"<script type='application/json' id='jTcd'>" & [_JSON Tabela Cidade Clientes] & "</script>" &
			[_JS Clientes]
		displayFolder: HTML Clientes
		lineageTag: f352ed6a-f1be-4d4c-98c8-0ed15e2bf8c3

	/// Quantidade de clientes distintos com algum valor de devolucao no periodo filtrado.
	measure 'Clientes com Devolução' =
			CALCULATE(
			    DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			    DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0
			)
		formatString: 0
		lineageTag: b99496b8-7174-483e-907b-b823d66f9eab

	/// Variacao percentual MoM da quantidade de clientes com devolucao.
	measure 'MoM Clientes com Devolução %' =
			VAR Atual = [Clientes com Devolução]
			VAR Anterior = CALCULATE([Clientes com Devolução], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao = DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 8723ab9b-8c0e-4c24-9274-5dee75ed51a2

	/// Variacao percentual MoM da Taxa de Devolucao (R$). Compara fracao atual vs mes anterior.
	measure 'MoM Taxa de Devolução %' =
			VAR Atual = [Taxa de Devolução (R$)]
			VAR Anterior = CALCULATE([Taxa de Devolução (R$)], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao = DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: f51f6846-cfe7-4fe5-b2f4-b114b4b7cd88

	/// JSON com dados dos 4 KPIs do HTML Devolucoes. v2 - corrigido espaco extra em momClientes.
	measure '_JSON KPIs Devolucoes' =
			"{""totalRS"":"     & SUBSTITUTE(FORMAT(COALESCE([Total Devoluções (R$)], 0), "0.00"), ",", ".") &
			",""momRS"":"""      & COALESCE([MoM Devoluções %], "--") & """" &
			",""totalPeso"":"   & SUBSTITUTE(FORMAT(COALESCE([Peso Total Devolvido], 0), "0.00"), ",", ".") &
			",""momPeso"":"""    & COALESCE([MoM Peso Total Devolvido %], "--") & """" &
			",""taxaDev"":"     & SUBSTITUTE(FORMAT(COALESCE([Taxa de Devolução (R$)], 0) * 100, "0.00"), ",", ".") &
			",""momTaxa"":"""    & COALESCE([MoM Taxa de Devolução %], "--") & """" &
			",""clientesDev"":" & COALESCE([Clientes com Devolução], 0) &
			",""momClientes"":""" & COALESCE([MoM Clientes com Devolução %], "--") & """" &
			"}"
		displayFolder: HTML Devolucoes
		lineageTag: 92c95d87-5ea2-404a-b29a-f795629d0644

	/// Mix por Categoria de Devolucao (Comercial, Qualidade, Logistica, Industria, etc.). Para a rosca de gargalo - somente perspectiva de devolucao (sem toggle V/D).
	measure '_JSON Mix Categoria Devolucoes' =
			VAR _cats =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução] <> "Sem tipo"
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _cats,
			        "_devRS",   [Total Devoluções (R$)],
			        "_devPeso", [Peso Total Devolvido],
			        "_qtdTipos", CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0)
			    )
			VAR _f = FILTER(_com, [_devRS] > 0)
			RETURN
			"[" & CONCATENATEX(
			    _f,
			    "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução], """""", ""), "\", "") &
			    """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""qtdTipos"":"   & COALESCE([_qtdTipos], 0) &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: e303af03-8463-4b19-961a-f4a98bcb2715

	/// Top motivos de devolucao (TIPODEVOLUCAO especifico) com tag de categoria. Para o card Top 10 Motivos.
	measure '_JSON Top Motivos Devolucoes' =
			VAR _tipos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _tipos,
			        "_categoria", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução])),
			        "_devRS",     [Total Devoluções (R$)],
			        "_devPeso",   [Peso Total Devolvido],
			        "_clientes",  [Clientes com Devolução]
			    )
			VAR _top = TOPN(20, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _top,
			    "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO], """""", ""), "\", "") &
			    """,""categoria"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_categoria], "-"), """""", ""), "\", "") &
			    """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""clientes"":"   & COALESCE([_clientes], 0) &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: 660d2efb-45a6-4209-9e72-d8be75c91857

	/// Evolucao mensal de devolucoes. v3 - ignora filtro de D_Calendario (mostra todos os meses do dataset). Outros filtros (cliente, vendedor, atividade, etc.) ainda se aplicam.
	measure '_JSON Evolucao Mensal Devolucoes' =
			VAR _meses =
			    CALCULATETABLE(
			        FILTER(
			            SUMMARIZE(D_Calendario, D_Calendario[Mês/Ano]),
			            CALCULATE([Faturamento Total]) > 0
			        ),
			        REMOVEFILTERS(D_Calendario)
			    )
			VAR _com =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            _meses,
			            "_devRS",   CALCULATE([Total Devoluções (R$)]),
			            "_devPeso", CALCULATE([Peso Total Devolvido]),
			            "_taxaDev", CALCULATE([Taxa de Devolução (R$)]) * 100,
			            "_ordem",   CALCULATE(MIN(D_Calendario[Data]))
			        ),
			        REMOVEFILTERS(D_Calendario)
			    )
			VAR _ordenado = TOPN(24, _com, [_ordem], ASC)
			RETURN
			"[" & CONCATENATEX(
			    _ordenado,
			    "{""mes"":""" & SUBSTITUTE(D_Calendario[Mês/Ano], """""", "") &
			    """,""val"":"   & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""taxa"":"    & SUBSTITUTE(FORMAT(COALESCE([_taxaDev], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_ordem], ASC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: f0f0f3cf-f507-4e29-9969-491dc6537af6

	/// Top clientes por devolucao (top 50, JS faz slice 0,15). Estrutura {rs:[...], peso:[...]} para toggle R$/Peso.
	measure '_JSON Top Cliente Devolucoes' =
			VAR _clientes =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[CLIENTE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _clientes,
			        "_cidade",    CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CIDADE])),
			        "_atividade", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE])),
			        "_devRS",     [Total Devoluções (R$)],
			        "_devPeso",   [Peso Total Devolvido],
			        "_pedidos",   [Total de Pedidos]
			    )
			VAR _topRS   = TOPN(50, FILTER(_com, [_devRS] > 0),   [_devRS], DESC)
			VAR _topPeso = TOPN(50, FILTER(_com, [_devPeso] > 0), [_devPeso], DESC)
			VAR _arrRS =
			    "[" & CONCATENATEX(
			        _topRS,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""cidade"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_cidade], "-"), """""", ""), "\", "") &
			        """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], "-"), """""", ""), "\", "") &
			        """,""pedidos"":"  & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			VAR _arrPeso =
			    "[" & CONCATENATEX(
			        _topPeso,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""rs"":"         & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""cidade"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_cidade], "-"), """""", ""), "\", "") &
			        """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], "-"), """""", ""), "\", "") &
			        """,""pedidos"":"  & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devPeso], DESC
			    ) & "]"
			RETURN
			"{""rs"":" & _arrRS & ",""peso"":" & _arrPeso & "}"
		displayFolder: HTML Devolucoes
		lineageTag: b6eead80-f170-4b17-953e-6b01da0d6f21

