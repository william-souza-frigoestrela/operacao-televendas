			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _filtroERP = TREATAS(SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _tipos =
