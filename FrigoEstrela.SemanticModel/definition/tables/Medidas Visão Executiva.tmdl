	/// Mix por Categoria de Devolucao dos clientes Yuzap. Para rosca.
	measure '_JSON Mix Categoria Dev Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _filtroERP = TREATAS(SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _cats =
			    CALCULATETABLE(
			        FILTER(
			            VALUES(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]),
			            NOT(ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução])) &&
			            DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução] <> "Sem tipo"
			        ),
			        _filtroERP
			    )
			VAR _com =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            _cats,
			            "_dev",     CALCULATE([Total Devoluções (R$)]),
			            "_peso",    CALCULATE([Peso Total Devolvido]),
			            "_tipos",   CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0),
			            "_clientes",CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0)
			        ),
			        _filtroERP
			    )
			VAR _f = FILTER(_com, [_dev] > 0)
			RETURN
			"[" & CONCATENATEX(
			    _f,
			    "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução], """""", ""), "\", "") &
			    """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_dev], 0), "0.00"), ",", ".") &
			    ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""qtdTipos"":"  & COALESCE([_tipos], 0) &
			    ",""clientes"":" & COALESCE([_clientes], 0) &
			    "}",
			    ",",
			    [_dev], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: 7aa6e899-bb98-40c4-8abf-afa19854129a

	/// Top motivos de devolucao dos clientes Yuzap. JS faz slice 0,10.
	measure '_JSON Top Motivos Dev Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _filtroERP = TREATAS(SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _tipos =
			    CALCULATETABLE(
			        FILTER(
			            VALUES(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]),
			            NOT(ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO])) && DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO] <> ""
			        ),
			        _filtroERP
