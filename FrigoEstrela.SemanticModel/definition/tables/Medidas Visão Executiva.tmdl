table 'Medidas Visão Executiva'
	lineageTag: 13a474d7-56fe-43ba-bf44-819cb0738937

	measure 'Faturamento Total' =
			
			SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA])
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 46bc0039-2c5d-46d7-b3cb-8e252102b465

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Peso Total Vendido' =
			
			SUM(DCVVQ_VENDAGERALTELEVENDAS[PESOVENDA])
		lineageTag: 19eedd4f-7578-458a-b2ca-6fa43bccb7ad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ticket Mediano' =
			
			MEDIANX(
			    VALUES(DCVVQ_VENDAGERALTELEVENDAS[NROPEDIDO]),
			    CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA]))
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: be77a2e3-572a-431c-b284-f75fd2f2b915

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Total Devoluções (R$)' =
			
			SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO])
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: bfb56861-6ffe-430a-847d-60d0a6c94ab9

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Peso Total Devolvido' =
			
			SUM(DCVVQ_VENDAGERALTELEVENDAS[PESODEVOLVIDO])
		lineageTag: 9cfb6e06-242e-4127-85ac-a7eb2414179e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total de Pedidos' =
			
			DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[NROPEDIDO])
		formatString: 0
		lineageTag: 1a3d43aa-93f6-4238-87d8-8d366d5dbab1

	measure 'Total de Itens' =
			
			COUNTROWS(DCVVQ_VENDAGERALTELEVENDAS)
		formatString: 0
		lineageTag: f4eaca59-54dc-44c1-b3ba-15c7a4be4229

	measure 'Total Clientes Ativos' =
			
			DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
		formatString: 0
		lineageTag: 38867db5-632b-494c-a250-56ce3a6968ed

	measure 'Faturamento Mês Anterior' =
			
			CALCULATE(
			    [Faturamento Total],
			    DATEADD(D_Calendario[Data], -1, MONTH)
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: a77007f5-6842-4d4f-beb7-9efbd37fe2d6

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Variação MoM Faturamento' =
			
			[Faturamento Total] - [Faturamento Mês Anterior]
		lineageTag: 89eb7e31-185f-45c9-a62e-2f5cf4aa31e0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'MoM Faturamento %' =
			
			VAR FaturamentoAtual =
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA])
			
			VAR FaturamentoMesAnterior =
			    CALCULATE(
			        SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA]),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        FaturamentoAtual - FaturamentoMesAnterior,
			        FaturamentoMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: fa5b6149-42c0-4db4-9082-84f84536ddc8

	measure 'MoM Peso Total Vendido %' =
			
			VAR PesoAtual =
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[PESOVENDA])
			
			VAR PesoMesAnterior =
			    CALCULATE(
			        SUM(DCVVQ_VENDAGERALTELEVENDAS[PESOVENDA]),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        PesoAtual - PesoMesAnterior,
			        PesoMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 1d350221-b51e-481d-8efa-e45844fc1911

	measure 'MoM Ticket Mediano %' =
			
			VAR TicketAtual =
			    MEDIANX(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[NROPEDIDO]),
			        CALCULATE(
			            SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA])
			        )
			    )
			
			VAR TicketMesAnterior =
			    CALCULATE(
			        MEDIANX(
			            VALUES(DCVVQ_VENDAGERALTELEVENDAS[NROPEDIDO]),
			            CALCULATE(
			                SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA])
			            )
			        ),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        TicketAtual - TicketMesAnterior,
			        TicketMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: fca0eae3-25d9-4c75-ba8f-43a394a37e57

	measure 'MoM Devoluções %' =
			
			VAR DevolucaoAtual =
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO])
			
			VAR DevolucaoMesAnterior =
			    CALCULATE(
			        SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO]),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        DevolucaoAtual - DevolucaoMesAnterior,
			        DevolucaoMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 0913daf7-50f9-4327-91fd-9eb9c4a5b6c8

	measure 'MoM Peso Total Devolvido %' =
			
			VAR PesoDevolvidoAtual =
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[PESODEVOLVIDO])
			
			VAR PesoDevolvidoMesAnterior =
			    CALCULATE(
			        SUM(DCVVQ_VENDAGERALTELEVENDAS[PESODEVOLVIDO]),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        PesoDevolvidoAtual - PesoDevolvidoMesAnterior,
			        PesoDevolvidoMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: cd8ed810-0789-459f-8d10-d228815ce60e

	measure 'MoM Clientes Ativos %' =
			
			VAR ClientesAtivosAtual =
			    DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			
			VAR ClientesAtivosMesAnterior =
			    CALCULATE(
			        DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			        DATEADD(D_Calendario[Data], -1, MONTH)
			    )
			
			VAR Variacao =
			    DIVIDE(
			        ClientesAtivosAtual - ClientesAtivosMesAnterior,
			        ClientesAtivosMesAnterior,
			        0
			    )
			
			RETURN
			FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 538f7bf4-3849-46eb-93fa-7ea04e6bb995

	/// JSON com dados dos 4 KPIs do HTML Saude do Negocio: Faturamento, Peso, Ticket Mediano, Clientes Ativos com MoM%. Responde a filtros nativos.
	measure '_JSON KPIs Saude' =
			"{""fat"":"         & SUBSTITUTE(FORMAT(COALESCE([Faturamento Total], 0), "0.##"), ",", ".") &
			",""momFat"":"""    & COALESCE([MoM Faturamento %], "--") & """" &
			",""peso"":"        & SUBSTITUTE(FORMAT(COALESCE([Peso Total Vendido], 0), "0.##"), ",", ".") &
			",""momPeso"":"""   & COALESCE([MoM Peso Total Vendido %], "--") & """" &
			",""ticket"":"      & SUBSTITUTE(FORMAT(COALESCE([Ticket Mediano], 0), "0.##"), ",", ".") &
			",""momTicket"":""" & COALESCE([MoM Ticket Mediano %], "--") & """" &
			",""clientes"":"    & COALESCE([Total Clientes Ativos], 0) &
			",""momClientes"":""" & COALESCE([MoM Clientes Ativos %], "--") & """" &
			"}"
		displayFolder: HTML Saude
		lineageTag: 9165fc4b-89ea-448e-8405-bfa7e030e690

	/// Array JSON com métricas mensais (Faturamento, Peso, Pedidos, Ticket Mediano) para o gráfico de evolução do HTML Saude do Negocio. IGNORA filtro de data.
	measure '_JSON Evolucao Saude' =
			VAR _meses =
			    CALCULATETABLE(
			        FILTER(
			            SUMMARIZE(DCVVQ_VENDAGERALTELEVENDAS, D_Calendario[Mês/Ano], D_Calendario[MesAno Ordem]),
			            NOT ISBLANK(D_Calendario[MesAno Ordem])
			        ),
			        ALL(D_Calendario)
			    )
			VAR _result =
			    ADDCOLUMNS(
			        _meses,
			        "_fat",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Faturamento Total], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym),
			        "_peso",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Peso Total Vendido], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym),
			        "_ped",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Total de Pedidos], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym),
			        "_ticket",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Ticket Mediano], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym),
			        "_devRS",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Total Devoluções (R$)], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym),
			        "_devPeso",
			            VAR _ym = D_Calendario[Mês/Ano]
			            RETURN CALCULATE([Peso Total Devolvido], ALL(D_Calendario), D_Calendario[Mês/Ano] = _ym)
			    )
			RETURN
			"[" &
			CONCATENATEX(
			    _result,
			    "{""mes"":""" & D_Calendario[Mês/Ano] &
			    """,""ord"":" & D_Calendario[MesAno Ordem] &
			    ",""fat"":"     & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""pedidos"":" & COALESCE([_ped], 0) &
			    ",""ticket"":"  & SUBSTITUTE(FORMAT(COALESCE([_ticket], 0), "0.00"), ",", ".") &
			    ",""devRS"":"   & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""devPeso"":" & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    D_Calendario[MesAno Ordem], ASC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: f23cb472-12e5-4133-a6c1-40cf3634d967

	/// Top 10 produtos por Faturamento para o gráfico de barras do HTML Saude. Inclui peso e qtd para contexto.
	measure '_JSON Top Produtos Saude' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]) && DCVVQ_VENDAGERALTELEVENDAS[PRODUTO] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",     [Faturamento Total],
			        "_peso",    [Peso Total Vendido],
			        "_qtd",     CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDVENDA])),
			        "_devRS",   [Total Devoluções (R$)],
			        "_devPeso", [Peso Total Devolvido],
			        "_devQtd",  CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDDEVOLVIDA]))
			    )
			VAR _topVenda = TOPN(10, FILTER(_com, [_fat] > 0), [_fat], DESC)
			VAR _topDev   = TOPN(10, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _topVenda,
			        "{""produto"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			        """,""val"":"   & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""qtd"":"     & SUBSTITUTE(FORMAT(COALESCE([_qtd], 0), "0.00"), ",", ".") &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _topDev,
			        "{""produto"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			        """,""val"":"   & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""qtd"":"     & SUBSTITUTE(FORMAT(COALESCE([_devQtd], 0), "0.00"), ",", ".") &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Saude
		lineageTag: f6116420-7945-4e86-80d9-609cc77de03c

	/// Top 10 clientes por Faturamento para o gráfico de barras do HTML Saude. Inclui peso e qtd de pedidos para contexto.
	measure '_JSON Top Clientes Saude' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]) && DCVVQ_VENDAGERALTELEVENDAS[CLIENTE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_devPeso",  [Peso Total Devolvido]
			    )
			VAR _topVenda = TOPN(10, FILTER(_com, [_fat] > 0), [_fat], DESC)
			VAR _topDev   = TOPN(10, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _topVenda,
			        "{""cliente"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			        """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""pedidos"":"   & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _topDev,
			        "{""cliente"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			        """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""pedidos"":"   & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Saude
		lineageTag: 8d2b15ca-fc32-4264-b077-0c177992ceda

	/// Distribuição do faturamento por GRUPOPRODUTO para o treemap do HTML Saude. Todos os grupos ordenados, com fat absoluto e % do total.
	measure '_JSON Mix Grupo Saude' =
			VAR _total = [Faturamento Total]
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]) && DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO] <> ""
			    )
			VAR _comFat =
			    ADDCOLUMNS(
			        _todos,
			        "_fat", [Faturamento Total],
			        "_pct", DIVIDE([Faturamento Total], _total) * 100
			    )
			VAR _ord = FILTER(_comFat, [_fat] > 0)
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""grupo"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO], """""", ""), "\", "") &
			    """,""fat"":" & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""pct"":"   & SUBSTITUTE(FORMAT(COALESCE([_pct], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: b3546d47-4c40-4104-948a-f57ceabb522f

	/// JSON com o bloco resumido de devoluções do HTML Saude: Total R$, Peso Devolvido, Taxa R$, Taxa Peso, com MoMs.
	measure '_JSON Devolucoes Saude' =
			"{""totalRS"":"    & SUBSTITUTE(FORMAT(COALESCE([Total Devoluções (R$)], 0), "0.00"), ",", ".") &
			",""momRS"":"""    & COALESCE([MoM Devoluções %], "--") & """" &
			",""totalPeso"":"  & SUBSTITUTE(FORMAT(COALESCE([Peso Total Devolvido], 0), "0.00"), ",", ".") &
			",""momPeso"":"""  & COALESCE([MoM Peso Total Devolvido %], "--") & """" &
			",""taxaRS"":"     & SUBSTITUTE(FORMAT(COALESCE([Taxa de Devolução (R$)], 0) * 100, "0.00"), ",", ".") &
			",""taxaPeso"":"   & SUBSTITUTE(FORMAT(COALESCE([Taxa de Devolução (Peso)], 0) * 100, "0.00"), ",", ".") &
			"}"
		displayFolder: HTML Saude
		lineageTag: 97766ac4-9653-4876-9d0e-fe4229f4f4e6

	/// Array JSON com dados por VENDEDOR para a aba Vendedor da tabela do HTML Saude. Inclui faturamento, peso, pedidos e itens.
	measure '_JSON Tabela Vendedor Saude' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]) && DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",     [Faturamento Total],
			        "_peso",    [Peso Total Vendido],
			        "_pedidos", [Total de Pedidos],
			        "_itens",   [Total de Itens]
			    )
			VAR _ord = FILTER(_com, [_fat] > 0)
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""vendedor"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			    """,""fat"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat],  0), "0.00"), ",", ".") &
			    ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			    ",""itens"":"      & COALESCE([_itens], 0) &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: 9820b52d-5daa-47fb-bf6f-fe28d8154b1c

	/// Array JSON com dados por PRODUTO para a aba Produto da tabela do HTML Saude. Inclui grupo, faturamento, peso e qtd vendida.
	measure '_JSON Tabela Produto Saude' =
			VAR _todos =
			    SUMMARIZE(
			        DCVVQ_VENDAGERALTELEVENDAS,
			        DCVVQ_VENDAGERALTELEVENDAS[PRODUTO],
			        DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",  [Faturamento Total],
			        "_peso", [Peso Total Vendido],
			        "_qtd",  CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDVENDA]))
			    )
			VAR _ord =
			    FILTER(
			        _com,
			        [_fat] > 0
			        && NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO])
			        && DCVVQ_VENDAGERALTELEVENDAS[PRODUTO] <> ""
			    )
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""produto"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			    """,""grupo"":"""  & SUBSTITUTE(SUBSTITUTE(COALESCE(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO], ""), """""", ""), "\", "") &
			    """,""fat"":"     & SUBSTITUTE(FORMAT(COALESCE([_fat],  0), "0.00"), ",", ".") &
			    ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""qtd"":"       & SUBSTITUTE(FORMAT(COALESCE([_qtd],  0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: e892204f-7906-497b-bd40-2b92fd7d5936

	/// Array JSON com dados por CLIENTE para a aba Cliente da tabela do HTML Saude. Inclui atividade, porte, faturamento e pedidos.
	measure '_JSON Tabela Cliente Saude' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]) && DCVVQ_VENDAGERALTELEVENDAS[CLIENTE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_atividade", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE])),
			        "_porte",     CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[PORTE])),
			        "_fat",       [Faturamento Total],
			        "_pedidos",   [Total de Pedidos]
			    )
			VAR _ord = FILTER(_com, [_fat] > 0)
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""cliente"":"""     & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			    """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], ""), """""", ""), "\", "") &
			    """,""porte"":"""     & SUBSTITUTE(SUBSTITUTE(COALESCE([_porte], ""), """""", ""), "\", "") &
			    """,""fat"":"        & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"      & COALESCE([_pedidos], 0) &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: b6a6214c-66a6-482e-b557-a1b2d81d5399

	/// Array JSON com dados por CIDADE para a aba Cidade da tabela do HTML Saude. Inclui UF, faturamento e clientes ativos.
	measure '_JSON Tabela Cidade Saude' =
			VAR _todos =
			    SUMMARIZE(
			        DCVVQ_VENDAGERALTELEVENDAS,
			        DCVVQ_VENDAGERALTELEVENDAS[CIDADE],
			        DCVVQ_VENDAGERALTELEVENDAS[UF]
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_clientes", [Total Clientes Ativos]
			    )
			VAR _ord =
			    FILTER(
			        _com,
			        [_fat] > 0
			        && NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CIDADE])
			        && DCVVQ_VENDAGERALTELEVENDAS[CIDADE] <> ""
			    )
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""cidade"":"""   & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CIDADE], """""", ""), "\", "") &
			    """,""uf"":"""      & SUBSTITUTE(SUBSTITUTE(COALESCE(DCVVQ_VENDAGERALTELEVENDAS[UF], ""), """""", ""), "\", "") &
			    """,""fat"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""clientes"":"   & COALESCE([_clientes], 0) &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: c6e8914e-609d-476f-b42a-a07a38284806

	/// Array JSON com dados por TIPODEVOLUCAO para a aba Devolução da tabela do HTML Saude. Inclui qtd devolvida, peso devolvido e valor R$.
	measure '_JSON Tabela Devolucao Saude' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]) && DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_qtd",  CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDDEVOLVIDA])),
			        "_peso", [Peso Total Devolvido],
			        "_val",  [Total Devoluções (R$)]
			    )
			VAR _ord = FILTER(_com, [_val] > 0)
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""tipo"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO], """""", ""), "\", "") &
			    """,""qtd"":"  & SUBSTITUTE(FORMAT(COALESCE([_qtd],  0), "0.00"), ",", ".") &
			    ",""peso"":"   & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""val"":"    & SUBSTITUTE(FORMAT(COALESCE([_val],  0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_val], DESC
			) & "]"
		displayFolder: HTML Saude
		lineageTag: b77f2f67-cde6-4e29-ab25-94388498d3a6

	/// JS Saude do Negocio v3 - mini-barras apenas em colunas monetarias (R$), toggles Venda/Devolucao nos top10, dropdown evolucao estendido
	measure '_JS Saude' =
			"<script>" & "(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' mi'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(Math.round(v)); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' mi'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fAkg(v) { return fA(v) + ' kg'; }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function momClsInv(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'down' : (s.indexOf('-') === 0 ? 'up' : 'neu'); }
			  function svgDim(el, fbW, fbH) { var bb = el.getBoundingClientRect(); return [Math.round(bb.width) || fbW, Math.round(bb.height) || fbH]; }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [
			      {bg:'rgba(184,147,90,.15)',fg:'#8A6740'},
			      {bg:'rgba(78,125,98,.15)',fg:'#3D6049'},
			      {bg:'rgba(74,110,138,.15)',fg:'#3A5872'},
			      {bg:'rgba(192,124,58,.15)',fg:'#995F2C'},
			      {bg:'rgba(58,36,16,.12)',fg:'#3A2410'},
			      {bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}
			    ];
			    return palette[Math.abs(h) % palette.length];
			  }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){ if (!ttEl) return; ttEl.innerHTML = h; ttEl.classList.add('on'); var vw=window.innerWidth, vh=window.innerHeight, tw=ttEl.offsetWidth, th=ttEl.offsetHeight; var lx=e.clientX+14; if(lx+tw+8>vw) lx=e.clientX-tw-14; if(lx<4) lx=4; var ty=e.clientY-36; if(ty<4) ty=e.clientY+18; if(ty+th+4>vh) ty=vh-th-4; ttEl.style.left=lx+'px'; ttEl.style.top=ty+'px'; };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  window.tgD = function(id){ var l = document.getElementById(id); if (!l) return; document.querySelectorAll('.dd-list.on').forEach(function(e){ if(e!==l) e.classList.remove('on'); }); l.classList.toggle('on'); };
			  window.ddC = function(e){ var o = e.target.closest('.dd-item'); if (!o) return; var ls=e.currentTarget, p=ls.dataset.p, fn=ls.dataset.fn, v=o.dataset.v, l=o.dataset.l; var b=document.getElementById(p+'-b'); if(b){ b.textContent=l+' ▾'; b.dataset.v=v; } ls.querySelectorAll('.dd-item').forEach(function(el){ el.classList.toggle('act', el.dataset.v===v); }); ls.classList.remove('on'); if(window[fn]) window[fn](); };
			  document.addEventListener('click', function(e){ if (!e.target.closest('.dd') && !e.target.closest('.tabs') && !e.target.closest('.mini-toggle')) document.querySelectorAll('.dd-list.on').forEach(function(el){ el.classList.remove('on'); }); });
			  function axes(W,H,P,mx,fmtFn){ var s=''; var fn=fmtFn||fA; for(var i=0;i<=4;i++){ var y=P.t+(H-P.t-P.b)*i/4, v=mx*(1-i/4); s += ""<line class='gl' x1='""+(P.l)+""' x2='""+(W-P.r)+""' y1='""+(y)+""' y2='""+(y)+""'/>""; if(i<4) s += ""<text class='axl' x='""+(P.l-4)+""' y='""+(y+4)+""' text-anchor='end'>""+fn(v)+""</text>""; } return s; }
			  function smoothCurve(pts){if(pts.length<2)return pts.length?'M'+pts[0].x.toFixed(1)+','+pts[0].y.toFixed(1):'';var d='M'+pts[0].x.toFixed(1)+','+pts[0].y.toFixed(1);for(var i=0;i<pts.length-1;i++){var p0=pts[Math.max(i-1,0)],p1=pts[i],p2=pts[i+1],p3=pts[Math.min(i+2,pts.length-1)];var cp1x=p1.x+(p2.x-p0.x)/6,cp1y=p1.y+(p2.y-p0.y)/6,cp2x=p2.x-(p3.x-p1.x)/6,cp2y=p2.y-(p3.y-p1.y)/6;d+=' C'+cp1x.toFixed(1)+','+cp1y.toFixed(1)+' '+cp2x.toFixed(1)+','+cp2y.toFixed(1)+' '+p2.x.toFixed(1)+','+p2.y.toFixed(1);}return d;}
			  var kpiIcons = {
			    money: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>"",
			    weight: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='5' r='3'/><path d='M6.5 22L4 9l16 0-2.5 13z'/></svg>"",
			    target: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg>"",
			    users: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'money',label:'Faturamento Total',val:fMK(K.fat||0),sub:'MoM = <span class=\''+momCls(K.momFat)+'\'>'+(K.momFat||'-')+'</span>'},
			      {icon:'weight',label:'Peso Vendido',val:fA(K.peso||0)+' kg',sub:'MoM = <span class=\''+momCls(K.momPeso)+'\'>'+(K.momPeso||'-')+'</span>'},
			      {icon:'target',label:'Ticket Mediano',val:fMK(K.ticket||0),sub:'MoM = <span class=\''+momCls(K.momTicket)+'\'>'+(K.momTicket||'-')+'</span>'},
			      {icon:'users',label:'Clientes Ativos',val:fN(K.clientes||0),sub:'MoM = <span class=\''+momCls(K.momClientes)+'\'>'+(K.momClientes||'-')+'</span>'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  window.rEv = function(){
			    var btn=document.getElementById('mE-b'); if(!btn) return; var k=btn.dataset.v;
			    var btn2=document.getElementById('mE2-b'); var k2 = btn2 ? btn2.dataset.v : 'none';
			    var hasComp = (k2 && k2 !== 'none' && k2 !== k);
			    var el=document.getElementById('svgEv'); if(!el) return;
			    var d=svgDim(el,800,200); var W=d[0],H=d[1]; el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var EV=rJ('jEv')||[]; if(!EV.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    function pickFmt(kk){ if(kk==='fat'||kk==='ticket'||kk==='devRS') return fMK; if(kk==='peso'||kk==='devPeso') return fAkg; return fA; }
			    var fmtFn = pickFmt(k);
			    var fmtFn2 = pickFmt(k2);
			    var P={t:24, r: hasComp?72:16, b:28, l:64};
			    var vals=EV.map(function(d2){ return Number(d2[k])||0; });
			    var mx=Math.max.apply(null,vals.concat([1]))*1.18, CW=W-P.l-P.r, CH=H-P.t-P.b, gw=CW/(EV.length-1||1);
			    var pts=EV.map(function(d2,i){ var v=Number(d2[k])||0; var x=P.l+(EV.length>1?i*gw:CW/2); var y=P.t+CH-(v/mx)*CH; return {x:x,y:y,v:v,mes:d2.mes}; });
			    var pts2=null, mx2=0;
			    if(hasComp){
			      var vals2=EV.map(function(d2){ return Number(d2[k2])||0; });
			      mx2=Math.max.apply(null,vals2.concat([1]))*1.18;
			      pts2=EV.map(function(d2,i){ var v=Number(d2[k2])||0; var x=P.l+(EV.length>1?i*gw:CW/2); var y=P.t+CH-(v/mx2)*CH; return {x:x,y:y,v:v,mes:d2.mes}; });
			    }
			    var lineD=smoothCurve(pts);
			    var areaD='M'+pts[0].x.toFixed(1)+','+(P.t+CH)+' L'+lineD.slice(1)+' L'+pts[pts.length-1].x.toFixed(1)+','+(P.t+CH)+'Z';
			    var uid='g'+Math.floor(Math.random()*99999);
			    var svg=axes(W,H,P,mx,fmtFn);
			    if(hasComp){
			      for(var ai=0; ai<4; ai++){
			        var ay=P.t+CH*ai/4, av=mx2*(1-ai/4);
			        svg += ""<text class='axl' x='""+(W-P.r+6)+""' y='""+(ay+4)+""' text-anchor='start' style='fill:#4A6E8A;font-weight:600'>""+fmtFn2(av)+""</text>"";
			      }
			    }
			    svg += ""<defs><linearGradient id='lg""+uid+""' x1='0%' y1='0%' x2='100%' y2='0%'><stop offset='0%' stop-color='#1A1A1A' stop-opacity='.8'/><stop offset='100%' stop-color='#B8935A' stop-opacity='1'/></linearGradient><linearGradient id='ag""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='.15'/><stop offset='100%' stop-color='#B8935A' stop-opacity='0'/></linearGradient></defs>"";
			    svg += ""<path d='""+areaD+""' fill='url(#ag""+uid+"")'/>"";
			    svg += ""<path d='""+lineD+""' fill='none' stroke='url(#lg""+uid+"")' stroke-width='2.5' stroke-linejoin='round' stroke-linecap='round'/>"";
			    if(hasComp){
			      var lineD2=smoothCurve(pts2);
			      svg += ""<path d='""+lineD2+""' fill='none' stroke='#4A6E8A' stroke-width='2.2' stroke-linejoin='round' stroke-linecap='round' stroke-dasharray='5,4'/>"";
			    }
			    var ML={fat:'Faturamento',peso:'Peso',pedidos:'Pedidos',ticket:'Ticket',devRS:'Devolução R$',devPeso:'Peso Devolvido'};
			    var lbl=ML[k]||k;
			    var lbl2=ML[k2]||k2;
			    if(hasComp){
			      svg += ""<g transform='translate(""+(P.l+8)+"",""+(P.t-12)+"")'>"";
			      svg += ""<line x1='0' y1='0' x2='18' y2='0' stroke='#B8935A' stroke-width='2.5'/>"";
			      svg += ""<text x='22' y='4' style='fill:#1A1A1A;font-size:10.5px;font-weight:600'>""+esc(lbl)+""</text>"";
			      var off=Math.round(lbl.length*6.5+40);
			      svg += ""<line x1='""+off+""' y1='0' x2='""+(off+18)+""' y2='0' stroke='#4A6E8A' stroke-width='2.2' stroke-dasharray='5,4'/>"";
			      svg += ""<text x='""+(off+22)+""' y='4' style='fill:#4A6E8A;font-size:10.5px;font-weight:600'>""+esc(lbl2)+""</text>"";
			      svg += ""</g>"";
			    }
			    pts.forEach(function(p,i){
			      var compTip = hasComp ? ('<br>'+lbl2+': '+fmtFn2(pts2[i].v)) : '';
			      svg += ""<circle cx='""+p.x.toFixed(1)+""' cy='""+p.y.toFixed(1)+""' r='10' fill='transparent' onmousemove=\""tip(event,'<b>""+escT(p.mes)+""</b><br>""+lbl+"": ""+fmtFn(p.v)+""""+compTip+""')\"" onmouseleave='tipOff()'/>"";
			      svg += ""<circle cx='""+p.x.toFixed(1)+""' cy='""+p.y.toFixed(1)+""' r='3.5' fill='#B8935A' stroke='#fff' stroke-width='1.5' pointer-events='none'/>"";
			      if(hasComp){
			        svg += ""<circle cx='""+pts2[i].x.toFixed(1)+""' cy='""+pts2[i].y.toFixed(1)+""' r='3' fill='#4A6E8A' stroke='#fff' stroke-width='1.5' pointer-events='none'/>"";
			      }
			      if(pts.length <= 16) svg += ""<text class='axl' x='""+p.x.toFixed(1)+""' y='""+(H-8)+""' text-anchor='middle' pointer-events='none'>""+esc(p.mes)+""</text>"";
			    });
			    el.innerHTML=svg;
			  };
			  var _modoP='venda', _modoC='venda';
			  window.setModoP=function(m){ _modoP=m; document.querySelectorAll('#tpToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderTopProdutos(); };
			  window.setModoC=function(m){ _modoC=m; document.querySelectorAll('#tcToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderTopClientes(); };
			  function renderTopProdutos(){
			    var el=document.getElementById('topProdutos'); if(!el) return;
			    var TP=rJ('jTp')||{venda:[],devolucao:[]};
			    var data=TP[_modoP]||[];
			    if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,data.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var lbl = _modoP==='venda' ? 'Faturamento' : 'Devolução';
			    el.innerHTML=data.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      return ""<div class='bar-row' onmousemove=\""tip(event,'<b>""+escT(d.produto)+""</b><br>""+lbl+"": ""+fMK(v)+""<br>Peso: ""+fA(Number(d.peso)||0)+"" kg<br>Qtd: ""+fA(Number(d.qtd)||0)+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.produto)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  function renderTopClientes(){
			    var el=document.getElementById('topClientes'); if(!el) return;
			    var TC=rJ('jTc')||{venda:[],devolucao:[]};
			    var data=TC[_modoC]||[];
			    if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,data.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var lbl = _modoC==='venda' ? 'Faturamento' : 'Devolução';
			    el.innerHTML=data.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      return ""<div class='bar-row' onmousemove=\""tip(event,'<b>""+escT(d.cliente)+""</b><br>""+lbl+"": ""+fMK(v)+""<br>Pedidos: ""+fN(Number(d.pedidos)||0)+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.cliente)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  function renderTreemap(){
			    var el=document.getElementById('svgMix'); if(!el) return;
			    var d=svgDim(el,800,220); var W=d[0],H=d[1]; el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var MX=rJ('jMx')||[]; if(!MX.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    var total=MX.reduce(function(s,d2){ return s+(Number(d2.fat)||0); }, 0);
			    var colors=['#1A1A1A','#B8935A','#4E7D62','#C07C3A','#4A6E8A','#3A2410','#5A5A5A','#8B8B8B'];
			    var x=0, svg='';
			    MX.forEach(function(d2,i){
			      var v=Number(d2.fat)||0;
			      var w=(v/Math.max(total,1))*W;
			      var c=colors[i % colors.length];
			      var pct=(Number(d2.pct)||0).toFixed(1).replace('.',',');
			      svg += ""<g onmousemove=\""tip(event,'<b>""+escT(d2.grupo)+""</b><br>""+fMK(v)+""<br>""+pct+""%')\"" onmouseleave='tipOff()' style='cursor:default'>"";
			      svg += ""<rect x='""+x+""' y='0' width='""+w+""' height='""+H+""' fill='""+c+""' opacity='.95'/>"";
			      if(w > 60){
			        svg += ""<text x='""+(x+w/2)+""' y='""+(H/2-12)+""' text-anchor='middle' fill='#fff' font-size='13' font-weight='700' font-family='Segoe UI,sans-serif'>""+esc(d2.grupo)+""</text>"";
			        svg += ""<text x='""+(x+w/2)+""' y='""+(H/2+8)+""' text-anchor='middle' fill='#fff' font-size='11' font-weight='600' font-family='Segoe UI,sans-serif' opacity='.85'>""+pct+""%</text>"";
			        svg += ""<text x='""+(x+w/2)+""' y='""+(H/2+24)+""' text-anchor='middle' fill='#fff' font-size='10' font-weight='500' font-family='Segoe UI,sans-serif' opacity='.7'>""+fMK(v)+""</text>"";
			      }
			      svg += ""</g>"";
			      x += w;
			    });
			    el.innerHTML=svg;
			  }
			  function renderDevolucoes(){
			    var el=document.getElementById('devolKpis'); if(!el) return;
			    var D=rJ('jDv')||{};
			    var minis=[
			      {label:'Total Devolvido',val:fMK(D.totalRS||0),sub:'MoM = <span class=\''+momClsInv(D.momRS)+'\'>'+(D.momRS||'-')+'</span>'},
			      {label:'Peso Devolvido',val:fA(D.totalPeso||0)+' kg',sub:'MoM = <span class=\''+momClsInv(D.momPeso)+'\'>'+(D.momPeso||'-')+'</span>'},
			      {label:'Taxa Devolução (R$)',val:(Number(D.taxaRS)||0).toFixed(2).replace('.',',')+'%',sub:'sobre o faturamento'},
			      {label:'Taxa Devolução (Peso)',val:(Number(D.taxaPeso)||0).toFixed(2).replace('.',',')+'%',sub:'sobre o peso total'}
			    ];
			    el.innerHTML=minis.map(function(m){ return ""<div class='mini-kpi'><div class='mini-label'>""+m.label+""</div><div class='mini-val'>""+m.val+""</div><div class='mini-sub'>""+m.sub+""</div></div>""; }).join('');
			  }
			  var _aba='vendedor';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabelaBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='vendedor'){ data=rJ('jTv')||[]; cols=[{k:'vendedor',t:'Vendedor',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'itens',t:'Itens',cls:'num',fmt:fN}]; }
			    else if(_aba==='produto'){ data=rJ('jTpr')||[]; cols=[{k:'produto',t:'Produto',cls:'name'},{k:'grupo',t:'Grupo',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'qtd',t:'Qtd Vendida',cls:'num',fmt:fA}]; }
			    else if(_aba==='cliente'){ data=rJ('jTcl')||[]; cols=[{k:'cliente',t:'Cliente',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'porte',t:'Porte',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN}]; }
			    else if(_aba==='cidade'){ data=rJ('jTci')||[]; cols=[{k:'cidade',t:'Cidade',cls:'name'},{k:'uf',t:'UF',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'clientes',t:'Clientes Ativos',cls:'num',fmt:fN}]; }
			    else { data=rJ('jTdv')||[]; cols=[{k:'tipo',t:'Tipo de Devolução',cls:'name'},{k:'qtd',t:'Qtd Devolvida',cls:'num',fmt:fA},{k:'peso',t:'Peso Devolvido (kg)',cls:'num',fmt:fA},{k:'val',t:'Valor R$',cls:'num',fmt:fMK,bar:true}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null, data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>"" + cols.map(function(c){ return ""<th class='th-""+c.cls+""'>""+c.t+""</th>""; }).join('') + ""</tr></thead>"";
			    var body=""<tbody>"" + data.map(function(d){
			      return ""<tr>"" + cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){
			          var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100);
			          return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>"";
			        }
			        if(c.cls==='tag'){
			          var clr=tagColor(v);
			          return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>"";
			        }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('') + ""</tr>"";
			    }).join('') + ""</tbody>"";
			    el.innerHTML=""<table class='tbl'>"" + head + body + ""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderDevolucoes(); rEv(); renderTopProdutos(); renderTopClientes(); renderTreemap(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){
			    return ['jKpi','jEv','jTp','jTc','jMx','jDv','jTv','jTpr','jTcl','jTci','jTdv'].map(function(id){
			      var e=document.getElementById(id); if(!e) return '';
			      return e.textContent.length+'|'+e.textContent.slice(0,20);
			    }).join('~');
			  }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();" & "</script>"
		displayFolder: HTML Saude
		lineageTag: 44cee7ae-9d0a-4538-8e3c-4a56037305cd

	/// Dashboard HTML Saude do Negocio v3: KPIs > Devolucoes > Evolucao (dropdown 6 opcoes) > Top 10s (toggle Venda/Devolucao) > Mix > Tabela com mini-barras R$ e badges.
	measure 'HTML Saude' =
			"<style>:root {
			  --bg:    #EEEAE2;
			  --surf:  #FFFFFF;
			  --surf2: #F7F3EB;
			  --bd:    rgba(26,26,26,.07);
			  --bd2:   rgba(26,26,26,.15);
			  --t1:    #1A1A1A;
			  --t2:    #5A5A5A;
			  --t3:    #8B8B8B;
			  --gold:  #B8935A;
			  --goldS: #EAD9BE;
			  --dark:  #1E1E1E;
			  --grn:   #4E7D62;
			  --org:   #C07C3A;
			  --blu:   #4A6E8A;
			  --red:   #A04848;
			  --sh1:   0 1px 3px rgba(0,0,0,.06);
			  --sh2:   0 2px 10px rgba(0,0,0,.1);
			  --r:     10px;
			  --ease:  cubic-bezier(.4,0,.2,1);
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
			  background: var(--bg);
			  font-family: 'Segoe UI', system-ui, sans-serif;
			  font-size: 14px; color: var(--t1);
			  -webkit-font-smoothing: antialiased;
			  min-height: 100vh;
			}
			.dash { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }
			.hdr { display: flex; align-items: center; justify-content: space-between; padding: 0 2px; }
			.hdr-title { font-size: 25px; font-weight: 700; letter-spacing: -.5px; }
			.hdr-sub { font-size: 13px; color: var(--t3); margin-left: 8px; }
			.kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
			.kpi { background: var(--surf); border-radius: var(--r); padding: 14px 16px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.kpi-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
			.kpi-label { font-size: 12.5px; color: var(--t2); font-weight: 500; }
			.kpi-icon { width: 30px; height: 30px; border-radius: 8px; background: linear-gradient(135deg, var(--goldS), #F0E4CC); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
			.kpi-icon svg { width: 14px; height: 14px; }
			.kpi-val { font-size: 32px; font-weight: 700; letter-spacing: -.6px; line-height: 1.1; font-variant-numeric: tabular-nums; margin-top: 6px; }
			.kpi-sub { font-size: 12.5px; color: var(--t3); margin-top: 4px; }
			.kpi-sub .up { color: var(--grn); font-weight: 600; }
			.kpi-sub .down { color: var(--red); font-weight: 600; }
			.kpi-sub .neu { color: var(--gold); font-weight: 600; }
			.card { background: var(--surf); border-radius: var(--r); padding: 12px 14px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.card-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; gap: 10px; }
			.card-title { font-size: 16px; font-weight: 600; letter-spacing: -.2px; }
			.card-sub { font-size: 12px; color: var(--t3); margin-top: 1px; }
			.evol-card svg { width: 100%; height: 220px; display: block; }
			.dd { position: relative; display: inline-block; }
			.dd-btn { background: var(--dark); color: #fff; border: none; border-radius: 100px; padding: 6px 14px; font-size: 12.5px; font-weight: 600; cursor: pointer; outline: none; font-family: inherit; }
			.dd-btn-cmp { background: #4A6E8A; }
			.dd-list { position: absolute; top: calc(100% + 4px); right: 0; min-width: 160px; background: #222; border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.3); z-index: 9999; display: none; overflow: hidden; }
			.dd-list.on { display: block; }
			.dd-item { padding: 8px 14px; color: rgba(255,255,255,.85); font-size: 12.5px; font-weight: 500; cursor: pointer; white-space: nowrap; transition: background .1s; font-family: inherit; }
			.dd-item:hover { background: rgba(255,255,255,.1); }
			.dd-item.act { color: var(--gold); }
			.mini-toggle { display: flex; background: var(--surf2); border: 1px solid var(--bd2); border-radius: 100px; overflow: hidden; }
			.mini-toggle button { padding: 5px 13px; font-size: 12px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; transition: all .15s; }
			.mini-toggle button.on { background: var(--dark); color: #fff; border-radius: 100px; }
			.cv { width: 100%; display: block; }
			.cv .gl { stroke: rgba(0,0,0,.06); stroke-dasharray: 3,4; }
			.cv .axl { fill: #8B8B8B; font-size: 12.5px; font-weight: 500; }
			.cv .axv { fill: #1A1A1A; font-size: 12.5px; font-weight: 600; font-variant-numeric: tabular-nums; }
			.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
			.bars-list { display: flex; flex-direction: column; gap: 9px; }
			.bar-row { cursor: default; }
			.bar-head { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
			.bar-name { font-size: 13px; color: #1A1A1A; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
			.bar-val { font-size: 13px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--t1); }
			.bar-track { height: 6px; background: #EAD9BE; border-radius: 100px; overflow: hidden; }
			.bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #1A1A1A, var(--gold)); width: 0; transition: width .8s var(--ease); }
			.treemap-card svg { width: 100%; height: 240px; display: block; }
			.devol-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
			.mini-kpi { background: var(--surf2); border-radius: 8px; padding: 10px 12px; border: 1px solid var(--bd); }
			.mini-label { font-size: 12px; color: var(--t2); font-weight: 500; margin-bottom: 3px; }
			.mini-val { font-size: 22px; font-weight: 700; letter-spacing: -.3px; font-variant-numeric: tabular-nums; }
			.mini-sub { font-size: 11.5px; color: var(--t3); margin-top: 2px; }
			.mini-sub .up { color: var(--grn); font-weight: 600; }
			.mini-sub .down { color: var(--red); font-weight: 600; }
			.mini-sub .neu { color: var(--gold); font-weight: 600; }
			.tabs { display: flex; gap: 4px; background: var(--surf2); padding: 3px; border-radius: 100px; border: 1px solid var(--bd2); }
			.tab { padding: 6px 15px; font-size: 12.5px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; border-radius: 100px; transition: all .15s; }
			.tab.on { background: var(--dark); color: #fff; }
			.table-wrap { overflow-x: auto; max-height: 460px; overflow-y: auto; border-radius: 8px; }
			.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
			.tbl th { position: sticky; top: 0; background: var(--surf2); padding: 10px 12px; text-align: left; font-weight: 600; color: var(--t2); border-bottom: 1px solid var(--bd2); font-size: 12px; text-transform: uppercase; letter-spacing: .3px; z-index: 2; }
			.tbl th.th-num { text-align: right; }
			.tbl td { padding: 7px 10px; border-bottom: 1px solid var(--bd); vertical-align: middle; }
			.tbl tr:hover td { background: var(--surf2); }
			.tbl td.td-name { font-weight: 500; color: var(--t1); }
			.tbl td.td-tag { color: var(--t2); font-size: 12px; }
			.tbl td.td-num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: var(--t1); min-width: 100px; }
			.cell-val { display: block; }
			.cell-bar { height: 3px; background: rgba(26,26,26,.04); border-radius: 100px; overflow: hidden; margin-top: 3px; }
			.cell-fill { height: 100%; background: linear-gradient(90deg, #1A1A1A, var(--gold)); border-radius: 100px; }
			.tag-badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 11.5px; font-weight: 600; letter-spacing: .2px; white-space: nowrap; }
			.tt { position: fixed; background: #1E1E1E; color: #fff; padding: 7px 12px; border-radius: 7px; font-size: 12.5px; pointer-events: none; opacity: 0; transition: opacity .15s; z-index: 9999; white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
			.tt.on { opacity: 1; }
			.tt b { color: #D4B687; }
			</style>" &
			"<div class='dash'>
			  <div class='hdr'>
			    <div>
			      <span class='hdr-title'>Saúde do Negócio</span>
			      <span class='hdr-sub'>Visão executiva consolidada do faturamento, produtos, clientes e devoluções</span>
			    </div>
			  </div>
			  <div class='kpi-row' id='kpiGrid'></div>
			  <div class='card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Saúde de Devolução</div><div class='card-sub'>Pulso de devoluções - detalhamento na página específica</div></div>
			    </div>
			    <div class='devol-row' id='devolKpis'></div>
			  </div>
			  <div class='card evol-card'>
			    <div class='card-head'>
			      <div>
			        <div class='card-title'>Evolução Mensal</div>
			        <div class='card-sub'>Histórico completo - ignora filtro de data</div>
			      </div>
			      <div style='display:flex;gap:8px;align-items:center'>
			        <div class='dd'>
			          <button class='dd-btn' id='mE-b' data-v='fat' data-t='mE-l' onclick='tgD(&quot;mE-l&quot;)'>Faturamento ▾</button>
			          <div class='dd-list' id='mE-l' data-p='mE' data-fn='rEv' onclick='ddC(event)'>
			            <div class='dd-item act' data-v='fat' data-l='Faturamento'>Faturamento</div>
			            <div class='dd-item' data-v='peso' data-l='Peso'>Peso</div>
			            <div class='dd-item' data-v='pedidos' data-l='Pedidos'>Pedidos</div>
			            <div class='dd-item' data-v='ticket' data-l='Ticket'>Ticket</div>
			            <div class='dd-item' data-v='devRS' data-l='Devolução R$'>Devolução R$</div>
			            <div class='dd-item' data-v='devPeso' data-l='Peso Devolvido'>Peso Devolvido</div>
			          </div>
			        </div>
			        <span style='font-size:11px;color:var(--t3);font-weight:600'>vs</span>
			        <div class='dd'>
			          <button class='dd-btn dd-btn-cmp' id='mE2-b' data-v='none' data-t='mE2-l' onclick='tgD(&quot;mE2-l&quot;)'>Nenhuma ▾</button>
			          <div class='dd-list' id='mE2-l' data-p='mE2' data-fn='rEv' onclick='ddC(event)'>
			            <div class='dd-item act' data-v='none' data-l='Nenhuma'>Nenhuma</div>
			            <div class='dd-item' data-v='fat' data-l='Faturamento'>Faturamento</div>
			            <div class='dd-item' data-v='peso' data-l='Peso'>Peso</div>
			            <div class='dd-item' data-v='pedidos' data-l='Pedidos'>Pedidos</div>
			            <div class='dd-item' data-v='ticket' data-l='Ticket'>Ticket</div>
			            <div class='dd-item' data-v='devRS' data-l='Devolução R$'>Devolução R$</div>
			            <div class='dd-item' data-v='devPeso' data-l='Peso Devolvido'>Peso Devolvido</div>
			          </div>
			        </div>
			      </div>
			    </div>
			    <svg class='cv' id='svgEv' preserveAspectRatio='xMidYMid meet'></svg>
			  </div>
			  <div class='two-col'>
			    <div class='card'>
			      <div class='card-head'>
			        <div><div class='card-title'>Top 10 Produtos</div><div class='card-sub'>Por volume - alterne entre venda e devolução</div></div>
			        <div class='mini-toggle' id='tpToggle'>
			          <button class='on' data-m='venda' onclick='setModoP(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoP(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='bars-list' id='topProdutos'></div>
			    </div>
			    <div class='card'>
			      <div class='card-head'>
			        <div><div class='card-title'>Top 10 Clientes</div><div class='card-sub'>Por volume - alterne entre venda e devolução</div></div>
			        <div class='mini-toggle' id='tcToggle'>
			          <button class='on' data-m='venda' onclick='setModoC(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoC(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='bars-list' id='topClientes'></div>
			    </div>
			  </div>
			  <div class='card treemap-card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Mix por Grupo de Produto</div><div class='card-sub'>Distribuição do faturamento por grupo</div></div>
			    </div>
			    <svg class='cv' id='svgMix' preserveAspectRatio='xMidYMid meet'></svg>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Insights da Operação</div><div class='card-sub'>Detalhamento por dimensão - mini-barras mostram proporção na coluna</div></div>
			      <div class='tabs' id='abasTabs'>
			        <button class='tab on' data-aba='vendedor' onclick='setAba(&quot;vendedor&quot;)'>Vendedor</button>
			        <button class='tab' data-aba='produto' onclick='setAba(&quot;produto&quot;)'>Produto</button>
			        <button class='tab' data-aba='cliente' onclick='setAba(&quot;cliente&quot;)'>Cliente</button>
			        <button class='tab' data-aba='cidade' onclick='setAba(&quot;cidade&quot;)'>Cidade</button>
			        <button class='tab' data-aba='devolucao' onclick='setAba(&quot;devolucao&quot;)'>Devolução</button>
			      </div>
			    </div>
			    <div class='table-wrap' id='tabelaBox'></div>
			  </div>
			</div>
			<div class='tt' id='tt'></div>" &
			"<script type='application/json' id='jKpi'>" & [_JSON KPIs Saude] & "</script>" &
			"<script type='application/json' id='jEv'>" & [_JSON Evolucao Saude] & "</script>" &
			"<script type='application/json' id='jTp'>" & [_JSON Top Produtos Saude] & "</script>" &
			"<script type='application/json' id='jTc'>" & [_JSON Top Clientes Saude] & "</script>" &
			"<script type='application/json' id='jMx'>" & [_JSON Mix Grupo Saude] & "</script>" &
			"<script type='application/json' id='jDv'>" & [_JSON Devolucoes Saude] & "</script>" &
			"<script type='application/json' id='jTv'>" & [_JSON Tabela Vendedor Saude] & "</script>" &
			"<script type='application/json' id='jTpr'>" & [_JSON Tabela Produto Saude] & "</script>" &
			"<script type='application/json' id='jTcl'>" & [_JSON Tabela Cliente Saude] & "</script>" &
			"<script type='application/json' id='jTci'>" & [_JSON Tabela Cidade Saude] & "</script>" &
			"<script type='application/json' id='jTdv'>" & [_JSON Tabela Devolucao Saude] & "</script>" &
			[_JS Saude]
		displayFolder: HTML Saude
		lineageTag: 33d099c9-accd-425d-bc9f-71e5cbbb4e60

	/// Quantidade de vendedores distintos com faturamento > 0 no período filtrado.
	measure 'Vendedores Ativos' =
			CALCULATE(
			    DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]),
			    DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA] > 0
			)
		formatString: 0
		lineageTag: 9ce60af7-fa22-458e-86c5-7c980d70ffc7

	/// Variação percentual MoM da quantidade de vendedores ativos. Retorna string formatada (ex: +12,3%, -5,0%, 0,0%).
	measure 'MoM Vendedores Ativos %' =
			VAR Atual = [Vendedores Ativos]
			VAR Anterior =
			    CALCULATE([Vendedores Ativos], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao =
			    DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN
			    FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 4696873a-9903-44eb-90c2-0730a763bca0

	/// Variação percentual MoM do total de pedidos. Retorna string formatada (ex: +12,3%, -5,0%, 0,0%).
	measure 'MoM Pedidos %' =
			VAR Atual = [Total de Pedidos]
			VAR Anterior =
			    CALCULATE([Total de Pedidos], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao =
			    DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN
			    FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: a1579e44-9c92-4e2e-a6e3-6f2fcdce9234

	/// JSON com dados dos 4 KPIs do HTML Comercial: Faturamento, Pedidos, Ticket Mediano, Vendedores Ativos com MoM%.
	measure '_JSON KPIs Comercial' =
			"{""fat"":"           & SUBSTITUTE(FORMAT(COALESCE([Faturamento Total], 0), "0.##"), ",", ".") &
			",""momFat"":"""      & COALESCE([MoM Faturamento %], "--") & """" &
			",""pedidos"":"       & COALESCE([Total de Pedidos], 0) &
			",""momPedidos"":"""  & COALESCE([MoM Pedidos %], "--") & """" &
			",""ticket"":"        & SUBSTITUTE(FORMAT(COALESCE([Ticket Mediano], 0), "0.##"), ",", ".") &
			",""momTicket"":"""   & COALESCE([MoM Ticket Mediano %], "--") & """" &
			",""vendedores"":"    & COALESCE([Vendedores Ativos], 0) &
			",""momVendedores"":""" & COALESCE([MoM Vendedores Ativos %], "--") & """" &
			"}"
		displayFolder: HTML Comercial
		lineageTag: 540ff715-0661-4a89-9993-be42953df73b

	/// TODOS os vendedores em duas visões (venda e devolucao). Cada item: nome, val (R$), peso, pedidos.
	measure '_JSON Ranking Vendedor Comercial' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]) && DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_devPeso",  [Peso Total Devolvido]
			    )
			VAR _venda = FILTER(_com, [_fat] > 0)
			VAR _dev   = FILTER(_com, [_devRS] > 0)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _venda,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			        """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""pedidos"":"   & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _dev,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			        """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""pedidos"":"   & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Comercial
		lineageTag: 5af8d204-7277-4015-a42a-eb5f736d9ac1

	/// Array JSON com dados por VENDEDOR para a aba Vendedor da tabela do HTML Comercial. Inclui faturamento, peso, pedidos, devolução R$ e taxa de devolução.
	measure '_JSON Tabela Vendedor Comercial' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]) && DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_taxaDev",  DIVIDE([Total Devoluções (R$)], [Faturamento Total], 0) * 100
			    )
			VAR _ord = FILTER(_com, [_fat] > 0)
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			    """,""fat"":"        & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""peso"":"         & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"      & COALESCE([_pedidos], 0) &
			    ",""devRS"":"        & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(COALESCE([_taxaDev], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Comercial
		lineageTag: 55c58ac1-930d-42aa-974e-6438926f12d1

	/// Array JSON com top 200 combinacoes Cliente + Vendedor por faturamento para a aba Cliente+Vendedor do HTML Comercial. Inclui fat, pedidos, dev R$ e taxa.
	measure '_JSON Tabela ClienteVendedor Comercial' =
			VAR _todos =
			    SUMMARIZE(
			        DCVVQ_VENDAGERALTELEVENDAS,
			        DCVVQ_VENDAGERALTELEVENDAS[CLIENTE],
			        DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_taxaDev",  DIVIDE([Total Devoluções (R$)], [Faturamento Total], 0) * 100
			    )
			VAR _filt =
			    FILTER(
			        _com,
			        [_fat] > 0
			        && NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE])
			        && DCVVQ_VENDAGERALTELEVENDAS[CLIENTE] <> ""
			        && NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR])
			        && DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR] <> ""
			    )
			VAR _top = TOPN(200, _filt, [_fat], DESC)
			RETURN
			"[" &
			CONCATENATEX(
			    _top,
			    "{""cliente"":"""  & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			    """,""vendedor"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			    """,""fat"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			    ",""devRS"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"    & SUBSTITUTE(FORMAT(COALESCE([_taxaDev], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Comercial
		lineageTag: eb97ee5a-ba05-4c9c-84d5-7f2462825c23

	/// Top 10 grupos de produto em duas visões (venda e devolucao). Cada item: nome, val (R$), peso, qtd.
	measure '_JSON Ranking Grupo Comercial' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]) && DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_qtd",      CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDVENDA])),
			        "_devRS",    [Total Devoluções (R$)],
			        "_devPeso",  [Peso Total Devolvido],
			        "_devQtd",   CALCULATE(SUM(DCVVQ_VENDAGERALTELEVENDAS[QTDDEVOLVIDA]))
			    )
			VAR _topVenda = TOPN(10, FILTER(_com, [_fat] > 0), [_fat], DESC)
			VAR _topDev   = TOPN(10, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _topVenda,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO], """""", ""), "\", "") &
			        """,""val"":"   & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""qtd"":"     & SUBSTITUTE(FORMAT(COALESCE([_qtd], 0), "0.00"), ",", ".") &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _topDev,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO], """""", ""), "\", "") &
			        """,""val"":"   & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"    & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""qtd"":"     & SUBSTITUTE(FORMAT(COALESCE([_devQtd], 0), "0.00"), ",", ".") &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Comercial
		lineageTag: fc0e9490-586e-4c22-8ae5-db449812b1ae

