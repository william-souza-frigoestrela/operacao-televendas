			            _tipos,
			            "_categoria", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução])),
			            "_dev",       CALCULATE([Total Devoluções (R$)]),
			            "_peso",      CALCULATE([Peso Total Devolvido]),
			            "_clientes",  CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0)
			        ),
