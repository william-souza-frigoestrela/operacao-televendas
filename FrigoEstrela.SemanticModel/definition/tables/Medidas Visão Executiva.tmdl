			        "_fat",      [Faturamento Total],
			        "_clientes", [Total Clientes Ativos],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)]
			    )
			VAR _venda = TOPN(50, FILTER(_com, [_fat] > 0), [_fat], DESC)
			VAR _dev   = TOPN(50, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _venda,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CIDADE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _dev,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CIDADE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Clientes
