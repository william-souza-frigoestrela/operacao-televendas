			    SUMMARIZE(
			        DCVVQ_VENDAGERALTELEVENDAS,
			        DCVVQ_VENDAGERALTELEVENDAS[PRODUTO],
			        DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO]
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_taxaDev",  DIVIDE([Total Devoluções (R$)], [Faturamento Total], 0) * 100
			    )
			VAR _ord =
			    FILTER(
			        _com,
			        [_fat] > 0
			        && NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO])
			        && DCVVQ_VENDAGERALTELEVENDAS[PRODUTO] <> ""
			    )
			RETURN
			"[" &
			CONCATENATEX(
			    _ord,
			    "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			    """,""grupo"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO], ""), """""", ""), "\", "") &
			    """,""fat"":"        & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""peso"":"         & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"      & COALESCE([_pedidos], 0) &
			    ",""devRS"":"        & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(COALESCE([_taxaDev], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Comercial
		lineageTag: 644723c5-5dd6-421a-85a3-fcc1dacae69f

	/// Dashboard HTML Comercial v11: revisao ortografica completa - acentos PT-BR aplicados em todos os textos visiveis.
	measure 'HTML Comercial' =
			"<style>:root {
			  --bg:    #EEEAE2;
			  --surf:  #FFFFFF;
			  --surf2: #F7F3EB;
			  --bd:    rgba(26,26,26,.07);
			  --bd2:   rgba(26,26,26,.15);
			  --t1:    #1A1A1A;
			  --t2:    #5A5A5A;
			  --t3:    #8B8B8B;
			  --gold:  #B8935A;
			  --goldS: #EAD9BE;
			  --dark:  #1E1E1E;
			  --grn:   #4E7D62;
			  --org:   #C07C3A;
			  --blu:   #4A6E8A;
			  --red:   #A04848;
			  --sh1:   0 1px 3px rgba(0,0,0,.06);
			  --sh2:   0 2px 10px rgba(0,0,0,.1);
			  --r:     10px;
			  --ease:  cubic-bezier(.4,0,.2,1);
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
			  background: var(--bg);
			  font-family: 'Segoe UI', system-ui, sans-serif;
			  font-size: 14px; color: var(--t1);
			  -webkit-font-smoothing: antialiased;
			  min-height: 100vh;
			}
			.dash { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }
			.hdr { display: flex; align-items: center; justify-content: space-between; padding: 0 2px; }
			.hdr-title { font-size: 25px; font-weight: 700; letter-spacing: -.5px; }
			.hdr-sub { font-size: 13px; color: var(--t3); margin-left: 8px; }
			.kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
			.kpi { background: var(--surf); border-radius: var(--r); padding: 14px 16px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.kpi-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
			.kpi-label { font-size: 12.5px; color: var(--t2); font-weight: 500; }
			.kpi-icon { width: 30px; height: 30px; border-radius: 8px; background: linear-gradient(135deg, var(--goldS), #F0E4CC); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
			.kpi-icon svg { width: 14px; height: 14px; }
			.kpi-val { font-size: 32px; font-weight: 700; letter-spacing: -.6px; line-height: 1.1; font-variant-numeric: tabular-nums; margin-top: 6px; }
			.kpi-sub { font-size: 12.5px; color: var(--t3); margin-top: 4px; }
			.kpi-sub .up { color: var(--grn); font-weight: 600; }
			.kpi-sub .down { color: var(--red); font-weight: 600; }
			.kpi-sub .neu { color: var(--gold); font-weight: 600; }
			.card { background: var(--surf); border-radius: var(--r); padding: 12px 14px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.card-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; gap: 10px; flex-wrap: wrap; }
			.card-title { font-size: 16px; font-weight: 600; letter-spacing: -.2px; }
			.card-sub { font-size: 12px; color: var(--t3); margin-top: 1px; }
			.toggle-group { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
			.mini-toggle, .tri-toggle { display: flex; background: var(--surf2); border: 1px solid var(--bd2); border-radius: 100px; overflow: hidden; }
			.mini-toggle button, .tri-toggle button { padding: 5px 13px; font-size: 12px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; transition: all .15s; }
			.mini-toggle button.on, .tri-toggle button.on { background: var(--dark); color: #fff; border-radius: 100px; }
			.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: stretch; }
			.two-col > .card { display: flex; flex-direction: column; }
			.bars-list-scroll { display: flex; flex-direction: column; gap: 9px; max-height: 380px; overflow-y: auto; padding-right: 6px; }
			.bars-list-scroll::-webkit-scrollbar { width: 6px; }
			.bars-list-scroll::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.bar-row { cursor: default; }
			.bar-head { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
			.bar-name { font-size: 13px; color: #1A1A1A; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; }
			.bar-val { font-size: 13px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--t1); }
			.bar-track { height: 6px; background: #EAD9BE; border-radius: 100px; overflow: hidden; }
			.bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #1A1A1A, var(--gold)); width: 0; transition: width .8s var(--ease); }
			.donut-card { display: flex; flex-direction: column; }
			.donut-svg-wrap { flex: 1; min-height: 0; display: flex; }
			.donut-svg-wrap svg { width: 100%; height: 100%; display: block; }
			.donut-slice { transition: opacity .2s; cursor: pointer; }
			.donut-slice:hover { opacity: .85; }
			.chart-vert-wrap { overflow-x: auto; overflow-y: hidden; padding-bottom: 4px; }
			.chart-vert-wrap::-webkit-scrollbar { height: 8px; }
			.chart-vert-wrap::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.chart-vert-wrap svg .vbar { transition: opacity .2s; cursor: pointer; }
			.chart-vert-wrap svg .vbar:hover { opacity: .80; }
			.tabs { display: flex; gap: 4px; background: var(--surf2); padding: 3px; border-radius: 100px; border: 1px solid var(--bd2); flex-wrap: wrap; }
			.tab { padding: 6px 15px; font-size: 12.5px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; border-radius: 100px; transition: all .15s; }
			.tab.on { background: var(--dark); color: #fff; }
			.table-wrap { overflow-x: auto; max-height: 460px; overflow-y: auto; border-radius: 8px; }
			.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
			.tbl th { position: sticky; top: 0; background: var(--surf2); padding: 10px 12px; text-align: left; font-weight: 600; color: var(--t2); border-bottom: 1px solid var(--bd2); font-size: 12px; text-transform: uppercase; letter-spacing: .3px; z-index: 2; }
			.tbl th.th-num { text-align: right; }
			.tbl td { padding: 7px 10px; border-bottom: 1px solid var(--bd); vertical-align: middle; }
			.tbl tr:hover td { background: var(--surf2); }
			.tbl td.td-name { font-weight: 500; color: var(--t1); }
			.tbl td.td-tag { color: var(--t2); font-size: 12px; }
			.tbl td.td-num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: var(--t1); min-width: 100px; }
			.cell-val { display: block; }
			.cell-bar { height: 3px; background: rgba(26,26,26,.04); border-radius: 100px; overflow: hidden; margin-top: 3px; }
			.cell-fill { height: 100%; background: linear-gradient(90deg, #1A1A1A, var(--gold)); border-radius: 100px; }
			.tag-badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 11.5px; font-weight: 600; letter-spacing: .2px; white-space: nowrap; }
			.tt { position: fixed; background: #1E1E1E; color: #fff; padding: 7px 12px; border-radius: 7px; font-size: 12.5px; pointer-events: none; opacity: 0; transition: opacity .15s; z-index: 9999; white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
			.tt.on { opacity: 1; }
			.tt b { color: #D4B687; }
			</style>" &
			"<div class='dash'>
			  <div class='hdr'>
			    <div>
			      <span class='hdr-title'>Comercial</span>
			      <span class='hdr-sub'>Performance por vendedor e produto</span>
			    </div>
			  </div>
			  <div class='kpi-row' id='kpiGrid'></div>
			  <div class='two-col'>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Ranking de Vendedores</div>
			          <div class='card-sub'>Todos os vendedores - rolagem vertical</div>
			        </div>
			        <div class='mini-toggle' id='vendModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoV(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoV(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='rankingVend'></div>
			    </div>
			    <div class='card donut-card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Mix por Grupo de Produto</div>
			          <div class='card-sub'>Participação dos grupos - alterne Venda / Devolução</div>
			        </div>
			        <div class='mini-toggle' id='grupoModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoG(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoG(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			      <div class='donut-svg-wrap'><svg id='svgGrupo' preserveAspectRatio='xMidYMid meet'></svg></div>
			    </div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div>
			        <div class='card-title'>Top 15 - Análise Hierárquica de Produto</div>
			        <div class='card-sub'>Barras verticais com rótulo de dados - escolha o nível e o modo</div>
			      </div>
			      <div class='toggle-group'>
			        <div class='tri-toggle' id='prodHierToggle'>
			          <button class='on' data-p='familia' onclick='setModoP(&quot;familia&quot;)'>Família</button>
			          <button data-p='produto' onclick='setModoP(&quot;produto&quot;)'>Produto</button>
			          <button data-p='subgrupo' onclick='setModoP(&quot;subgrupo&quot;)'>Subgrupo</button>
			        </div>
			        <div class='mini-toggle' id='prodModoToggle'>
			          <button class='on' data-m='venda' onclick='setModoR(&quot;venda&quot;)'>Venda</button>
			          <button data-m='devolucao' onclick='setModoR(&quot;devolucao&quot;)'>Devolução</button>
			        </div>
			      </div>
			    </div>
			    <div class='chart-vert-wrap' id='analiseProd'></div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Insights da Operação</div><div class='card-sub'>Detalhamento por dimensão - mini-barras nas colunas R$</div></div>
			      <div class='tabs' id='abasTabs'>
			        <button class='tab on' data-aba='vendedor' onclick='setAba(&quot;vendedor&quot;)'>Vendedor</button>
			        <button class='tab' data-aba='produto' onclick='setAba(&quot;produto&quot;)'>Produto</button>
			        <button class='tab' data-aba='subgrupo' onclick='setAba(&quot;subgrupo&quot;)'>Subgrupo</button>
			        <button class='tab' data-aba='familia' onclick='setAba(&quot;familia&quot;)'>Família</button>
			        <button class='tab' data-aba='clivend' onclick='setAba(&quot;clivend&quot;)'>Cliente + Vendedor</button>
			      </div>
			    </div>
			    <div class='table-wrap' id='tabelaBox'></div>
			  </div>
			</div>
			<div class='tt' id='tt'></div>" &
			"<script type='application/json' id='jKpi'>" & [_JSON KPIs Comercial] & "</script>" &
			"<script type='application/json' id='jRvd'>" & [_JSON Ranking Vendedor Comercial] & "</script>" &
			"<script type='application/json' id='jRgr'>" & [_JSON Ranking Grupo Comercial] & "</script>" &
			"<script type='application/json' id='jRsg'>" & [_JSON Ranking Subgrupo Comercial] & "</script>" &
			"<script type='application/json' id='jRfm'>" & [_JSON Ranking Familia Comercial] & "</script>" &
			"<script type='application/json' id='jRpd'>" & [_JSON Ranking Produto Comercial] & "</script>" &
			"<script type='application/json' id='jTvd'>" & [_JSON Tabela Vendedor Comercial] & "</script>" &
			"<script type='application/json' id='jTpr'>" & [_JSON Tabela Produto Comercial] & "</script>" &
			"<script type='application/json' id='jTsg'>" & [_JSON Tabela Subgrupo Comercial] & "</script>" &
			"<script type='application/json' id='jTfm'>" & [_JSON Tabela Familia Comercial] & "</script>" &
			"<script type='application/json' id='jTcv'>" & [_JSON Tabela ClienteVendedor Comercial] & "</script>" &
			[_JS Comercial]
		displayFolder: HTML Comercial
		lineageTag: e78df333-9923-479d-bfe9-90787c031559

	/// JS Comercial v15 - grafico Top 15 com H=500 e P.b=70 (elimina espaco em branco abaixo dos nomes).
	measure '_JS Comercial' =
			"<script>" & "(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(v); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fPct(v) { return (Number(v)||0).toFixed(2).replace('.',',') + '%'; }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function svgDim(el, fbW, fbH) { var bb = el.getBoundingClientRect(); return [Math.round(bb.width) || fbW, Math.round(bb.height) || fbH]; }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [
			      {bg:'rgba(184,147,90,.15)',fg:'#8A6740'},
			      {bg:'rgba(78,125,98,.15)',fg:'#3D6049'},
			      {bg:'rgba(74,110,138,.15)',fg:'#3A5872'},
			      {bg:'rgba(192,124,58,.15)',fg:'#995F2C'},
			      {bg:'rgba(58,36,16,.12)',fg:'#3A2410'},
			      {bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}
			    ];
			    return palette[Math.abs(h) % palette.length];
			  }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){ if (!ttEl) return; ttEl.innerHTML = h; ttEl.classList.add('on'); ttEl.style.left = (e.clientX+14)+'px'; ttEl.style.top = (e.clientY-36)+'px'; };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  var kpiIcons = {
			    money: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>"",
			    bag: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z'/><line x1='3' y1='6' x2='21' y2='6'/><path d='M16 10a4 4 0 0 1-8 0'/></svg>"",
			    target: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg>"",
			    users: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'money',label:'Faturamento Total',val:fMK(K.fat||0),sub:'MoM = <span class=\''+momCls(K.momFat)+'\'>'+(K.momFat||'-')+'</span>'},
			      {icon:'bag',label:'Total de Pedidos',val:fN(K.pedidos||0),sub:'MoM = <span class=\''+momCls(K.momPedidos)+'\'>'+(K.momPedidos||'-')+'</span>'},
			      {icon:'target',label:'Ticket Mediano',val:fMK(K.ticket||0),sub:'MoM = <span class=\''+momCls(K.momTicket)+'\'>'+(K.momTicket||'-')+'</span>'},
			      {icon:'users',label:'Vendedores Ativos',val:fN(K.vendedores||0),sub:'MoM = <span class=\''+momCls(K.momVendedores)+'\'>'+(K.momVendedores||'-')+'</span>'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  var _modoV='venda';
			  window.setModoV=function(m){ _modoV=m; document.querySelectorAll('#vendModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderRankingVendedor(); };
			  function renderRankingVendedor(){
			    var el=document.getElementById('rankingVend'); if(!el) return;
			    var data=rJ('jRvd')||{venda:[],devolucao:[]};
			    var arr=data[_modoV]||[];
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var lbl=_modoV==='venda'?'Faturamento':'Devolução';
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+'</b><br>'+lbl+': '+fMK(v)+'<br>Peso: '+fA(Number(d.peso)||0)+' kg<br>Pedidos: '+fN(Number(d.pedidos)||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoG='venda';
			  window.setModoG=function(m){ _modoG=m; document.querySelectorAll('#grupoModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderRoscaGrupo(); };
			  function renderRoscaGrupo(){
			    var el=document.getElementById('svgGrupo'); if(!el) return;
			    var d=svgDim(el,420,360); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var data=rJ('jRgr')||{venda:[],devolucao:[]};
			    var arr=(data[_modoG]||[]).filter(function(d2){ return (Number(d2.val)||0) > 0; });
			    if(!arr.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    var total=arr.reduce(function(s,d2){ return s + (Number(d2.val)||0); }, 0);
			    if(total<=0) total=1;
			    var colors=['#1A1A1A','#B8935A','#4E7D62','#C07C3A','#4A6E8A','#5A5A5A'];
			    var cx=W*0.30, cy=H/2;
			    var r=Math.min(W*0.26, H*0.40), ri=r*0.58;
			    var start=-Math.PI/2;
			    var svg='';
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var ang=(v/total)*Math.PI*2;
			      var end=start+ang;
			      var largeArc = ang > Math.PI ? 1 : 0;
			      var x1=cx+r*Math.cos(start), y1=cy+r*Math.sin(start);
			      var x2=cx+r*Math.cos(end),   y2=cy+r*Math.sin(end);
			      var xi1=cx+ri*Math.cos(end), yi1=cy+ri*Math.sin(end);
			      var xi2=cx+ri*Math.cos(start), yi2=cy+ri*Math.sin(start);
			      var dPath='M '+x1.toFixed(2)+' '+y1.toFixed(2) +
			                ' A '+r.toFixed(2)+' '+r.toFixed(2)+' 0 '+largeArc+' 1 '+x2.toFixed(2)+' '+y2.toFixed(2) +
			                ' L '+xi1.toFixed(2)+' '+yi1.toFixed(2) +
			                ' A '+ri.toFixed(2)+' '+ri.toFixed(2)+' 0 '+largeArc+' 0 '+xi2.toFixed(2)+' '+yi2.toFixed(2) +
			                ' Z';
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[i % colors.length];
			      var ttHtml='<b>'+escT(d2.nome)+'</b><br>'+(_modoG==='venda'?'Faturamento':'Devolução')+': '+fMK(v)+'<br>'+pct+'% do total';
			      svg += ""<path class='donut-slice' d='""+dPath+""' fill='""+color+""' stroke='#FFFFFF' stroke-width='2' onmousemove=\""tip(event,'""+ttHtml+""')\"" onmouseleave='tipOff()'/>"";
			      start=end;
			    });
			    var lblCentro=_modoG==='venda'?'FATURAMENTO':'DEVOLUÇÃO';
			    svg += ""<text x='""+cx+""' y='""+(cy-2)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:22px;font-weight:700;font-family:Segoe UI,system-ui'>""+fMK(total)+""</text>"";
			    svg += ""<text x='""+cx+""' y='""+(cy+18)+""' text-anchor='middle' fill='#8B8B8B' style='font-size:11px;font-weight:600;letter-spacing:1.8px;font-family:Segoe UI,system-ui'>""+lblCentro+""</text>"";
			    var lx=W*0.58;
			    var step=48;
			    var ly=Math.max(32, (H - arr.length*step)/2 + 16);
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[i % colors.length];
			      var y=ly + i*step;
			      svg += ""<rect x='""+lx+""' y='""+(y-11)+""' width='14' height='14' rx='3' fill='""+color+""'/>"";
			      svg += ""<text x='""+(lx+22)+""' y='""+y+""' fill='#1A1A1A' style='font-size:14px;font-weight:600;font-family:Segoe UI,system-ui'>""+esc(d2.nome)+""</text>"";
			      svg += ""<text x='""+(lx+22)+""' y='""+(y+18)+""' style='font-size:12.5px;font-family:Segoe UI,system-ui'><tspan fill='#5A5A5A'>""+fMK(v)+""</tspan> <tspan fill='#B8935A' font-weight='700'>""+pct+""%</tspan></text>"";
			    });
			    el.innerHTML=svg;
			  }
			  var _modoP='familia', _modoR='venda';
			  window.setModoP=function(m){ _modoP=m; document.querySelectorAll('#prodHierToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.p===m); }); renderAnaliseProduto(); };
			  window.setModoR=function(m){ _modoR=m; document.querySelectorAll('#prodModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderAnaliseProduto(); };
			  function renderAnaliseProduto(){
			    var el=document.getElementById('analiseProd'); if(!el) return;
			    var sources={subgrupo:'jRsg', familia:'jRfm', produto:'jRpd'};
			    var data=rJ(sources[_modoP])||{venda:[],devolucao:[]};
			    var arr=(data[_modoR]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var H=500;
			    var P={t:38, r:24, b:70, l:68};
			    var n=arr.length;
			    var containerW = el.clientWidth || 900;
			    var availW = containerW - P.l - P.r;
			    var minBarW = 30;
			    var maxBarW = 56;
			    var defaultGap = 18;
			    var maxGap = 40;
			    var idealBarW = (availW - (n-1)*defaultGap) / Math.max(n,1);
			    var barW, gap, contentW, startX;
			    if (idealBarW >= maxBarW) {
			      barW = maxBarW;
			      var remaining = availW - n*barW;
			      gap = n > 1 ? Math.min(maxGap, remaining / (n-1)) : 0;
			      var totalBarsW = n*barW + (n-1)*gap;
			      startX = P.l + Math.max(0, (availW - totalBarsW) / 2);
			      contentW = containerW;
			    } else if (idealBarW >= minBarW) {
			      barW = idealBarW;
			      gap = defaultGap;
			      startX = P.l;
			      contentW = containerW;
			    } else {
			      barW = minBarW;
			      gap = defaultGap;
			      startX = P.l;
			      contentW = n*barW + (n-1)*gap + P.l + P.r;
			    }
			    var W = Math.max(contentW, containerW);
			    var mx = Math.max.apply(null, arr.map(function(d){ return Number(d.val)||0; }).concat([1])) * 1.10;
			    var lblFn = _modoR==='venda' ? 'Faturamento' : 'Devolução';
			    var uid = 'b' + Math.floor(Math.random()*99999);
			    var maxWordChars = barW < 40 ? 10 : 14;
			    var svg = ""<defs><linearGradient id='bg""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='1'/><stop offset='100%' stop-color='#1A1A1A' stop-opacity='1'/></linearGradient></defs>"";
			    for (var i=0; i<=4; i++){
			      var y = P.t + (H - P.t - P.b) * i / 4;
			      var v = mx * (1 - i/4);
			      svg += ""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      if (i<4) svg += ""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12.5px;font-family:Segoe UI,system-ui;font-weight:500'>""+fA(v)+""</text>"";
			    }
			    arr.forEach(function(d, i){
			      var v = Number(d.val)||0;
			      var bh = Math.max(2, (v/mx) * (H - P.t - P.b));
			      var bx = startX + i*(barW+gap);
			      var by = H - P.b - bh;
			      var labelX = bx + barW/2;
			      var tt = '<b>'+escT(d.nome)+'</b><br>'+lblFn+': '+fMK(v)+'<br>Peso: '+fA(Number(d.peso)||0)+' kg<br>Qtd: '+fA(Number(d.qtd)||0);
			      svg += ""<rect class='vbar' x='""+bx.toFixed(1)+""' y='""+by.toFixed(1)+""' width='""+barW.toFixed(1)+""' height='""+bh.toFixed(1)+""' rx='3' fill='url(#bg""+uid+"")' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(by-8).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:700;font-variant-numeric:tabular-nums;font-family:Segoe UI,system-ui;pointer-events:none'>R$ ""+fA(v)+""</text>"";
			      var words = d.nome.split(/\s+/);
			      var displayWords = words.slice(0, 4).map(function(w){ return w.length > maxWordChars ? w.slice(0, maxWordChars-2) + '..' : w; });
			      var nameY = H - P.b + 16;
			      displayWords.forEach(function(w, j){
			        svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(nameY + j*14)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(w)+""</text>"";
			      });
			    });
			    el.innerHTML = ""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  var _aba='vendedor';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabelaBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='vendedor'){ data=rJ('jTvd')||[]; cols=[{k:'nome',t:'Vendedor',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='produto'){ data=rJ('jTpr')||[]; cols=[{k:'nome',t:'Produto',cls:'name'},{k:'grupo',t:'Grupo',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='subgrupo'){ data=rJ('jTsg')||[]; cols=[{k:'nome',t:'Subgrupo',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='familia'){ data=rJ('jTfm')||[]; cols=[{k:'nome',t:'Família',cls:'name'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else { data=rJ('jTcv')||[]; cols=[{k:'cliente',t:'Cliente',cls:'name'},{k:'vendedor',t:'Vendedor',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null, data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>"" + cols.map(function(c){ return ""<th class='th-""+c.cls+""'>""+c.t+""</th>""; }).join('') + ""</tr></thead>"";
			    var body=""<tbody>"" + data.map(function(d){
			      return ""<tr>"" + cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){
			          var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100);
			          return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>"";
			        }
			        if(c.cls==='tag'){
			          var clr=tagColor(v);
			          return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>"";
			        }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('') + ""</tr>"";
			    }).join('') + ""</tbody>"";
			    el.innerHTML=""<table class='tbl'>"" + head + body + ""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderRankingVendedor(); renderRoscaGrupo(); renderAnaliseProduto(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){
			    return ['jKpi','jRvd','jRgr','jRsg','jRfm','jRpd','jTvd','jTpr','jTsg','jTfm','jTcv'].map(function(id){
			      var e=document.getElementById(id); if(!e) return '';
			      return e.textContent.length+'|'+e.textContent.slice(0,20);
			    }).join('~');
			  }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();" & "</script>"
		displayFolder: HTML Comercial
		lineageTag: abc3b921-6631-4289-9415-5024451f4195

	/// Faturamento medio por cliente ativo no periodo.
	measure 'Ticket Médio por Cliente' = DIVIDE([Faturamento Total], [Total Clientes Ativos], 0)
		formatString: "R$ "#,##0.00
		lineageTag: 9515dcc7-eebd-4c7f-9649-acc3d1352304

	/// Variacao percentual MoM do ticket medio por cliente.
	measure 'MoM Ticket Médio por Cliente %' =
			VAR Atual = [Ticket Médio por Cliente]
			VAR Anterior =
			    CALCULATE([Ticket Médio por Cliente], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao =
			    DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN
			    FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 1ad5dd17-6aa4-4973-8611-44a1fa805559

	/// Quantidade media de pedidos por cliente ativo no periodo.
	measure 'Pedidos por Cliente' = DIVIDE([Total de Pedidos], [Total Clientes Ativos], 0)
		formatString: 0.00
		lineageTag: 500c9506-6196-482d-8bd2-010a3ef15812

	/// Variacao percentual MoM de pedidos por cliente.
	measure 'MoM Pedidos por Cliente %' =
			VAR Atual = [Pedidos por Cliente]
			VAR Anterior =
			    CALCULATE([Pedidos por Cliente], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao =
			    DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN
			    FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: ba36dd68-bafe-4fec-b5b1-8751ffad1b0d

	/// Recorrência Rolling 2M: % dos clientes ativos no período filtrado que também compraram em algum dos 2 meses cheios imediatamente anteriores ao início do período.
	measure 'Taxa de Recorrência %' =
			VAR _mesInicio = DATE(YEAR(MIN(D_Calendario[Data])), MONTH(MIN(D_Calendario[Data])), 1)
			VAR _dataMaxJanela = _mesInicio - 1
			VAR _dataMinJanela = EDATE(_mesInicio, -2)
			VAR _ativosNoPeriodo =
			    CALCULATETABLE(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			        DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA] > 0
			    )
			VAR _ativosNaJanelaAnterior =
			    CALCULATETABLE(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			        DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA] > 0,
			        FILTER(
			            ALL(D_Calendario),
			            D_Calendario[Data] >= _dataMinJanela &&
			            D_Calendario[Data] <= _dataMaxJanela
			        )
			    )
			VAR _recorrentes = INTERSECT(_ativosNoPeriodo, _ativosNaJanelaAnterior)
			VAR _qtdRecorrentes = COUNTROWS(_recorrentes)
			VAR _qtdAtivos = COUNTROWS(_ativosNoPeriodo)
			RETURN
			    DIVIDE(_qtdRecorrentes, _qtdAtivos, 0) * 100
		formatString: 0.00
		lineageTag: 9d75a1cb-5d89-4d7f-a1cf-f6fa9e331612

	/// Variacao percentual MoM da taxa de recorrencia.
	measure 'MoM Taxa de Recorrência %' =
			VAR Atual = [Taxa de Recorrência %]
			VAR Anterior =
			    CALCULATE([Taxa de Recorrência %], DATEADD(D_Calendario[Data], -1, MONTH))
			VAR Variacao =
			    DIVIDE(Atual - Anterior, Anterior, 0)
			RETURN
			    FORMAT(Variacao, "+0.0%;-0.0%;0.0%")
		lineageTag: 59f72fc8-ed75-4cb5-b946-5296b9cfd1d9

	/// JSON com dados dos 4 KPIs do HTML Clientes. v2 - formato 0.00 (estavel) ao inves de 0.## (gerava '0.' invalido quando valor era zero).
	measure '_JSON KPIs Clientes' =
			"{""clientes"":"        & COALESCE([Total Clientes Ativos], 0) &
			",""momClientes"":"""   & COALESCE([MoM Clientes Ativos %], "--") & """" &
			",""ticketMed"":"       & SUBSTITUTE(FORMAT(COALESCE([Ticket Médio por Cliente], 0), "0.00"), ",", ".") &
			",""momTicket"":"""     & COALESCE([MoM Ticket Médio por Cliente %], "--") & """" &
			",""pedPorCli"":"       & SUBSTITUTE(FORMAT(COALESCE([Pedidos por Cliente], 0), "0.00"), ",", ".") &
			",""momPed"":"""        & COALESCE([MoM Pedidos por Cliente %], "--") & """" &
			",""recorrencia"":"     & SUBSTITUTE(FORMAT(COALESCE([Taxa de Recorrência %], 0), "0.00"), ",", ".") &
			",""momRec"":"""        & COALESCE([MoM Taxa de Recorrência %], "--") & """" &
			"}"
		displayFolder: HTML Clientes
		lineageTag: e99cfe32-b65f-4e10-a898-ee838618d8da

	/// Distribuicao por ATIVIDADE em duas visoes (venda e devolucao). Cada item: nome, val (R$), peso, clientes ativos, pedidos.
	measure '_JSON Distribuicao Atividade Clientes' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE]) && DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_clientes", [Total Clientes Ativos],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_devPeso",  [Peso Total Devolvido]
			    )
			VAR _venda = FILTER(_com, [_fat] > 0)
			VAR _dev   = FILTER(_com, [_devRS] > 0)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _venda,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _dev,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
		displayFolder: HTML Clientes
		lineageTag: 467adb57-695a-408a-9051-0f0148fe1570

	/// Distribuicao por PORTE em duas visoes (venda e devolucao).
