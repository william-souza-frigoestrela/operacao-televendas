			    """,""categoria"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_categoria], "-"), """""", ""), "\", "") &
			    """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_dev], 0), "0.00"), ",", ".") &
			    ",""peso"":"      & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
