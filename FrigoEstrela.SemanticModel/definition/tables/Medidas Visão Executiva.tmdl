	/// Ranking por CIDADE em duas visoes (venda e devolucao). Top 50 cada para limitar tamanho - JS aplica slice(0,15).
	measure '_JSON Ranking Cidade Clientes' =
			VAR _todos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]) && DCVVQ_VENDAGERALTELEVENDAS[CIDADE] <> ""
			    )
