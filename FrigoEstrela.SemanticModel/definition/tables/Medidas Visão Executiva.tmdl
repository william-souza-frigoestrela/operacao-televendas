			        """,""val"":"     & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""rs"":"        & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""grupo"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_grupo], "-"), """""", ""), "\", "") &
