	/// Tabela detalhada dos clientes Yuzap com FAT > 0 (apenas convertidos/recorrentes). Inclui status, qtd conversas Yuzap, fat, pedidos, devolucao, taxa dev, dias ultima compra.
	measure '_JSON Tabela Cliente Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            FILTER(
			                VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			                NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])) &&
			                F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			            ),
			            "_nome",     CALCULATE(MAX(F_Yuzap_Conversas[Nome Contato])),
			            "_qtdConv",  CALCULATE(COUNTROWS(F_Yuzap_Conversas)),
			            "_ultLabel",
			                VAR _md = CALCULATE(MAX(F_Yuzap_Conversas[Data Atualizacao]))
			                RETURN CALCULATE(MAX(F_Yuzap_Conversas[Labels]), F_Yuzap_Conversas[Data Atualizacao] = _md)
			        )
			    )
			VAR _hoje = TODAY()
			VAR _com =
			    ADDCOLUMNS(
			        _yz,
			        "_cidade",    CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_atividade", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_clienteNome", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_fat",       CALCULATE([Faturamento Total], TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_pedidos",   CALCULATE([Total de Pedidos],  TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_dev",       CALCULATE([Total Devoluções (R$)], TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_ultCompra", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[DATA]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]))
			    )
			VAR _comVenda = FILTER(_com, COALESCE([_fat], 0) > 0)
			VAR _ordenado = TOPN(220, _comVenda, [_fat], DESC, [_qtdConv], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _ordenado,
			    "{""codigo"":""" & SUBSTITUTE(SUBSTITUTE(F_Yuzap_Conversas[data.attr_cdigo_cliente], """""", ""), "\", "") &
			    """,""cliente"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_clienteNome], [_nome], "-"), """""", ""), "\", "") &
			    """,""cidade"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE([_cidade], "-"), """""", ""), "\", "") &
			    """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], "-"), """""", ""), "\", "") &
			    """,""label"":"""     & SUBSTITUTE(SUBSTITUTE(COALESCE([_ultLabel], "-"), """""", ""), "\", "") &
			    """,""status"":"""    & IF([_pedidos] >= 2, "Recorrente", "Convertido") &
			    """,""conversas"":"  & COALESCE([_qtdConv], 0) &
			    ",""fat"":"          & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""pedidos"":"      & COALESCE([_pedidos], 0) &
			    ",""dev"":"          & SUBSTITUTE(FORMAT(COALESCE([_dev], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_dev], 0), COALESCE([_fat], 0) + COALESCE([_dev], 0), 0) * 100, "0.00"), ",", ".") &
			    ",""diasUltCompra"":" & IF(ISBLANK([_ultCompra]), -1, INT(_hoje - [_ultCompra])) &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: 1e2e956d-89a0-4690-9dcd-57447edfc397

	/// Tabela detalhada de produtos vendidos para clientes Yuzap. Top 100.
	measure '_JSON Tabela Produto Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _filtroERP = TREATAS(SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _produtos =
			    CALCULATETABLE(
			        FILTER(
			            VALUES(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]),
			            NOT(ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO])) && DCVVQ_VENDAGERALTELEVENDAS[PRODUTO] <> ""
			        ),
			        _filtroERP
			    )
			VAR _com =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            _produtos,
			            "_grupo",    CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO])),
			            "_subgrupo", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[SUBGRUPOPROD])),
			            "_fat",      CALCULATE([Faturamento Total]),
			            "_peso",     CALCULATE([Peso Total Vendido]),
			            "_dev",      CALCULATE([Total Devoluções (R$)]),
			            "_clientes", CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]))
			        ),
			        _filtroERP
			    )
			VAR _top = TOPN(100, FILTER(_com, [_fat] > 0), [_fat], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _top,
			    "{""produto"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			    """,""grupo"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE([_grupo], "-"), """""", ""), "\", "") &
			    """,""subgrupo"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_subgrupo], "-"), """""", ""), "\", "") &
			    """,""fat"":"        & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""peso"":"         & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			    ",""dev"":"          & SUBSTITUTE(FORMAT(COALESCE([_dev], 0), "0.00"), ",", ".") &
			    ",""clientes"":"     & COALESCE([_clientes], 0) &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_dev], 0), COALESCE([_fat], 0) + COALESCE([_dev], 0), 0) * 100, "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_fat], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: 1339dc14-d5e6-4d1b-ba68-bb38906333b0

	/// Tabela detalhada de vendedores que atenderam clientes Yuzap.
