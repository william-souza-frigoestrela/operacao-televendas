			        DCVVQ_VENDAGERALTELEVENDAS[CLIENTE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _clientes,
			        "_cidade",     CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CIDADE])),
			        "_atividade",  CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE])),
			        "_porte",      CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[PORTE])),
			        "_fat",        [Faturamento Total],
			        "_devRS",      [Total Devoluções (R$)],
			        "_devPeso",    [Peso Total Devolvido],
			        "_catDominante",
			            CALCULATE(
			                MAXX(
			                    TOPN(
			                        1,
			                        FILTER(VALUES(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]), [Total Devoluções (R$)] > 0),
			                        [Total Devoluções (R$)],
			                        DESC
			                    ),
			                    DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]
			                )
			            )
			    )
			VAR _top = TOPN(200, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _top,
			    "{""cliente"":"""   & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE], """""", ""), "\", "") &
			    """,""cidade"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_cidade], "-"), """""", ""), "\", "") &
			    """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], "-"), """""", ""), "\", "") &
			    """,""porte"":"""     & SUBSTITUTE(SUBSTITUTE(COALESCE([_porte], "-"), """""", ""), "\", "") &
			    """,""categoria"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_catDominante], "-"), """""", ""), "\", "") &
			    """,""devRS"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""devPeso"":"     & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"     & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_devRS], 0), COALESCE([_fat], 0) + COALESCE([_devRS], 0), 0) * 100, "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: 3386b876-035b-42cf-b551-4f7e103054ba

	/// Tabela detalhada de produtos com devolucao (top 100). Grupo como tag.
	measure '_JSON Tabela Produto Devolucoes' =
			VAR _produtos =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[PRODUTO] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _produtos,
			        "_grupo",     CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[GRUPOPRODUTO])),
			        "_subgrupo",  CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[SUBGRUPOPROD])),
			        "_fat",       [Faturamento Total],
			        "_devRS",     [Total Devoluções (R$)],
			        "_devPeso",   [Peso Total Devolvido],
			        "_qtdLinhas", CALCULATE(COUNTROWS(DCVVQ_VENDAGERALTELEVENDAS), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0),
			        "_clientes",  [Clientes com Devolução]
			    )
			VAR _top = TOPN(100, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _top,
			    "{""produto"":"""   & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO], """""", ""), "\", "") &
			    """,""grupo"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE([_grupo], "-"), """""", ""), "\", "") &
			    """,""subgrupo"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_subgrupo], "-"), """""", ""), "\", "") &
			    """,""devRS"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""devPeso"":"     & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""qtdLinhas"":"   & COALESCE([_qtdLinhas], 0) &
			    ",""clientes"":"    & COALESCE([_clientes], 0) &
			    ",""taxaDev"":"     & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_devRS], 0), COALESCE([_fat], 0) + COALESCE([_devRS], 0), 0) * 100, "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: b8cc5a3a-41f2-402f-b961-a5cbfa5ee1a1

	/// Tabela detalhada de vendedores com devolucao. Supervisor e gerente como tags.
	measure '_JSON Tabela Vendedor Devolucoes' =
			VAR _vendedores =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _vendedores,
			        "_supervisor", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[SUPERVISOR])),
			        "_gerente",    CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[GERENTE])),
			        "_fat",        [Faturamento Total],
			        "_devRS",      [Total Devoluções (R$)],
			        "_devPeso",    [Peso Total Devolvido],
			        "_clientes",   [Clientes com Devolução]
			    )
			VAR _f = FILTER(_com, [_devRS] > 0)
			RETURN
			"[" & CONCATENATEX(
			    _f,
			    "{""vendedor"":"""  & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[VENDEDOR], """""", ""), "\", "") &
			    """,""supervisor"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_supervisor], "-"), """""", ""), "\", "") &
			    """,""gerente"":"""  & SUBSTITUTE(SUBSTITUTE(COALESCE([_gerente], "-"), """""", ""), "\", "") &
			    """,""devRS"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""devPeso"":"     & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""clientes"":"    & COALESCE([_clientes], 0) &
			    ",""taxaDev"":"     & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_devRS], 0), COALESCE([_fat], 0) + COALESCE([_devRS], 0), 0) * 100, "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: 245faed8-77f6-43d9-9462-3b7af2c7ed69

	/// Tabela detalhada de cidades com devolucao (top 50). UF como tag.
	measure '_JSON Tabela Cidade Devolucoes' =
			VAR _cidades =
			    FILTER(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]) &&
			        DCVVQ_VENDAGERALTELEVENDAS[CIDADE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _cidades,
			        "_uf",        CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[UF])),
			        "_fat",       [Faturamento Total],
			        "_devRS",     [Total Devoluções (R$)],
			        "_devPeso",   [Peso Total Devolvido],
			        "_clientes",  [Clientes com Devolução],
			        "_produtos",  CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[PRODUTO]), DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO] > 0)
			    )
			VAR _top = TOPN(50, FILTER(_com, [_devRS] > 0), [_devRS], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _top,
			    "{""cidade"":"""    & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[CIDADE], """""", ""), "\", "") &
			    """,""uf"":"""       & SUBSTITUTE(SUBSTITUTE(COALESCE([_uf], "-"), """""", ""), "\", "") &
			    """,""devRS"":"     & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""devPeso"":"     & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			    ",""clientes"":"    & COALESCE([_clientes], 0) &
			    ",""produtos"":"    & COALESCE([_produtos], 0) &
			    ",""taxaDev"":"     & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_devRS], 0), COALESCE([_fat], 0) + COALESCE([_devRS], 0), 0) * 100, "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_devRS], DESC
			) & "]"
		displayFolder: HTML Devolucoes
		lineageTag: f1ade644-e310-4e43-b9ab-1b5d82fdbc5e

	/// Script JS - v2. Ajustes: (1) fontes maiores na legenda da rosca; (2) rotulos de dados sobre cada ponto na evolucao mensal; (3) tooltip viewport-aware (reposiciona pra esquerda/cima quando ultrapassa borda).
	measure '_JS Devolucoes' =
			"<script>" & "(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(v); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fPct(v) { return (Number(v)||0).toFixed(2).replace('.',',') + '%'; }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function momClsInv(s) { if (!s || s === '--') return 'neu'; return s.indexOf('-') === 0 ? 'up' : (s.indexOf('+') === 0 ? 'down' : 'neu'); }
			  function svgDim(el, fbW, fbH) { var bb = el.getBoundingClientRect(); return [Math.round(bb.width) || fbW, Math.round(bb.height) || fbH]; }
			  function catColor(cat) {
			    var map = {
			      'Comercial':      {bg:'rgba(192,124,58,.15)', fg:'#995F2C'},
			      'Qualidade':      {bg:'rgba(160,72,72,.15)',  fg:'#7A2E2E'},
			      'Logística':      {bg:'rgba(74,110,138,.15)', fg:'#3A5872'},
			      'Indústria':      {bg:'rgba(78,125,98,.15)',  fg:'#3D6049'},
			      'Multi/Misto':    {bg:'rgba(184,147,90,.18)', fg:'#8A6740'},
			      'Fiscal':         {bg:'rgba(90,90,90,.15)',   fg:'#5A5A5A'},
			      'Administrativo': {bg:'rgba(58,36,16,.12)',   fg:'#3A2410'}
			    };
			    return map[cat] || {bg:'rgba(139,139,139,.12)', fg:'#5A5A5A'};
			  }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [
			      {bg:'rgba(184,147,90,.15)',fg:'#8A6740'},
			      {bg:'rgba(78,125,98,.15)',fg:'#3D6049'},
			      {bg:'rgba(74,110,138,.15)',fg:'#3A5872'},
			      {bg:'rgba(192,124,58,.15)',fg:'#995F2C'},
			      {bg:'rgba(58,36,16,.12)',fg:'#3A2410'},
			      {bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}
			    ];
			    return palette[Math.abs(h) % palette.length];
			  }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){
			    if (!ttEl) return;
			    ttEl.innerHTML = h;
			    ttEl.classList.add('on');
			    var ttW = ttEl.offsetWidth;
			    var ttH = ttEl.offsetHeight;
			    var vw = window.innerWidth || document.documentElement.clientWidth;
			    var vh = window.innerHeight || document.documentElement.clientHeight;
			    var x = e.clientX + 14;
			    var y = e.clientY - ttH - 10;
			    if (x + ttW > vw - 8) x = e.clientX - ttW - 14;
			    if (x < 8) x = 8;
			    if (y < 8) y = e.clientY + 18;
			    if (y + ttH > vh - 8) y = vh - ttH - 8;
			    ttEl.style.left = x + 'px';
			    ttEl.style.top = y + 'px';
			  };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  var kpiIcons = {
			    money:    ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>"",
			    scale:    ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M12 3v18M3 12h18M5 7l14 10M5 17L19 7'/></svg>"",
			    percent:  ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='19' y1='5' x2='5' y2='19'/><circle cx='6.5' cy='6.5' r='2.5'/><circle cx='17.5' cy='17.5' r='2.5'/></svg>"",
			    users:    ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'money',  label:'Total Devolvido',       val:fMK(K.totalRS||0),    sub:'MoM = <span class=\''+momClsInv(K.momRS)+'\'>'+(K.momRS||'-')+'</span>'},
			      {icon:'scale',  label:'Peso Devolvido (kg)',   val:fA(K.totalPeso||0),   sub:'MoM = <span class=\''+momClsInv(K.momPeso)+'\'>'+(K.momPeso||'-')+'</span>'},
			      {icon:'percent',label:'Taxa de Devolução',     val:fPct(K.taxaDev||0),   sub:'MoM = <span class=\''+momClsInv(K.momTaxa)+'\'>'+(K.momTaxa||'-')+'</span>'},
			      {icon:'users',  label:'Clientes com Devolução',val:fN(K.clientesDev||0), sub:'MoM = <span class=\''+momClsInv(K.momClientes)+'\'>'+(K.momClientes||'-')+'</span>'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  function renderRoscaCat(){
			    var el=document.getElementById('svgCat'); if(!el) return;
			    var d=svgDim(el,420,360); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var arr=(rJ('jMix')||[]).filter(function(d2){ return (Number(d2.val)||0) > 0; });
			    if(!arr.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    var total=arr.reduce(function(s,d2){ return s + (Number(d2.val)||0); }, 0);
			    if(total<=0) total=1;
			    var cx=W*0.30, cy=H/2;
			    var r=Math.min(W*0.26, H*0.40), ri=r*0.58;
			    var start=-Math.PI/2;
			    var svg='';
			    arr.forEach(function(d2){
			      var v=Number(d2.val)||0;
			      var ang=(v/total)*Math.PI*2;
			      var end=start+ang;
			      var largeArc = ang > Math.PI ? 1 : 0;
			      var x1=cx+r*Math.cos(start), y1=cy+r*Math.sin(start);
			      var x2=cx+r*Math.cos(end),   y2=cy+r*Math.sin(end);
			      var xi1=cx+ri*Math.cos(end), yi1=cy+ri*Math.sin(end);
			      var xi2=cx+ri*Math.cos(start), yi2=cy+ri*Math.sin(start);
			      var dPath='M '+x1.toFixed(2)+' '+y1.toFixed(2) +
			                ' A '+r.toFixed(2)+' '+r.toFixed(2)+' 0 '+largeArc+' 1 '+x2.toFixed(2)+' '+y2.toFixed(2) +
			                ' L '+xi1.toFixed(2)+' '+yi1.toFixed(2) +
			                ' A '+ri.toFixed(2)+' '+ri.toFixed(2)+' 0 '+largeArc+' 0 '+xi2.toFixed(2)+' '+yi2.toFixed(2) +
			                ' Z';
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var clr=catColor(d2.nome).fg;
			      var ttHtml='<b>'+escT(d2.nome)+'</b><br>Devolução: '+fMK(v)+'<br>Peso: '+fA(Number(d2.peso)||0)+' kg<br>'+pct+'% do total<br>'+(Number(d2.qtdTipos)||0)+' motivos distintos';
			      svg += ""<path class='donut-slice' d='""+dPath+""' fill='""+clr+""' stroke='#FFFFFF' stroke-width='2' onmousemove=\""tip(event,'""+ttHtml+""')\"" onmouseleave='tipOff()'/>"";
			      start=end;
			    });
			    svg += ""<text x='""+cx+""' y='""+(cy-4)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:24px;font-weight:700;font-family:Segoe UI,system-ui'>""+fMK(total)+""</text>"";
			    svg += ""<text x='""+cx+""' y='""+(cy+18)+""' text-anchor='middle' fill='#8B8B8B' style='font-size:12px;font-weight:600;letter-spacing:1.8px;font-family:Segoe UI,system-ui'>DEVOLUÇÃO</text>"";
			    var lx=W*0.58;
			    var step=48;
			    var ly=Math.max(32, (H - arr.length*step)/2 + 14);
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var clr=catColor(d2.nome).fg;
			      var y=ly + i*step;
			      svg += ""<rect x='""+lx+""' y='""+(y-12)+""' width='15' height='15' rx='3' fill='""+clr+""'/>"";
			      svg += ""<text x='""+(lx+22)+""' y='""+y+""' fill='#1A1A1A' style='font-size:15px;font-weight:600;font-family:Segoe UI,system-ui'>""+esc(d2.nome)+""</text>"";
			      svg += ""<text x='""+(lx+22)+""' y='""+(y+18)+""' style='font-size:14px;font-family:Segoe UI,system-ui'><tspan fill='#5A5A5A'>""+fMK(v)+""</tspan> <tspan fill='#B8935A' font-weight='700'>""+pct+""%</tspan></text>"";
			    });
			    el.innerHTML=svg;
			  }
			  function renderTopMotivos(){
			    var el=document.getElementById('motivosList'); if(!el) return;
			    var arr=(rJ('jMot')||[]).slice(0,10);
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var clr=catColor(d.categoria);
			      var tt='<b>'+escT(d.nome)+'</b><br>Categoria: '+escT(d.categoria)+'<br>Devolução: '+fMK(v)+'<br>Peso: '+fA(Number(d.peso)||0)+' kg<br>Clientes afetados: '+fN(Number(d.clientes)||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'><span class='cat-pill' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.categoria)+""</span> ""+esc(d.nome)+""</div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoEvo='val';
			  window.setModoEvo=function(m){ _modoEvo=m; document.querySelectorAll('#evoModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderEvolucao(); };
			  function renderEvolucao(){
			    var el=document.getElementById('evoChart'); if(!el) return;
			    var arr=rJ('jEvo')||[];
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var containerW = el.clientWidth || 900;
			    var minW = Math.max(containerW, arr.length * 64);
			    var W = minW, H = 320;
			    var P = {t:46, r:30, b:50, l:65};
			    var maxV = Math.max.apply(null, arr.map(function(d){ return Number(d[_modoEvo])||0; }).concat([1])) * 1.15;
			    var stepX = (W - P.l - P.r) / Math.max(arr.length - 1, 1);
			    var fmt = _modoEvo==='val' ? fMK : (_modoEvo==='peso' ? function(v){return fA(v)+' kg';} : fPct);
			    var fmtAxis = _modoEvo==='val' ? function(v){return 'R$ '+fA(v);} : (_modoEvo==='peso' ? function(v){return fA(v);} : function(v){return (Number(v)||0).toFixed(1).replace('.',',')+'%';});
			    var fmtLabel = _modoEvo==='val' ? function(v){return 'R$ '+fA(v);} : (_modoEvo==='peso' ? function(v){return fA(v);} : function(v){return (Number(v)||0).toFixed(2).replace('.',',')+'%';});
			    var label = _modoEvo==='val' ? 'Devolução R$' : (_modoEvo==='peso' ? 'Peso Devolvido' : 'Taxa de Devolução');
			    var uid='ev'+Math.floor(Math.random()*99999);
			    var svg = ""<defs><linearGradient id='area""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='.35'/><stop offset='100%' stop-color='#B8935A' stop-opacity='0'/></linearGradient></defs>"";
			    for (var i=0; i<=4; i++){
			      var y = P.t + (H - P.t - P.b) * i / 4;
			      var v = maxV * (1 - i/4);
			      svg += ""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      svg += ""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12px;font-family:Segoe UI,system-ui;font-weight:500'>""+fmtAxis(v)+""</text>"";
			    }
			    var pts = arr.map(function(d, i){
			      var v = Number(d[_modoEvo])||0;
			      var x = P.l + i * stepX;
			      var y = H - P.b - (v / maxV) * (H - P.t - P.b);
			      return {x:x, y:y, mes:d.mes, v:v, peso:d.peso, taxa:d.taxa, val:d.val};
			    });
			    var areaD = pts.map(function(p, i){ return (i===0?'M':'L')+p.x.toFixed(1)+','+p.y.toFixed(1); }).join(' ');
			    areaD += ' L'+pts[pts.length-1].x.toFixed(1)+','+(H-P.b)+' L'+pts[0].x.toFixed(1)+','+(H-P.b)+' Z';
			    var pathD = pts.map(function(p, i){ return (i===0?'M':'L')+p.x.toFixed(1)+','+p.y.toFixed(1); }).join(' ');
			    svg += ""<path d='""+areaD+""' fill='url(#area""+uid+"")' stroke='none'/>"";
			    svg += ""<path d='""+pathD+""' fill='none' stroke='#1A1A1A' stroke-width='2.5' stroke-linejoin='round' stroke-linecap='round'/>"";
			    pts.forEach(function(p){
			      var tt='<b>'+escT(p.mes)+'</b><br>Devolução: '+fMK(Number(p.val)||0)+'<br>Peso: '+fA(Number(p.peso)||0)+' kg<br>Taxa: '+fPct(Number(p.taxa)||0);
			      svg += ""<circle class='evo-pt' cx='""+p.x.toFixed(1)+""' cy='""+p.y.toFixed(1)+""' r='5' fill='#B8935A' stroke='#FFFFFF' stroke-width='2' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			    });
			    pts.forEach(function(p, i){
			      var lblY = Math.max(14, p.y - 14);
			      var lblAnchor = 'middle';
			      var lblX = p.x;
			      if (i === 0) { lblAnchor = 'start'; lblX = p.x - 4; }
			      else if (i === pts.length - 1) { lblAnchor = 'end'; lblX = p.x + 4; }
			      svg += ""<text x='""+lblX.toFixed(1)+""' y='""+lblY.toFixed(1)+""' text-anchor='""+lblAnchor+""' fill='#1A1A1A' style='font-size:11px;font-weight:700;font-family:Segoe UI,system-ui;font-variant-numeric:tabular-nums;pointer-events:none'>""+fmtLabel(p.v)+""</text>"";
			    });
			    pts.forEach(function(p){
			      svg += ""<text x='""+p.x.toFixed(1)+""' y='""+(H - P.b + 18)+""' text-anchor='middle' fill='#5A5A5A' style='font-size:11px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(p.mes)+""</text>"";
			    });
			    el.innerHTML = ""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  var _modoHier='cliente', _modoHierMm='rs';
			  window.setModoHier=function(m){ _modoHier=m; document.querySelectorAll('#hierToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.h===m); }); renderHierarchico(); };
			  window.setModoHierMm=function(m){ _modoHierMm=m; document.querySelectorAll('#hierModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderHierarchico(); };
			  function renderHierarchico(){
			    var el=document.getElementById('hierChart'); if(!el) return;
			    var sources={cliente:'jHc', produto:'jHp', vendedor:'jHv'};
			    var data=rJ(sources[_modoHier])||{rs:[],peso:[]};
			    var arr=(data[_modoHierMm]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var H=500;
			    var P={t:38, r:24, b:70, l:68};
			    var n=arr.length;
			    var containerW = el.clientWidth || 900;
			    var availW = containerW - P.l - P.r;
			    var minBarW = 30, maxBarW = 56, defaultGap = 18, maxGap = 40;
			    var idealBarW = (availW - (n-1)*defaultGap) / Math.max(n,1);
			    var barW, gap, contentW, startX;
			    if (idealBarW >= maxBarW) { barW=maxBarW; var rem=availW-n*barW; gap=n>1?Math.min(maxGap, rem/(n-1)):0; var totalBars=n*barW+(n-1)*gap; startX=P.l+Math.max(0,(availW-totalBars)/2); contentW=containerW; }
			    else if (idealBarW >= minBarW) { barW=idealBarW; gap=defaultGap; startX=P.l; contentW=containerW; }
			    else { barW=minBarW; gap=defaultGap; startX=P.l; contentW=n*barW+(n-1)*gap+P.l+P.r; }
			    var W = Math.max(contentW, containerW);
			    var mx = Math.max.apply(null, arr.map(function(d){ return Number(d.val)||0; }).concat([1])) * 1.10;
			    var isRS = _modoHierMm==='rs';
			    var fmtVal = isRS ? fMK : function(v){return fA(v)+' kg';};
			    var fmtAxis = isRS ? function(v){return 'R$ '+fA(v);} : fA;
			    var lblMm = isRS ? 'Devolução R$' : 'Peso Devolvido';
			    var uid='h'+Math.floor(Math.random()*99999);
			    var maxWordChars = barW < 40 ? 10 : 14;
			    var svg = ""<defs><linearGradient id='bg""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#A04848' stop-opacity='1'/><stop offset='100%' stop-color='#1A1A1A' stop-opacity='1'/></linearGradient></defs>"";
			    for (var i=0; i<=4; i++){
			      var y = P.t + (H - P.t - P.b) * i / 4;
			      var v = mx * (1 - i/4);
			      svg += ""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      if (i<4) svg += ""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12.5px;font-family:Segoe UI,system-ui;font-weight:500'>""+fmtAxis(v)+""</text>"";
			    }
			    arr.forEach(function(d, i){
			      var v = Number(d.val)||0;
			      var bh = Math.max(2, (v/mx) * (H - P.t - P.b));
			      var bx = startX + i*(barW+gap);
			      var by = H - P.b - bh;
			      var labelX = bx + barW/2;
			      var ctx = '';
			      if (_modoHier==='cliente') ctx = '<br>Cidade: '+escT(d.cidade||'-')+'<br>Atividade: '+escT(d.atividade||'-');
			      else if (_modoHier==='produto') ctx = '<br>Grupo: '+escT(d.grupo||'-');
			      else ctx = '<br>Supervisor: '+escT(d.supervisor||'-')+'<br>Clientes: '+fN(Number(d.clientes)||0);
			      var altMm = isRS ? ('<br>Peso: '+fA(Number(d.peso)||0)+' kg') : ('<br>Devolução R$: '+fMK(Number(d.rs)||0));
			      var tt = '<b>'+escT(d.nome)+'</b><br>'+lblMm+': '+fmtVal(v)+altMm+ctx;
			      svg += ""<rect class='vbar' x='""+bx.toFixed(1)+""' y='""+by.toFixed(1)+""' width='""+barW.toFixed(1)+""' height='""+bh.toFixed(1)+""' rx='3' fill='url(#bg""+uid+"")' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      var labelTop = isRS ? ('R$ '+fA(v)) : (fA(v)+' kg');
			      svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(by-8).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:700;font-variant-numeric:tabular-nums;font-family:Segoe UI,system-ui;pointer-events:none'>""+labelTop+""</text>"";
			      var words = d.nome.split(/\s+/);
			      var displayWords = words.slice(0, 4).map(function(w){ return w.length > maxWordChars ? w.slice(0, maxWordChars-2) + '..' : w; });
			      var nameY = H - P.b + 16;
			      displayWords.forEach(function(w, j){
			        svg += ""<text x='""+labelX.toFixed(1)+""' y='""+(nameY + j*14)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(w)+""</text>"";
			      });
			    });
			    el.innerHTML = ""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  function buildBarList(elId, jsonId, modoVar, contextFn){
			    var el=document.getElementById(elId); if(!el) return;
			    var data=rJ(jsonId)||{rs:[],peso:[]};
			    var arr=data[modoVar]||[];
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){ return Number(d.val)||0; }).concat([1]));
			    var isRS = modoVar==='rs';
			    var fmtVal = isRS ? fMK : function(v){return fA(v)+' kg';};
			    var lblMm = isRS ? 'Devolução R$' : 'Peso Devolvido';
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var altMm = isRS ? ('<br>Peso: '+fA(Number(d.peso)||0)+' kg') : ('<br>Devolução R$: '+fMK(Number(d.rs)||0));
			      var tt = '<b>'+escT(d.nome)+'</b><br>'+lblMm+': '+fmtVal(v)+altMm+contextFn(d);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fmtVal(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoCid='rs';
			  window.setModoCid=function(m){ _modoCid=m; document.querySelectorAll('#cidModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderCidades(); };
			  function renderCidades(){ buildBarList('cidList','jCd',_modoCid, function(d){ return '<br>UF: '+escT(d.uf||'-')+'<br>Clientes: '+fN(Number(d.clientes)||0); }); }
			  var _modoAtv='rs';
			  window.setModoAtv=function(m){ _modoAtv=m; document.querySelectorAll('#atvModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderAtividades(); };
			  function renderAtividades(){ buildBarList('atvList','jAtv',_modoAtv, function(d){ return '<br>Clientes afetados: '+fN(Number(d.clientes)||0); }); }
			  var _aba='motivo';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabelaBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='motivo'){ data=rJ('jTm')||[]; cols=[{k:'nome',t:'Motivo',cls:'name'},{k:'categoria',t:'Categoria',cls:'cat'},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'devPeso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'qtdLinhas',t:'Ocorrências',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN}]; }
			    else if(_aba==='cliente'){ data=rJ('jTc')||[]; cols=[{k:'cliente',t:'Cliente',cls:'name'},{k:'cidade',t:'Cidade',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'porte',t:'Porte',cls:'tag'},{k:'categoria',t:'Cat. dominante',cls:'cat'},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'devPeso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='produto'){ data=rJ('jTp')||[]; cols=[{k:'produto',t:'Produto',cls:'name'},{k:'grupo',t:'Grupo',cls:'tag'},{k:'subgrupo',t:'Subgrupo',cls:'tag'},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'devPeso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'qtdLinhas',t:'Ocorrências',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='vendedor'){ data=rJ('jTv')||[]; cols=[{k:'vendedor',t:'Vendedor',cls:'name'},{k:'supervisor',t:'Supervisor',cls:'tag'},{k:'gerente',t:'Gerente',cls:'tag'},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'devPeso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else { data=rJ('jTcd')||[]; cols=[{k:'cidade',t:'Cidade',cls:'name'},{k:'uf',t:'UF',cls:'tag'},{k:'devRS',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'devPeso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'produtos',t:'Produtos',cls:'num',fmt:fN},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null, data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>"" + cols.map(function(c){ return ""<th class='th-""+c.cls+""'>""+c.t+""</th>""; }).join('') + ""</tr></thead>"";
			    var body=""<tbody>"" + data.map(function(d){
			      return ""<tr>"" + cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){
			          var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100);
			          return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>"";
			        }
			        if(c.cls==='tag'){ var clr=tagColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='cat'){ var ccr=catColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+ccr.bg+"";color:""+ccr.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('') + ""</tr>"";
			    }).join('') + ""</tbody>"";
			    el.innerHTML=""<table class='tbl'>"" + head + body + ""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderRoscaCat(); renderTopMotivos(); renderEvolucao(); renderHierarchico(); renderCidades(); renderAtividades(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){
			    return ['jKpi','jMix','jMot','jEvo','jHc','jHp','jHv','jCd','jAtv','jTm','jTc','jTp','jTv','jTcd'].map(function(id){
			      var e=document.getElementById(id); if(!e) return '';
			      return e.textContent.length+'|'+e.textContent.slice(0,20);
			    }).join('~');
			  }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();" & "</script>"
		displayFolder: HTML Devolucoes
		lineageTag: 7d863e1e-bf07-4d19-bece-82bff42c6fa7

	/// Dashboard HTML Content da pagina Devolucoes - layout completo + JSONs + chama _JS Devolucoes.
	measure 'HTML Devolucoes' =
			"<style>:root {
			  --bg:    #EEEAE2;
			  --surf:  #FFFFFF;
			  --surf2: #F7F3EB;
			  --bd:    rgba(26,26,26,.07);
			  --bd2:   rgba(26,26,26,.15);
			  --t1:    #1A1A1A;
			  --t2:    #5A5A5A;
			  --t3:    #8B8B8B;
			  --gold:  #B8935A;
			  --goldS: #EAD9BE;
			  --dark:  #1E1E1E;
			  --grn:   #4E7D62;
			  --org:   #C07C3A;
			  --blu:   #4A6E8A;
			  --red:   #A04848;
			  --sh1:   0 1px 3px rgba(0,0,0,.06);
			  --sh2:   0 2px 10px rgba(0,0,0,.1);
			  --r:     10px;
			  --ease:  cubic-bezier(.4,0,.2,1);
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
			  background: var(--bg);
			  font-family: 'Segoe UI', system-ui, sans-serif;
			  font-size: 14px; color: var(--t1);
			  -webkit-font-smoothing: antialiased;
			  min-height: 100vh;
			}
			.dash { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }
			.hdr { display: flex; align-items: center; justify-content: space-between; padding: 0 2px; }
			.hdr-title { font-size: 25px; font-weight: 700; letter-spacing: -.5px; }
			.hdr-sub { font-size: 13px; color: var(--t3); margin-left: 8px; }
			.kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
			.kpi { background: var(--surf); border-radius: var(--r); padding: 14px 16px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.kpi-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
			.kpi-label { font-size: 12.5px; color: var(--t2); font-weight: 500; }
			.kpi-icon { width: 30px; height: 30px; border-radius: 8px; background: linear-gradient(135deg, var(--goldS), #F0E4CC); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
			.kpi-icon svg { width: 14px; height: 14px; }
			.kpi-val { font-size: 32px; font-weight: 700; letter-spacing: -.6px; line-height: 1.1; font-variant-numeric: tabular-nums; margin-top: 6px; }
			.kpi-sub { font-size: 12.5px; color: var(--t3); margin-top: 4px; }
			.kpi-sub .up { color: var(--grn); font-weight: 600; }
			.kpi-sub .down { color: var(--red); font-weight: 600; }
			.kpi-sub .neu { color: var(--gold); font-weight: 600; }
			.card { background: var(--surf); border-radius: var(--r); padding: 12px 14px; box-shadow: var(--sh1); border: 1px solid var(--bd); }
			.card-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; gap: 10px; flex-wrap: wrap; }
			.card-title { font-size: 16px; font-weight: 600; letter-spacing: -.2px; }
			.card-sub { font-size: 12px; color: var(--t3); margin-top: 1px; }
			.toggle-group { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
			.mini-toggle, .tri-toggle { display: flex; background: var(--surf2); border: 1px solid var(--bd2); border-radius: 100px; overflow: hidden; }
			.mini-toggle button, .tri-toggle button { padding: 5px 13px; font-size: 12px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; transition: all .15s; }
			.mini-toggle button.on, .tri-toggle button.on { background: var(--dark); color: #fff; border-radius: 100px; }
			.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; align-items: stretch; }
			.two-col > .card { display: flex; flex-direction: column; }
			.bars-list-scroll { display: flex; flex-direction: column; gap: 9px; max-height: 420px; overflow-y: auto; padding-right: 6px; }
			.bars-list-scroll::-webkit-scrollbar { width: 6px; }
			.bars-list-scroll::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.bars-list-scroll::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.bar-row { cursor: default; }
			.bar-head { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
			.bar-name { font-size: 13px; color: #1A1A1A; font-weight: 500; flex: 1; min-width: 0; line-height: 1.4; }
			.bar-val { font-size: 13px; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--t1); white-space: nowrap; }
			.bar-track { height: 6px; background: #EAD9BE; border-radius: 100px; overflow: hidden; }
			.bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg, #1A1A1A, var(--red)); width: 0; transition: width .8s var(--ease); }
			.cat-pill { display: inline-block; padding: 1px 8px; border-radius: 100px; font-size: 10.5px; font-weight: 700; letter-spacing: .2px; margin-right: 6px; vertical-align: middle; text-transform: uppercase; }
			.donut-card { display: flex; flex-direction: column; }
			.donut-svg-wrap { flex: 1; min-height: 320px; display: flex; }
			.donut-svg-wrap svg { width: 100%; height: 100%; display: block; }
			.donut-slice { transition: opacity .2s; cursor: pointer; }
			.donut-slice:hover { opacity: .85; }
			.chart-vert-wrap { overflow-x: auto; overflow-y: hidden; padding-bottom: 4px; }
			.chart-vert-wrap::-webkit-scrollbar { height: 8px; }
			.chart-vert-wrap::-webkit-scrollbar-track { background: rgba(26,26,26,.04); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb { background: var(--goldS); border-radius: 100px; }
			.chart-vert-wrap::-webkit-scrollbar-thumb:hover { background: var(--gold); }
			.chart-vert-wrap svg .vbar { transition: opacity .2s; cursor: pointer; }
			.chart-vert-wrap svg .vbar:hover { opacity: .80; }
			.chart-vert-wrap svg .evo-pt { transition: r .2s, opacity .2s; cursor: pointer; }
			.chart-vert-wrap svg .evo-pt:hover { r: 7; }
			.tabs { display: flex; gap: 4px; background: var(--surf2); padding: 3px; border-radius: 100px; border: 1px solid var(--bd2); flex-wrap: wrap; }
			.tab { padding: 6px 15px; font-size: 12.5px; font-weight: 600; border: none; background: transparent; color: var(--t2); cursor: pointer; font-family: inherit; border-radius: 100px; transition: all .15s; }
			.tab.on { background: var(--dark); color: #fff; }
			.table-wrap { overflow-x: auto; max-height: 480px; overflow-y: auto; border-radius: 8px; }
			.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
			.tbl th { position: sticky; top: 0; background: var(--surf2); padding: 10px 12px; text-align: left; font-weight: 600; color: var(--t2); border-bottom: 1px solid var(--bd2); font-size: 12px; text-transform: uppercase; letter-spacing: .3px; z-index: 2; }
			.tbl th.th-num { text-align: right; }
			.tbl td { padding: 7px 10px; border-bottom: 1px solid var(--bd); vertical-align: middle; }
			.tbl tr:hover td { background: var(--surf2); }
			.tbl td.td-name { font-weight: 500; color: var(--t1); }
			.tbl td.td-tag { color: var(--t2); font-size: 12px; }
			.tbl td.td-num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: var(--t1); min-width: 90px; }
			.cell-val { display: block; }
			.cell-bar { height: 3px; background: rgba(26,26,26,.04); border-radius: 100px; overflow: hidden; margin-top: 3px; }
			.cell-fill { height: 100%; background: linear-gradient(90deg, #1A1A1A, var(--red)); border-radius: 100px; }
			.tag-badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 11.5px; font-weight: 600; letter-spacing: .2px; white-space: nowrap; }
			.tt { position: fixed; background: #1E1E1E; color: #fff; padding: 7px 12px; border-radius: 7px; font-size: 12.5px; pointer-events: none; opacity: 0; transition: opacity .15s; z-index: 9999; white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
			.tt.on { opacity: 1; }
			.tt b { color: #D4B687; }
			</style>" &
			"<div class='dash'>
			  <div class='hdr'>
			    <div>
			      <span class='hdr-title'>Devoluções</span>
			      <span class='hdr-sub'>Onde está o gargalo e quem está envolvido</span>
			    </div>
			  </div>
			  <div class='kpi-row' id='kpiGrid'></div>
			  <div class='two-col'>
			    <div class='card donut-card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Mix por Categoria</div>
			          <div class='card-sub'>Distribuição do R$ devolvido pelas áreas responsáveis</div>
			        </div>
			      </div>
			      <div class='donut-svg-wrap'><svg id='svgCat' preserveAspectRatio='xMidYMid meet'></svg></div>
			    </div>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Top 10 Motivos</div>
			          <div class='card-sub'>Tipos específicos com maior impacto - tag indica a categoria</div>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='motivosList'></div>
			    </div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div>
			        <div class='card-title'>Evolução Mensal</div>
			        <div class='card-sub'>Série temporal das devoluções - escolha o indicador</div>
			      </div>
			      <div class='mini-toggle' id='evoModoToggle'>
			        <button class='on' data-m='val' onclick='setModoEvo(&quot;val&quot;)'>Valor R$</button>
			        <button data-m='peso' onclick='setModoEvo(&quot;peso&quot;)'>Peso</button>
			        <button data-m='taxa' onclick='setModoEvo(&quot;taxa&quot;)'>Taxa %</button>
			      </div>
			    </div>
			    <div class='chart-vert-wrap' id='evoChart'></div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div>
			        <div class='card-title'>Top 15 - Análise Hierárquica</div>
			        <div class='card-sub'>Quem mais devolveu - escolha o nível e a métrica</div>
			      </div>
			      <div class='toggle-group'>
			        <div class='tri-toggle' id='hierToggle'>
			          <button class='on' data-h='cliente' onclick='setModoHier(&quot;cliente&quot;)'>Cliente</button>
			          <button data-h='produto' onclick='setModoHier(&quot;produto&quot;)'>Produto</button>
			          <button data-h='vendedor' onclick='setModoHier(&quot;vendedor&quot;)'>Vendedor</button>
			        </div>
			        <div class='mini-toggle' id='hierModoToggle'>
			          <button class='on' data-m='rs' onclick='setModoHierMm(&quot;rs&quot;)'>Valor R$</button>
			          <button data-m='peso' onclick='setModoHierMm(&quot;peso&quot;)'>Peso</button>
			        </div>
			      </div>
			    </div>
			    <div class='chart-vert-wrap' id='hierChart'></div>
			  </div>
			  <div class='two-col'>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Top Cidades com Devolução</div>
			          <div class='card-sub'>Onde acontecem as devoluções</div>
			        </div>
			        <div class='mini-toggle' id='cidModoToggle'>
			          <button class='on' data-m='rs' onclick='setModoCid(&quot;rs&quot;)'>R$</button>
			          <button data-m='peso' onclick='setModoCid(&quot;peso&quot;)'>Peso</button>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='cidList'></div>
			    </div>
			    <div class='card'>
			      <div class='card-head'>
			        <div>
			          <div class='card-title'>Top Atividades com Devolução</div>
			          <div class='card-sub'>Que perfil de cliente devolve mais</div>
			        </div>
			        <div class='mini-toggle' id='atvModoToggle'>
			          <button class='on' data-m='rs' onclick='setModoAtv(&quot;rs&quot;)'>R$</button>
			          <button data-m='peso' onclick='setModoAtv(&quot;peso&quot;)'>Peso</button>
			        </div>
			      </div>
			      <div class='bars-list-scroll' id='atvList'></div>
			    </div>
			  </div>
			  <div class='card'>
			    <div class='card-head'>
			      <div><div class='card-title'>Detalhamento</div><div class='card-sub'>Análise por dimensão - mini-barras nas colunas R$</div></div>
			      <div class='tabs' id='abasTabs'>
			        <button class='tab on' data-aba='motivo' onclick='setAba(&quot;motivo&quot;)'>Motivo</button>
			        <button class='tab' data-aba='cliente' onclick='setAba(&quot;cliente&quot;)'>Cliente</button>
			        <button class='tab' data-aba='produto' onclick='setAba(&quot;produto&quot;)'>Produto</button>
			        <button class='tab' data-aba='vendedor' onclick='setAba(&quot;vendedor&quot;)'>Vendedor</button>
			        <button class='tab' data-aba='cidade' onclick='setAba(&quot;cidade&quot;)'>Cidade</button>
			      </div>
			    </div>
			    <div class='table-wrap' id='tabelaBox'></div>
			  </div>
			</div>
			<div class='tt' id='tt'></div>" &
			"<script type='application/json' id='jKpi'>" & [_JSON KPIs Devolucoes] & "</script>" &
			"<script type='application/json' id='jMix'>" & [_JSON Mix Categoria Devolucoes] & "</script>" &
			"<script type='application/json' id='jMot'>" & [_JSON Top Motivos Devolucoes] & "</script>" &
			"<script type='application/json' id='jEvo'>" & [_JSON Evolucao Mensal Devolucoes] & "</script>" &
			"<script type='application/json' id='jHc'>"  & [_JSON Top Cliente Devolucoes] & "</script>" &
			"<script type='application/json' id='jHp'>"  & [_JSON Top Produto Devolucoes] & "</script>" &
			"<script type='application/json' id='jHv'>"  & [_JSON Top Vendedor Devolucoes] & "</script>" &
			"<script type='application/json' id='jCd'>"  & [_JSON Top Cidade Devolucoes] & "</script>" &
			"<script type='application/json' id='jAtv'>" & [_JSON Top Atividade Devolucoes] & "</script>" &
			"<script type='application/json' id='jTm'>"  & [_JSON Tabela Motivo Devolucoes] & "</script>" &
			"<script type='application/json' id='jTc'>"  & [_JSON Tabela Cliente Devolucoes] & "</script>" &
			"<script type='application/json' id='jTp'>"  & [_JSON Tabela Produto Devolucoes] & "</script>" &
			"<script type='application/json' id='jTv'>"  & [_JSON Tabela Vendedor Devolucoes] & "</script>" &
			"<script type='application/json' id='jTcd'>" & [_JSON Tabela Cidade Devolucoes] & "</script>" &
			[_JS Devolucoes]
		displayFolder: HTML Devolucoes
		lineageTag: ef5eb680-1510-471b-9049-e712a0a3aa94

	/// JSON com dados dos 4 KPIs da pagina Yuzap x ERP.
	measure '_JSON KPIs Yz' =
			"{""identificados"":" & COALESCE([Yuzap - Clientes Identificados], 0) &
			",""momIdentificados"":""" & COALESCE([Yuzap - MoM Clientes %], "--") & """" &
			",""convertidos"":" & COALESCE([Yuzap - Clientes Convertidos], 0) &
			",""perdidos"":" & COALESCE([Yuzap - Clientes Perdidos], 0) &
			",""conversao"":" & SUBSTITUTE(FORMAT(COALESCE([Yuzap - % Conversão], 0) * 100, "0.00"), ",", ".") &
			",""momConversao"":""" & COALESCE([Yuzap - MoM Conversão %], "--") & """" &
			",""fat"":" & SUBSTITUTE(FORMAT(COALESCE([Yuzap - Faturamento], 0), "0.00"), ",", ".") &
			",""momFat"":""" & COALESCE([Yuzap - MoM Faturamento %], "--") & """" &
			",""taxaDev"":" & SUBSTITUTE(FORMAT(COALESCE([Yuzap - Taxa Devolução %], 0) * 100, "0.00"), ",", ".") &
			",""momDev"":""" & COALESCE([Yuzap - MoM Devoluções %], "--") & """" &
			",""conversas"":" & COALESCE([Yuzap - Conversas], 0) &
			",""pedidos"":" & COALESCE([Yuzap - Pedidos], 0) &
			",""ticket"":" & SUBSTITUTE(FORMAT(COALESCE([Yuzap - Ticket Médio], 0), "0.00"), ",", ".") &
			"}"
		displayFolder: HTML Yuzap
		lineageTag: 28c246a4-9cf9-402a-9778-4e5c7c9b8d0c

	/// Dados do funil de conversao Yuzap. Etapas: Identificados -> Convertidos -> Recompraram (2+ pedidos) -> Sem Devolucao.
	measure '_JSON Funil Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _yzAsSeq = SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente]))
			VAR _filtroERP = TREATAS(_yzAsSeq, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _identificados = COUNTROWS(_yz)
			VAR _convertidos =
			    CALCULATE(
			        DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			        _filtroERP
			    )
			VAR _recorrentes =
			    CALCULATE(
			        COUNTROWS(
			            FILTER(
			                ADDCOLUMNS(
			                    VALUES(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			                    "_p", [Total de Pedidos]
			                ),
			                [_p] >= 2
			            )
			        ),
			        _filtroERP
			    )
			VAR _semDev =
			    CALCULATE(
			        COUNTROWS(
			            FILTER(
			                ADDCOLUMNS(
			                    VALUES(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			                    "_d", [Total Devoluções (R$)]
			                ),
			                COALESCE([_d], 0) = 0
			            )
			        ),
			        _filtroERP
			    )
			RETURN
			"[" &
			"{""nome"":""Identificados no Yuzap"",""val"":" & COALESCE(_identificados, 0) & ",""desc"":""Clientes com código no Yuzap""}," &
			"{""nome"":""Convertidos no ERP"",""val"":" & COALESCE(_convertidos, 0) & ",""desc"":""Compraram pelo menos 1x""}," &
			"{""nome"":""Recorrentes"",""val"":" & COALESCE(_recorrentes, 0) & ",""desc"":""Com 2+ pedidos""}," &
			"{""nome"":""Sem Devolução"",""val"":" & COALESCE(_semDev, 0) & ",""desc"":""Convertidos sem nenhuma devolução""}" &
			"]"
		displayFolder: HTML Yuzap
		lineageTag: ca500081-22cc-4105-aaf7-83c1a1e08d84

	/// Conversao por Label Yuzap. Para cada label, clientes distintos com esse label, quantos converteram no ERP, % conversao e faturamento.
	measure '_JSON Por Label Yz' =
			VAR _labels =
			    FILTER(
			        VALUES(F_Yuzap_Conversas[Labels]),
			        NOT(ISBLANK(F_Yuzap_Conversas[Labels])) &&
			        F_Yuzap_Conversas[Labels] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _labels,
			        "_clientes",
			            CALCULATE(
			                DISTINCTCOUNT(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			                NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			                F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			            ),
			        "_convertidos",
			            VAR _seqs =
			                CALCULATETABLE(
			                    VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			                    NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			                    F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			                )
			            VAR _f = TREATAS(SELECTCOLUMNS(_seqs, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			            RETURN CALCULATE(DISTINCTCOUNT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]), _f),
			        "_fat",
			            VAR _seqs =
			                CALCULATETABLE(
			                    VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			                    NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			                    F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			                )
			            VAR _f = TREATAS(SELECTCOLUMNS(_seqs, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			            RETURN CALCULATE([Faturamento Total], _f)
			    )
			VAR _f = FILTER(_com, [_clientes] > 0)
			RETURN
			"[" & CONCATENATEX(
			    _f,
			    "{""label"":""" & SUBSTITUTE(SUBSTITUTE(F_Yuzap_Conversas[Labels], """""", ""), "\", "") &
			    """,""clientes"":" & COALESCE([_clientes], 0) &
			    ",""convertidos"":" & COALESCE([_convertidos], 0) &
			    ",""taxa"":" & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_convertidos], 0), COALESCE([_clientes], 0), 0) * 100, "0.00"), ",", ".") &
			    ",""fat"":" & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    "}",
			    ",",
			    [_clientes], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: b9a0601b-fe5b-400a-a24d-0380d438626d

	/// Lista dos clientes Yuzap perdidos (identificados mas sem venda no ERP). Inclui codigo, nome, telefone, qtd conversas, ultimo label, ultimo agente, data ultima conversa e dias desde a conversa.
	measure '_JSON Perdidos Yz' =
			VAR _yzAll =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _erpClientes =
			    SELECTCOLUMNS(
			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE]),
			        "x", FORMAT(DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE], "0")
			    )
			VAR _perdidos =
			    FILTER(
			        _yzAll,
			        NOT(F_Yuzap_Conversas[data.attr_cdigo_cliente] IN _erpClientes)
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _perdidos,
			        "_nome",       CALCULATE(MAX(F_Yuzap_Conversas[Nome Contato])),
			        "_tel",        CALCULATE(MAX(F_Yuzap_Conversas[telefone_contato])),
			        "_qtdConv",    CALCULATE(COUNTROWS(F_Yuzap_Conversas)),
			        "_ultData",    CALCULATE(MAX(F_Yuzap_Conversas[Data Atualizacao])),
			        "_ultLabel",
			            VAR _md = CALCULATE(MAX(F_Yuzap_Conversas[Data Atualizacao]))
			            RETURN CALCULATE(MAX(F_Yuzap_Conversas[Labels]), F_Yuzap_Conversas[Data Atualizacao] = _md),
			        "_ultAgente",
			            VAR _md = CALCULATE(MAX(F_Yuzap_Conversas[Data Atualizacao]))
			            RETURN CALCULATE(MAX(F_Yuzap_Conversas[Agente Responsavel]), F_Yuzap_Conversas[Data Atualizacao] = _md)
			    )
			VAR _hoje = TODAY()
			RETURN
			"[" & CONCATENATEX(
			    _com,
			    "{""codigo"":""" & SUBSTITUTE(SUBSTITUTE(F_Yuzap_Conversas[data.attr_cdigo_cliente], """""", ""), "\", "") &
			    """,""nome"":"""      & SUBSTITUTE(SUBSTITUTE(COALESCE([_nome], "-"), """""", ""), "\", "") &
			    """,""tel"":"""       & SUBSTITUTE(SUBSTITUTE(COALESCE([_tel], "-"), """""", ""), "\", "") &
			    """,""conversas"":"  & COALESCE([_qtdConv], 0) &
			    ",""label"":"""      & SUBSTITUTE(SUBSTITUTE(COALESCE([_ultLabel], "-"), """""", ""), "\", "") &
			    """,""agente"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_ultAgente], "-"), """""", ""), "\", "") &
			    """,""data"":"""     & IF(ISBLANK([_ultData]), "-", FORMAT([_ultData], "dd/MM/yyyy")) &
			    """,""dias"":"       & IF(ISBLANK([_ultData]), 0, INT(_hoje - [_ultData])) &
			    "}",
			    ",",
			    [_ultData], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: 41ec7b4a-b00f-474e-bd15-672d589303e8

	/// Evolucao mensal dos clientes Yuzap. v1 - ignora filtro de D_Calendario (mostra todos meses do dataset).
	measure '_JSON Evolucao Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			        NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])),
			        F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			    )
			VAR _filtroERP = TREATAS(SELECTCOLUMNS(_yz, "x", VALUE(F_Yuzap_Conversas[data.attr_cdigo_cliente])), DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			VAR _meses =
			    CALCULATETABLE(
			        FILTER(
			            SUMMARIZE(D_Calendario, D_Calendario[Mês/Ano]),
			            CALCULATE([Faturamento Total], _filtroERP) > 0
			        ),
			        REMOVEFILTERS(D_Calendario)
			    )
			VAR _com =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            _meses,
			            "_fat",     CALCULATE([Faturamento Total], _filtroERP),
			            "_peso",    CALCULATE([Peso Total Vendido], _filtroERP),
			            "_pedidos", CALCULATE([Total de Pedidos], _filtroERP),
			            "_dev",     CALCULATE([Total Devoluções (R$)], _filtroERP),
			            "_ordem",   CALCULATE(MIN(D_Calendario[Data]))
			        ),
			        REMOVEFILTERS(D_Calendario)
			    )
			VAR _ordenado = TOPN(24, _com, [_ordem], ASC)
			RETURN
			"[" & CONCATENATEX(
			    _ordenado,
