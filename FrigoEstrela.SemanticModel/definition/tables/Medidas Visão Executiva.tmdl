			        VALUES(DCVVQ_VENDAGERALTELEVENDAS[PORTE]),
			        NOT ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[PORTE]) && DCVVQ_VENDAGERALTELEVENDAS[PORTE] <> ""
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _todos,
			        "_fat",      [Faturamento Total],
			        "_peso",     [Peso Total Vendido],
			        "_clientes", [Total Clientes Ativos],
			        "_pedidos",  [Total de Pedidos],
			        "_devRS",    [Total Devoluções (R$)],
			        "_devPeso",  [Peso Total Devolvido]
			    )
			VAR _venda = FILTER(_com, [_fat] > 0)
			VAR _dev   = FILTER(_com, [_devRS] > 0)
			VAR _arrVenda =
			    "[" & CONCATENATEX(
			        _venda,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PORTE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			        ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_peso], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_fat], DESC
			    ) & "]"
			VAR _arrDev =
			    "[" & CONCATENATEX(
			        _dev,
			        "{""nome"":""" & SUBSTITUTE(SUBSTITUTE(DCVVQ_VENDAGERALTELEVENDAS[PORTE], """""", ""), "\", "") &
			        """,""val"":"      & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			        ",""peso"":"       & SUBSTITUTE(FORMAT(COALESCE([_devPeso], 0), "0.00"), ",", ".") &
			        ",""clientes"":"   & COALESCE([_clientes], 0) &
			        ",""pedidos"":"    & COALESCE([_pedidos], 0) &
			        "}",
			        ",",
			        [_devRS], DESC
			    ) & "]"
			RETURN
			"{""venda"":" & _arrVenda & ",""devolucao"":" & _arrDev & "}"
