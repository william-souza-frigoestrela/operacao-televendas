			    ",""devRS"":"        & SUBSTITUTE(FORMAT(COALESCE([_devRS], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_devRS], 0), COALESCE([_fat], 0) + COALESCE([_devRS], 0), 0) * 100, "0.00"), ",", ".") &
