	/// JavaScript da pagina Yuzap x ERP. Renderiza: KPIs, Funil, Por Label, Perdidos, Evolucao, Top Hierarquico (Produto/Vendedor), Bar List (Cidade/Atividade), Rosca Cat Dev, Top Motivos, Tabela 5 abas.
	measure '_JS Yz' =
			"<script>" & "(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(v); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fPct(v) { return (Number(v)||0).toFixed(2).replace('.',',') + '%'; }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function svgDim(el, fbW, fbH) { var bb = el.getBoundingClientRect(); return [Math.round(bb.width) || fbW, Math.round(bb.height) || fbH]; }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [{bg:'rgba(184,147,90,.15)',fg:'#8A6740'},{bg:'rgba(78,125,98,.15)',fg:'#3D6049'},{bg:'rgba(74,110,138,.15)',fg:'#3A5872'},{bg:'rgba(192,124,58,.15)',fg:'#995F2C'},{bg:'rgba(58,36,16,.12)',fg:'#3A2410'},{bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}];
			    return palette[Math.abs(h) % palette.length];
			  }
			  function statusBadge(s){ if(s==='Convertido') return {bg:'rgba(78,125,98,.18)',fg:'#3D6049'}; if(s==='Recorrente') return {bg:'rgba(184,147,90,.20)',fg:'#8A6740'}; return {bg:'rgba(160,72,72,.15)',fg:'#A04848'}; }
			  function catColor(c){ if(c && c.indexOf('Comercial')===0) return {bg:'rgba(74,110,138,.18)',fg:'#3A5872'}; if(c && c.indexOf('Qualidade')===0) return {bg:'rgba(160,72,72,.16)',fg:'#A04848'}; if(c && (c.indexOf('Logistica')===0||c.indexOf('Log')===0)) return {bg:'rgba(192,124,58,.18)',fg:'#995F2C'}; if(c && (c.indexOf('Industria')===0||c.indexOf('Ind')===0)) return {bg:'rgba(78,125,98,.18)',fg:'#3D6049'}; return tagColor(c); }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){ if (!ttEl) return; ttEl.innerHTML = h; ttEl.classList.add('on'); var ww=window.innerWidth, x=e.clientX+14; if(x+260>ww) x=ww-280; ttEl.style.left = x+'px'; ttEl.style.top = (e.clientY-36)+'px'; };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  var kpiIcons = {
			    users: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>"",
			    target: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg>"",
			    money: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>"",
			    alert: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/><line x1='12' y1='9' x2='12' y2='13'/><line x1='12' y1='17' x2='12.01' y2='17'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'users',  label:'Clientes Identificados', val:fN(K.identificados||0), sub:'<span>'+fN(K.conversas||0)+' conversas no Yuzap</span>'},
			      {icon:'target', label:'% Conversao Yuzap->ERP', val:fPct(K.conversao||0),   sub:'<span>'+fN(K.convertidos||0)+' convertidos / '+fN(K.perdidos||0)+' perdidos</span>'},
			      {icon:'money',  label:'Faturamento Gerado',     val:fMK(K.fat||0),          sub:'MoM = <span class=\\''+momCls(K.momFat)+'\\'>'+(K.momFat||'-')+'</span>'},
			      {icon:'alert',  label:'Taxa de Devolucao',      val:fPct(K.taxaDev||0),     sub:'MoM = <span class=\\''+momCls(K.momDev)+'\\'>'+(K.momDev||'-')+'</span>'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  function renderFunil(){
			    var el=document.getElementById('funilBox'); if(!el) return;
			    var data=rJ('jFn')||[]; if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Number(data[0].val)||1;
			    el.innerHTML=data.map(function(d,i){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var pct=i===0?100:(v/(Number(data[0].val)||1))*100;
			      var pctTxt=pct.toFixed(1).replace('.',',')+'%';
			      var colors=['#1A1A1A','#4E7D62','#B8935A','#4A6E8A'];
			      var c=colors[i % colors.length];
			      var tt='<b>'+escT(d.nome)+'</b><br>'+escT(d.desc)+'<br>Total: '+fN(v)+'<br>'+pctTxt+' do topo do funil';
			      return ""<div class='funil-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='funil-head'><div class='funil-name'>""+esc(d.nome)+"" <span class='funil-desc'>""+esc(d.desc)+""</span></div><div class='funil-val'>""+fN(v)+"" <span class='funil-pct'>(""+pctTxt+"")</span></div></div><div class='funil-track'><div class='funil-fill' data-w='""+w+""' style='background:""+c+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.funil-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  function renderPorLabel(){
			    var el=document.getElementById('porLabelBox'); if(!el) return;
			    var data=rJ('jLb')||[]; if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mxFat=Math.max.apply(null,data.map(function(d){return Number(d.fat)||0;}).concat([1]));
			    var mxCli=Math.max.apply(null,data.map(function(d){return Number(d.clientes)||0;}).concat([1]));
			    var head=""<thead><tr><th class='th-name'>Label Yuzap</th><th class='th-num'>Clientes</th><th class='th-num'>Convertidos</th><th class='th-num'>% Conv.</th><th class='th-num'>Faturamento</th></tr></thead>"";
			    var body=""<tbody>""+data.map(function(d){
			      var cli=Number(d.clientes)||0, conv=Number(d.convertidos)||0, taxa=Number(d.taxa)||0, fat=Number(d.fat)||0;
			      var wCli=(cli/mxCli)*100, wFat=(fat/mxFat)*100;
			      var taxaCls = taxa>=70?'pct-hi':(taxa>=30?'pct-md':'pct-lo');
			      var clr=tagColor(d.label);
			      return ""<tr><td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.label)+""</span></td><td class='td-num'><div class='cell-val'>""+fN(cli)+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+wCli.toFixed(1)+""%'></div></div></td><td class='td-num'>""+fN(conv)+""</td><td class='td-num ""+taxaCls+""'>""+fPct(taxa)+""</td><td class='td-num'><div class='cell-val'>""+fMK(fat)+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+wFat.toFixed(1)+""%'></div></div></td></tr>"";
			    }).join('')+""</tbody>"";
			    el.innerHTML=""<table class='tbl'>""+head+body+""</table>"";
			  }
			  var _perdPg=0, _perdPSize=20;
			  window.setPerdPg=function(dir){ var data=rJ('jPe')||[]; var maxPg=Math.max(0,Math.ceil(data.length/_perdPSize)-1); _perdPg=Math.max(0,Math.min(maxPg,_perdPg+dir)); renderPerdidos(); };
			  function renderPerdidos(){
			    var el=document.getElementById('perdidosBox'); if(!el) return;
			    var data=rJ('jPe')||[]; if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem clientes perdidos</div>""; return; }
			    var total=data.length, maxPg=Math.max(0,Math.ceil(total/_perdPSize)-1);
			    if(_perdPg>maxPg) _perdPg=maxPg;
			    var start=_perdPg*_perdPSize, end=Math.min(start+_perdPSize,total);
			    var page=data.slice(start,end);
			    var head=""<thead><tr><th class='th-name'>Cliente</th><th class='th-name'>Codigo</th><th class='th-name'>Telefone</th><th class='th-num'>Conversas</th><th class='th-name'>Ultimo Label</th><th class='th-name'>Agente</th><th class='th-name'>Ultima Atividade</th><th class='th-num'>Dias</th></tr></thead>"";
			    var body=""<tbody>""+page.map(function(d){
			      var clr=tagColor(d.label);
			      var dias=Number(d.dias)||0;
			      var diasCls=dias>30?'pct-lo':(dias>7?'pct-md':'pct-hi');
			      return ""<tr><td class='td-name'>""+esc(d.nome)+""</td><td class='td-mono'>""+esc(d.codigo)+""</td><td class='td-mono'>""+esc(d.tel)+""</td><td class='td-num'>""+fN(d.conversas)+""</td><td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.label||'-')+""</span></td><td class='td-name'>""+esc(d.agente)+""</td><td class='td-name'>""+esc(d.data)+""</td><td class='td-num ""+diasCls+""'>""+fN(dias)+""</td></tr>"";
			    }).join('')+""</tbody>"";
			    var pager=""<div class='pager'><button ""+(_perdPg===0?'disabled':'')+"" onclick='setPerdPg(-1)'>< Anterior</button><span>Pagina ""+(_perdPg+1)+"" de ""+(maxPg+1)+"" - mostrando ""+(start+1)+""-""+end+"" de ""+total+"" perdidos</span><button ""+(_perdPg>=maxPg?'disabled':'')+"" onclick='setPerdPg(1)'>Proximo ></button></div>"";
			    el.innerHTML=""<table class='tbl tbl-compact'>""+head+body+""</table>""+pager;
			  }
			  var _modoEvo='val';
			  window.setModoEvo=function(m){ _modoEvo=m; document.querySelectorAll('#evoModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderEvolucao(); };
			  function renderEvolucao(){
			    var el=document.getElementById('svgEvo'); if(!el) return;
			    var d=svgDim(el,900,300); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var data=rJ('jEv')||[]; if(!data.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    var P={t:34,r:34,b:50,l:64};
			    var n=data.length;
			    var vals=data.map(function(r){ return Number(r[_modoEvo])||0; });
			    var mx=Math.max.apply(null,vals.concat([1]))*1.18;
			    var stepX=(W-P.l-P.r)/Math.max(1,n-1);
			    var fmtV = _modoEvo==='val'||_modoEvo==='dev'? fMK : (_modoEvo==='peso'? function(v){return fA(v)+' kg';} : fN);
			    var labels={val:'Faturamento',peso:'Peso',pedidos:'Pedidos',dev:'Devolucao'};
			    var color = _modoEvo==='dev' ? '#A04848' : '#B8935A';
			    var svg='';
			    for(var i=0;i<=4;i++){
			      var y=P.t+(H-P.t-P.b)*i/4;
			      var v=mx*(1-i/4);
			      svg+=""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      if(i<4) svg+=""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12px;font-family:Segoe UI,system-ui'>""+fA(v)+""</text>"";
			    }
			    var pts=data.map(function(r,i){ var x=P.l+i*stepX; var v=Number(r[_modoEvo])||0; var y=P.t+(H-P.t-P.b)*(1-v/mx); return {x:x,y:y,v:v,r:r}; });
			    var path = pts.map(function(p,i){ return (i===0?'M':'L')+p.x.toFixed(1)+' '+p.y.toFixed(1); }).join(' ');
			    var area = path + ' L '+pts[pts.length-1].x.toFixed(1)+' '+(H-P.b)+' L '+pts[0].x.toFixed(1)+' '+(H-P.b)+' Z';
			    var uid='ev'+Math.floor(Math.random()*99999);
			    svg+=""<defs><linearGradient id='""+uid+""' x1='0' y1='0' x2='0' y2='1'><stop offset='0%' stop-color='""+color+""' stop-opacity='.25'/><stop offset='100%' stop-color='""+color+""' stop-opacity='0'/></linearGradient></defs>"";
			    svg+=""<path d='""+area+""' fill='url(#""+uid+"")'/>"";
			    svg+=""<path d='""+path+""' fill='none' stroke='""+color+""' stroke-width='2.5'/>"";
			    pts.forEach(function(p){
			      var tt='<b>'+escT(p.r.mes)+'</b><br>Faturamento: '+fMK(p.r.val)+'<br>Peso: '+fA(p.r.peso)+' kg<br>Pedidos: '+fN(p.r.pedidos)+'<br>Devolucao: '+fMK(p.r.dev);
			      svg+=""<circle cx='""+p.x.toFixed(1)+""' cy='""+p.y.toFixed(1)+""' r='4' fill='#fff' stroke='""+color+""' stroke-width='2' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg+=""<text x='""+p.x.toFixed(1)+""' y='""+(p.y-10).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:10.5px;font-weight:700;font-family:Segoe UI,system-ui;pointer-events:none'>""+fmtV(p.v)+""</text>"";
			    });
			    var labelStep=Math.max(1,Math.ceil(n/12));
			    pts.forEach(function(p,i){ if(i%labelStep!==0 && i!==n-1) return; svg+=""<text x='""+p.x.toFixed(1)+""' y='""+(H-P.b+18)+""' text-anchor='middle' fill='#5A5A5A' style='font-size:11.5px;font-family:Segoe UI,system-ui'>""+esc(p.r.mes)+""</text>""; });
			    svg+=""<text x='""+P.l+""' y='""+(P.t-10)+""' fill='#5A5A5A' style='font-size:11.5px;font-family:Segoe UI,system-ui;font-weight:600'>""+labels[_modoEvo]+""</text>"";
			    el.innerHTML=svg;
			  }
			  var _modoH='produto', _modoHM='rs';
			  window.setModoH=function(m){ _modoH=m; document.querySelectorAll('#hierToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.h===m); }); renderHier(); };
			  window.setModoHM=function(m){ _modoHM=m; document.querySelectorAll('#hierMToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderHier(); };
			  function renderHier(){
			    var el=document.getElementById('hierBox'); if(!el) return;
			    var src={produto:'jHp',vendedor:'jHv'};
			    var data=rJ(src[_modoH])||{rs:[],peso:[]};
			    var arr=(data[_modoHM]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var H=460;
			    var P={t:38,r:24,b:108,l:68};
			    var n=arr.length;
			    var containerW=el.clientWidth||900;
			    var availW=containerW-P.l-P.r;
			    var minBarW=30,maxBarW=56,defaultGap=18,maxGap=40;
			    var idealBarW=(availW-(n-1)*defaultGap)/Math.max(n,1);
			    var barW,gap,contentW,startX;
			    if(idealBarW>=maxBarW){ barW=maxBarW; var rem=availW-n*barW; gap=n>1?Math.min(maxGap,rem/(n-1)):0; var tw=n*barW+(n-1)*gap; startX=P.l+Math.max(0,(availW-tw)/2); contentW=containerW; }
			    else if(idealBarW>=minBarW){ barW=idealBarW; gap=defaultGap; startX=P.l; contentW=containerW; }
			    else { barW=minBarW; gap=defaultGap; startX=P.l; contentW=n*barW+(n-1)*gap+P.l+P.r; }
			    var W=Math.max(contentW,containerW);
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]))*1.14;
			    var fmtV=_modoHM==='rs'? fMK : function(v){return fA(v)+' kg';};
			    var lblFn=_modoHM==='rs'?'Faturamento':'Peso';
			    var uid='b'+Math.floor(Math.random()*99999);
			    var maxWC=barW<40?10:14;
			    var svg=""<defs><linearGradient id='bg""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='1'/><stop offset='100%' stop-color='#1A1A1A' stop-opacity='1'/></linearGradient></defs>"";
			    for(var i=0;i<=4;i++){ var y=P.t+(H-P.t-P.b)*i/4; var v=mx*(1-i/4); svg+=""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>""; if(i<4) svg+=""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12.5px;font-family:Segoe UI,system-ui;font-weight:500'>""+fA(v)+""</text>""; }
			    arr.forEach(function(d,i){
			      var v=Number(d.val)||0;
			      var bh=Math.max(2,(v/mx)*(H-P.t-P.b));
			      var bx=startX+i*(barW+gap);
			      var by=H-P.b-bh;
			      var lx=bx+barW/2;
			      var sub = _modoH==='produto'? (d.grupo||'-') : (d.supervisor||'-');
			      var tt='<b>'+escT(d.nome)+'</b><br>'+lblFn+': '+fmtV(v)+'<br>'+(_modoHM==='rs'?'Peso: '+fA(d.peso||0)+' kg':'Faturamento: '+fMK(d.rs||0))+'<br>Clientes: '+fN(d.clientes||0)+'<br>'+(_modoH==='produto'?'Grupo: ':'Supervisor: ')+escT(sub);
			      svg+=""<rect class='vbar' x='""+bx.toFixed(1)+""' y='""+by.toFixed(1)+""' width='""+barW.toFixed(1)+""' height='""+bh.toFixed(1)+""' rx='3' fill='url(#bg""+uid+"")' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg+=""<text x='""+lx.toFixed(1)+""' y='""+(by-8).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:700;font-variant-numeric:tabular-nums;font-family:Segoe UI,system-ui;pointer-events:none'>""+(_modoHM==='rs'?'R$ '+fA(v):fA(v))+""</text>"";
			      var words=d.nome.split(/\\s+/);
			      var dw=words.slice(0,4).map(function(w){return w.length>maxWC?w.slice(0,maxWC-2)+'..':w;});
			      var ny=H-P.b+16;
			      dw.forEach(function(w,j){ svg+=""<text x='""+lx.toFixed(1)+""' y='""+(ny+j*14)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(w)+""</text>""; });
			    });
			    el.innerHTML=""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  var _modoCd='rs';
			  window.setModoCd=function(m){ _modoCd=m; document.querySelectorAll('#cdModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderCidades(); };
			  function renderCidades(){
			    var el=document.getElementById('cidList'); if(!el) return;
			    var data=rJ('jCd')||{rs:[],peso:[]};
			    var arr=(data[_modoCd]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]));
			    var fmtV=_modoCd==='rs'?fMK:function(v){return fA(v)+' kg';};
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+' / '+escT(d.uf||'-')+'</b><br>'+(_modoCd==='rs'?'Faturamento':'Peso')+': '+fmtV(v)+'<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+"" <span class='bar-sub'>""+esc(d.uf||'')+""</span></div><div class='bar-val'>""+fmtV(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoAtv='rs';
			  window.setModoAtv=function(m){ _modoAtv=m; document.querySelectorAll('#atvModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderAtividades(); };
			  function renderAtividades(){
			    var el=document.getElementById('atvList'); if(!el) return;
			    var data=rJ('jAtv')||{rs:[],peso:[]};
			    var arr=(data[_modoAtv]||[]).slice(0,12);
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]));
			    var fmtV=_modoAtv==='rs'?fMK:function(v){return fA(v)+' kg';};
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+'</b><br>'+(_modoAtv==='rs'?'Faturamento':'Peso')+': '+fmtV(v)+'<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fmtV(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  function renderRoscaCat(){
			    var el=document.getElementById('svgRoscaCat'); if(!el) return;
			    var d=svgDim(el,420,300); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var arr=(rJ('jMix')||[]).filter(function(x){return (Number(x.val)||0)>0;});
			    if(!arr.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem devolucoes</text>""; return; }
			    var total=arr.reduce(function(s,x){return s+(Number(x.val)||0);},0); if(total<=0) total=1;
			    var colors={Comercial:'#4A6E8A',Qualidade:'#A04848',Logistica:'#C07C3A','Log\u00edstica':'#C07C3A',Industria:'#4E7D62','Ind\u00fastria':'#4E7D62',Administrativo:'#5A5A5A',Fiscal:'#8A6740'};
			    var fallback=['#1A1A1A','#B8935A','#4E7D62','#C07C3A','#4A6E8A','#5A5A5A'];
			    var cx=W*0.32, cy=H/2;
			    var r=Math.min(W*0.26,H*0.40), ri=r*0.58;
			    var start=-Math.PI/2;
			    var svg='';
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var ang=(v/total)*Math.PI*2;
			      var end=start+ang;
			      var la=ang>Math.PI?1:0;
			      var x1=cx+r*Math.cos(start), y1=cy+r*Math.sin(start);
			      var x2=cx+r*Math.cos(end),   y2=cy+r*Math.sin(end);
			      var xi1=cx+ri*Math.cos(end), yi1=cy+ri*Math.sin(end);
			      var xi2=cx+ri*Math.cos(start), yi2=cy+ri*Math.sin(start);
			      var dPath='M '+x1.toFixed(2)+' '+y1.toFixed(2)+' A '+r.toFixed(2)+' '+r.toFixed(2)+' 0 '+la+' 1 '+x2.toFixed(2)+' '+y2.toFixed(2)+' L '+xi1.toFixed(2)+' '+yi1.toFixed(2)+' A '+ri.toFixed(2)+' '+ri.toFixed(2)+' 0 '+la+' 0 '+xi2.toFixed(2)+' '+yi2.toFixed(2)+' Z';
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[d2.nome]||fallback[i%fallback.length];
			      var tt='<b>'+escT(d2.nome)+'</b><br>Devolucao: '+fMK(v)+'<br>'+pct+'% do total<br>Tipos: '+fN(d2.qtdTipos||0)+'<br>Clientes: '+fN(d2.clientes||0);
			      svg+=""<path class='donut-slice' d='""+dPath+""' fill='""+color+""' stroke='#FFFFFF' stroke-width='2' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      start=end;
			    });
			    svg+=""<text x='""+cx+""' y='""+(cy-2)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:19px;font-weight:700;font-family:Segoe UI,system-ui'>""+fMK(total)+""</text>"";
			    svg+=""<text x='""+cx+""' y='""+(cy+16)+""' text-anchor='middle' fill='#8B8B8B' style='font-size:10.5px;font-weight:600;letter-spacing:1.6px;font-family:Segoe UI,system-ui'>DEVOLUCAO YUZAP</text>"";
			    var lx=W*0.60;
			    var step=42;
			    var ly=Math.max(28,(H-arr.length*step)/2+12);
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[d2.nome]||fallback[i%fallback.length];
			      var y=ly+i*step;
			      svg+=""<rect x='""+lx+""' y='""+(y-10)+""' width='12' height='12' rx='3' fill='""+color+""'/>"";
			      svg+=""<text x='""+(lx+20)+""' y='""+y+""' fill='#1A1A1A' style='font-size:13px;font-weight:600;font-family:Segoe UI,system-ui'>""+esc(d2.nome)+""</text>"";
			      svg+=""<text x='""+(lx+20)+""' y='""+(y+15)+""' style='font-size:11.5px;font-family:Segoe UI,system-ui'><tspan fill='#5A5A5A'>""+fMK(v)+""</tspan> <tspan fill='#B8935A' font-weight='700'>""+pct+""%</tspan></text>"";
			    });
			    el.innerHTML=svg;
			  }
			  function renderTopMotivos(){
			    var el=document.getElementById('topMotBox'); if(!el) return;
			    var data=(rJ('jMot')||[]).slice(0,10);
			    if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,data.map(function(d){return Number(d.val)||0;}).concat([1]));
			    el.innerHTML=data.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var clr=catColor(d.categoria);
			      var tt='<b>'+escT(d.nome)+'</b><br>Categoria: '+escT(d.categoria)+'<br>Devolucao: '+fMK(v)+'<br>Peso: '+fA(d.peso||0)+' kg<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+"" <span class='tag-badge tag-mini' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.categoria||'-')+""</span></div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _aba='cliente';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='cliente'){ data=rJ('jTc')||[]; cols=[{k:'codigo',t:'Codigo',cls:'mono'},{k:'cliente',t:'Cliente',cls:'name'},{k:'cidade',t:'Cidade',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'label',t:'Ult. Label',cls:'tag'},{k:'status',t:'Status',cls:'status'},{k:'conversas',t:'Conv.',cls:'num',fmt:fN},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'dev',t:'Devolucao R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct},{k:'diasUltCompra',t:'Dias Ult. Compra',cls:'num',fmt:function(v){var n=Number(v); return n<0?'-':fN(n);}}]; }
			    else if(_aba==='produto'){ data=rJ('jTp')||[]; cols=[{k:'produto',t:'Produto',cls:'name'},{k:'grupo',t:'Grupo',cls:'tag'},{k:'subgrupo',t:'Subgrupo',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolucao R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='vendedor'){ data=rJ('jTv')||[]; cols=[{k:'vendedor',t:'Vendedor',cls:'name'},{k:'supervisor',t:'Supervisor',cls:'tag'},{k:'gerente',t:'Gerente',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolucao R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='cidade'){ data=rJ('jTcd')||[]; cols=[{k:'cidade',t:'Cidade',cls:'name'},{k:'uf',t:'UF',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolucao R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else { data=rJ('jTm')||[]; cols=[{k:'motivo',t:'Motivo de Devolucao',cls:'name'},{k:'categoria',t:'Categoria',cls:'cat'},{k:'dev',t:'Devolucao R$',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'qtdLinhas',t:'Linhas',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null,data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>""+cols.map(function(c){return ""<th class='th-""+c.cls+""'>""+c.t+""</th>"";}).join('')+""</tr></thead>"";
			    var body=""<tbody>""+data.map(function(d){
			      return ""<tr>""+cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){ var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100); return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>""; }
			        if(c.cls==='tag'){ var clr=tagColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='cat'){ var clr2=catColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr2.bg+"";color:""+clr2.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='status'){ var clr3=statusBadge(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr3.bg+"";color:""+clr3.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='mono'){ return ""<td class='td-mono'>""+esc(v)+""</td>""; }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('')+""</tr>"";
			    }).join('')+""</tbody>"";
			    el.innerHTML=""<table class='tbl'>""+head+body+""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderFunil(); renderPorLabel(); renderPerdidos(); renderEvolucao(); renderHier(); renderCidades(); renderAtividades(); renderRoscaCat(); renderTopMotivos(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){ return ['jKpi','jFn','jLb','jPe','jEv','jHp','jHv','jCd','jAtv','jMix','jMot','jTc','jTp','jTv','jTcd','jTm'].map(function(id){ var e=document.getElementById(id); if(!e) return ''; return e.textContent.length+'|'+e.textContent.slice(0,20); }).join('~'); }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();" & "</script>"
		displayFolder: HTML Yuzap
		lineageTag: b666fdf2-5950-4418-9dac-4b36edc1b5de

	/// HTML completo da pagina Yuzap x ERP v5 - acentos e ortografia corrigidos. Cards Mix Devolucao + Top 10 Motivos com altura fixa via flexbox. Resto: sem Conversao por Label, cards Cidades/Atividades com scroll, aba Clientes c/ Dev, tabela Cliente filtra fat>0. Usa _JS Yz v2.
	measure 'HTML Yz' =
			VAR _css =
			"<style>" &
			"*,*::before,*::after{box-sizing:border-box}" &
			"html,body{margin:0;padding:0;background:#EDE8DF;color:#1A1A1A;font-family:'Segoe UI',system-ui,-apple-system,sans-serif;font-size:14px;line-height:1.4}" &
			".wrap{max-width:1480px;margin:0 auto;padding:14px 18px 40px}" &
			".pgHead{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:16px 20px;background:linear-gradient(135deg,#1A1A1A 0%,#2A1F12 70%,#3A2410 100%);color:#EDE8DF;border-radius:10px;margin-bottom:16px;box-shadow:0 6px 22px rgba(0,0,0,.18)}" &
			".pgHead h1{margin:0;font-size:19px;font-weight:700;letter-spacing:.2px;line-height:1.15}" &
			".pgHead .pgSub{font-size:12px;color:#C9A96E;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;display:block;margin-bottom:3px}" &
			".pgHead .pgIcon{width:42px;height:42px;border-radius:10px;background:rgba(184,147,90,.16);display:flex;align-items:center;justify-content:center;color:#C9A96E;flex-shrink:0}" &
			".pgHead .pgIcon svg{width:22px;height:22px}" &
			".grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}" &
			".col-12{grid-column:span 12}.col-6{grid-column:span 6}.col-4{grid-column:span 4}.col-3{grid-column:span 3}" &
			"@media(max-width:980px){.col-6,.col-4,.col-3{grid-column:span 12}}" &
			".card{background:#FFFFFF;border-radius:10px;padding:16px 18px;box-shadow:0 2px 10px rgba(58,36,16,.08);border:1px solid rgba(58,36,16,.06)}" &
			".card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px}" &
			".card-title{font-size:13.5px;font-weight:700;color:#1A1A1A;letter-spacing:.1px;margin:0}" &
			".card-sub{font-size:11.5px;color:#8B8B8B;margin-top:2px;font-weight:500}" &
			".card-eq{height:480px;display:flex;flex-direction:column}" &
			".card-eq .card-head{flex-shrink:0}" &
			".kpi{background:#FFFFFF;border-radius:10px;padding:14px 16px;box-shadow:0 2px 10px rgba(58,36,16,.08);border:1px solid rgba(58,36,16,.06);display:flex;flex-direction:column;gap:6px;min-height:108px}" &
			".kpi-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px}" &
			".kpi-label{font-size:11px;color:#5A5A5A;font-weight:600;letter-spacing:1.1px;text-transform:uppercase;line-height:1.25}" &
			".kpi-icon{width:32px;height:32px;border-radius:8px;background:rgba(184,147,90,.14);color:#B8935A;display:flex;align-items:center;justify-content:center;flex-shrink:0}" &
			".kpi-icon svg{width:17px;height:17px}" &
			".kpi-val{font-size:24px;font-weight:700;color:#1A1A1A;line-height:1.1;font-variant-numeric:tabular-nums;letter-spacing:-.4px}" &
			".kpi-sub{font-size:11.5px;color:#5A5A5A;font-weight:500}" &
			".kpi-sub .up{color:#3D6049;font-weight:700}" &
			".kpi-sub .down{color:#A04848;font-weight:700}" &
			".kpi-sub .neu{color:#8B8B8B;font-weight:600}" &
			".funil-row{margin-bottom:10px}" &
			".funil-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:4px}" &
			".funil-name{font-size:13px;font-weight:600;color:#1A1A1A}" &
			".funil-desc{font-size:11.5px;color:#8B8B8B;font-weight:500;margin-left:6px}" &
			".funil-val{font-size:14px;font-weight:700;color:#1A1A1A;font-variant-numeric:tabular-nums}" &
			".funil-pct{font-size:11.5px;color:#B8935A;font-weight:700;margin-left:4px}" &
			".funil-track{height:14px;background:rgba(58,36,16,.05);border-radius:4px;overflow:hidden}" &
			".funil-fill{height:100%;width:0;border-radius:4px;transition:width .55s cubic-bezier(.2,.65,.3,1)}" &
			".bar-row{margin-bottom:8px}" &
			".bar-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:3px}" &
			".bar-name{font-size:12.5px;font-weight:600;color:#1A1A1A;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}" &
			".bar-sub{font-size:11px;color:#8B8B8B;font-weight:500;margin-left:6px}" &
			".bar-val{font-size:12.5px;font-weight:700;color:#1A1A1A;font-variant-numeric:tabular-nums;flex-shrink:0}" &
			".bar-track{height:8px;background:rgba(58,36,16,.05);border-radius:3px;overflow:hidden}" &
			".bar-fill{height:100%;width:0;background:linear-gradient(90deg,#B8935A 0%,#1A1A1A 100%);border-radius:3px;transition:width .55s cubic-bezier(.2,.65,.3,1)}" &
			".toggle{display:inline-flex;background:rgba(58,36,16,.06);border-radius:6px;padding:2px;gap:0}" &
			".toggle button{background:transparent;border:0;padding:5px 11px;font-size:11.5px;font-weight:600;color:#5A5A5A;cursor:pointer;border-radius:4px;letter-spacing:.3px;font-family:inherit;transition:all .2s}" &
			".toggle button:hover{color:#1A1A1A}" &
			".toggle button.on{background:#1A1A1A;color:#EDE8DF;box-shadow:0 1px 4px rgba(0,0,0,.15)}" &
			".tbl{width:100%;border-collapse:collapse;font-size:12.5px}" &
			".tbl thead th{position:sticky;top:0;background:#F5F1E8;color:#5A5A5A;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:9px 8px;border-bottom:2px solid rgba(58,36,16,.12);text-align:left}" &
			".tbl thead .th-num{text-align:right}" &
			".tbl tbody td{padding:8px;border-bottom:1px solid rgba(58,36,16,.06);vertical-align:middle}" &
			".tbl tbody tr:hover{background:rgba(184,147,90,.05)}" &
			".td-num{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:#1A1A1A}" &
			".td-name{color:#1A1A1A;font-weight:500}" &
			".td-mono{font-family:'Consolas','Courier New',monospace;font-size:11.5px;color:#5A5A5A}" &
			".td-tag{}" &
			".tag-badge{display:inline-block;padding:3px 9px;border-radius:11px;font-size:10.5px;font-weight:700;letter-spacing:.3px;white-space:nowrap}" &
			".tag-mini{padding:2px 7px;font-size:9.5px;margin-left:6px;vertical-align:middle}" &
			".cell-val{font-weight:700;color:#1A1A1A;font-variant-numeric:tabular-nums;text-align:right}" &
			".cell-bar{height:4px;background:rgba(58,36,16,.05);border-radius:2px;overflow:hidden;margin-top:3px}" &
			".cell-fill{height:100%;background:linear-gradient(90deg,#B8935A,#1A1A1A);border-radius:2px}" &
			".pct-hi{color:#3D6049}" &
			".pct-md{color:#8A6740}" &
			".pct-lo{color:#A04848}" &
			".tbl-compact tbody td{padding:6px 8px;font-size:12px}" &
			".pager{display:flex;align-items:center;justify-content:center;gap:14px;padding:10px 0 2px;font-size:11.5px;color:#5A5A5A;font-weight:500}" &
			".pager button{background:#FFFFFF;border:1px solid rgba(58,36,16,.15);color:#1A1A1A;font-weight:600;padding:5px 12px;border-radius:5px;cursor:pointer;font-size:11.5px;font-family:inherit;transition:all .15s}" &
			".pager button:hover:not(:disabled){background:#1A1A1A;color:#EDE8DF;border-color:#1A1A1A}" &
			".pager button:disabled{opacity:.4;cursor:not-allowed}" &
			".tabs{display:flex;gap:0;border-bottom:2px solid rgba(58,36,16,.08);margin-bottom:12px}" &
			".tabs .tab{background:transparent;border:0;padding:8px 16px;font-size:12.5px;font-weight:600;color:#8B8B8B;cursor:pointer;letter-spacing:.3px;font-family:inherit;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}" &
			".tabs .tab:hover{color:#1A1A1A}" &
			".tabs .tab.on{color:#1A1A1A;border-bottom-color:#B8935A}" &
			".scrollX{overflow-x:auto;-webkit-overflow-scrolling:touch}" &
			".scrollY{max-height:520px;overflow-y:auto;overflow-x:auto}" &
			".scroll-card{max-height:360px;overflow-y:auto;overflow-x:hidden;padding-right:4px}" &
			".scroll-card::-webkit-scrollbar,.scroll-flex::-webkit-scrollbar{width:6px}" &
			".scroll-card::-webkit-scrollbar-track,.scroll-flex::-webkit-scrollbar-track{background:rgba(58,36,16,.04);border-radius:3px}" &
			".scroll-card::-webkit-scrollbar-thumb,.scroll-flex::-webkit-scrollbar-thumb{background:rgba(58,36,16,.2);border-radius:3px}" &
			".scroll-card::-webkit-scrollbar-thumb:hover,.scroll-flex::-webkit-scrollbar-thumb:hover{background:rgba(58,36,16,.35)}" &
			".scroll-flex{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;padding-right:4px}" &
			".svg-box{width:100%;height:300px;display:block}" &
			".svg-hier{width:100%;min-height:460px;display:block}" &
			".svg-rosca{width:100%;height:360px;display:block}" &
			".svg-rosca-flex{flex:1;width:100%;min-height:0;display:block}" &
			".vbar{transition:opacity .15s}" &
			".vbar:hover{opacity:.82}" &
			".donut-slice{cursor:pointer;transition:opacity .15s}" &
			".donut-slice:hover{opacity:.85}" &
			"#tt{position:fixed;display:none;background:#1A1A1A;color:#EDE8DF;font-size:11.5px;line-height:1.5;padding:8px 11px;border-radius:6px;pointer-events:none;z-index:9999;box-shadow:0 6px 22px rgba(0,0,0,.32);max-width:260px;font-family:'Segoe UI',system-ui,sans-serif}" &
			"#tt.on{display:block}" &
			"#tt b{color:#C9A96E;font-weight:700}" &
			".pgHead-stats{display:flex;gap:18px;flex-wrap:wrap}" &
			".pgHead-stat{display:flex;flex-direction:column;align-items:flex-end}" &
			".pgHead-stat-l{font-size:10px;color:#C9A96E;font-weight:600;letter-spacing:.9px;text-transform:uppercase}" &
			".pgHead-stat-v{font-size:15px;color:#EDE8DF;font-weight:700;font-variant-numeric:tabular-nums}" &
			"</style>"
			
			VAR _icon = "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><path d='M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z'/></svg>"
			
			VAR _head =
			"<div class='pgHead'>" &
			"<div style='display:flex;align-items:center;gap:14px'>" &
			"<div class='pgIcon'>" & _icon & "</div>" &
			"<div><span class='pgSub'>Cruzamento Yuzap x ERP</span><h1>Conversão de Atendimentos em Vendas</h1></div>" &
			"</div>" &
			"<div class='pgHead-stats'>" &
			"<div class='pgHead-stat'><span class='pgHead-stat-l'>Identificados</span><span class='pgHead-stat-v'>" & FORMAT(COALESCE([Yuzap - Clientes Identificados], 0), "#,0") & "</span></div>" &
			"<div class='pgHead-stat'><span class='pgHead-stat-l'>Convertidos</span><span class='pgHead-stat-v'>" & FORMAT(COALESCE([Yuzap - Clientes Convertidos], 0), "#,0") & "</span></div>" &
			"<div class='pgHead-stat'><span class='pgHead-stat-l'>Faturamento</span><span class='pgHead-stat-v'>" & FORMAT(COALESCE([Yuzap - Faturamento], 0)/1000, "#,0") & " mil</span></div>" &
			"</div>" &
			"</div>"
			
			VAR _kpis = "<div class='grid' style='margin-bottom:14px'><div class='col-12' id='kpiGrid' style='display:grid;grid-template-columns:repeat(4,1fr);gap:14px'></div></div>"
			
			VAR _funil =
			"<div class='grid' style='margin-bottom:14px'><div class='col-12'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Funil de Conversão Yuzap → ERP</h3><div class='card-sub'>Da identificação no Yuzap à venda recorrente sem devoluções</div></div></div>" &
			"<div id='funilBox'></div>" &
			"</div></div></div>"
			
			VAR _perdidos =
			"<div class='grid' style='margin-bottom:14px'><div class='col-12'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Clientes Perdidos: identificados no Yuzap, sem venda no ERP</h3><div class='card-sub'>Oportunidade de retomada - ordenado por atividade mais recente</div></div></div>" &
			"<div class='scrollX' id='perdidosBox'></div>" &
			"</div></div></div>"
			
			VAR _evo =
			"<div class='grid' style='margin-bottom:14px'><div class='col-12'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Evolução Mensal</h3><div class='card-sub'>Ignora filtros de data - mostra histórico completo</div></div>" &
			"<div class='toggle' id='evoModoToggle'>" &
			"<button data-m='val' class='on' onclick='setModoEvo(""val"")'>Faturamento</button>" &
			"<button data-m='peso' onclick='setModoEvo(""peso"")'>Peso</button>" &
			"<button data-m='pedidos' onclick='setModoEvo(""pedidos"")'>Pedidos</button>" &
			"<button data-m='dev' onclick='setModoEvo(""dev"")'>Devolução</button>" &
			"</div></div>" &
			"<svg id='svgEvo' class='svg-box' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid meet'></svg>" &
			"</div></div></div>"
			
			VAR _hier =
			"<div class='grid' style='margin-bottom:14px'><div class='col-12'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Top 15 - Produtos e Vendedores</h3><div class='card-sub'>Hierarquia: produto ou vendedor; métrica: faturamento ou peso</div></div>" &
			"<div style='display:flex;gap:8px;align-items:center'>" &
			"<div class='toggle' id='hierToggle'>" &
			"<button data-h='produto' class='on' onclick='setModoH(""produto"")'>Produto</button>" &
			"<button data-h='vendedor' onclick='setModoH(""vendedor"")'>Vendedor</button>" &
			"</div>" &
			"<div class='toggle' id='hierMToggle'>" &
			"<button data-m='rs' class='on' onclick='setModoHM(""rs"")'>R$</button>" &
			"<button data-m='peso' onclick='setModoHM(""peso"")'>kg</button>" &
			"</div></div></div>" &
			"<div class='scrollX' id='hierBox' style='min-height:460px'></div>" &
			"</div></div></div>"
			
			VAR _geo =
			"<div class='grid' style='margin-bottom:14px'>" &
			"<div class='col-6'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Top Cidades</h3><div class='card-sub'>Onde estão os clientes Yuzap convertidos</div></div>" &
			"<div class='toggle' id='cdModoToggle'>" &
			"<button data-m='rs' class='on' onclick='setModoCd(""rs"")'>R$</button>" &
			"<button data-m='peso' onclick='setModoCd(""peso"")'>kg</button>" &
			"</div></div>" &
			"<div class='scroll-card' id='cidList'></div>" &
			"</div></div>" &
			"<div class='col-6'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Top Atividades</h3><div class='card-sub'>Segmentos de mercado dos clientes Yuzap</div></div>" &
			"<div class='toggle' id='atvModoToggle'>" &
			"<button data-m='rs' class='on' onclick='setModoAtv(""rs"")'>R$</button>" &
			"<button data-m='peso' onclick='setModoAtv(""peso"")'>kg</button>" &
			"</div></div>" &
			"<div class='scroll-card' id='atvList'></div>" &
			"</div></div>" &
			"</div>"
			
			VAR _dev =
			"<div class='grid' style='margin-bottom:14px'>" &
			"<div class='col-6'><div class='card card-eq'>" &
			"<div class='card-head'><div><h3 class='card-title'>Mix de Devolução por Categoria</h3><div class='card-sub'>Devoluções apenas dos clientes Yuzap</div></div></div>" &
			"<svg id='svgRoscaCat' class='svg-rosca-flex' xmlns='http://www.w3.org/2000/svg' preserveAspectRatio='xMidYMid meet'></svg>" &
			"</div></div>" &
			"<div class='col-6'><div class='card card-eq'>" &
			"<div class='card-head'><div><h3 class='card-title'>Top 10 Motivos de Devolução</h3><div class='card-sub'>Específicos dos clientes Yuzap, com categoria</div></div></div>" &
			"<div class='scroll-flex' id='topMotBox'></div>" &
			"</div></div>" &
			"</div>"
			
			VAR _tabela =
			"<div class='grid'><div class='col-12'><div class='card'>" &
			"<div class='card-head'><div><h3 class='card-title'>Detalhamento</h3><div class='card-sub'>Explore os dados em 5 perspectivas - todas filtradas pelos clientes Yuzap</div></div></div>" &
			"<div class='tabs' id='abasTabs'>" &
			"<button class='tab on' data-aba='cliente' onclick='setAba(""cliente"")'>Clientes</button>" &
			"<button class='tab' data-aba='produto' onclick='setAba(""produto"")'>Produtos</button>" &
			"<button class='tab' data-aba='vendedor' onclick='setAba(""vendedor"")'>Vendedores</button>" &
			"<button class='tab' data-aba='cidade' onclick='setAba(""cidade"")'>Cidades</button>" &
			"<button class='tab' data-aba='devcliente' onclick='setAba(""devcliente"")'>Clientes c/ Dev.</button>" &
			"</div>" &
			"<div class='scrollY' id='tabBox'></div>" &
			"</div></div></div>"
			
			VAR _jsonContainers =
			"<div style='display:none'>" &
			"<div id='jKpi'>"  & [_JSON KPIs Yz] & "</div>" &
			"<div id='jFn'>"   & [_JSON Funil Yz] & "</div>" &
			"<div id='jPe'>"   & [_JSON Perdidos Yz] & "</div>" &
			"<div id='jEv'>"   & [_JSON Evolucao Yz] & "</div>" &
			"<div id='jHp'>"   & [_JSON Top Produto Yz] & "</div>" &
			"<div id='jHv'>"   & [_JSON Top Vendedor Yz] & "</div>" &
			"<div id='jCd'>"   & [_JSON Top Cidade Yz] & "</div>" &
			"<div id='jAtv'>"  & [_JSON Top Atividade Yz] & "</div>" &
			"<div id='jMix'>"  & [_JSON Mix Categoria Dev Yz] & "</div>" &
			"<div id='jMot'>"  & [_JSON Top Motivos Dev Yz] & "</div>" &
			"<div id='jTc'>"   & [_JSON Tabela Cliente Yz] & "</div>" &
			"<div id='jTp'>"   & [_JSON Tabela Produto Yz] & "</div>" &
			"<div id='jTv'>"   & [_JSON Tabela Vendedor Yz] & "</div>" &
			"<div id='jTcd'>"  & [_JSON Tabela Cidade Yz] & "</div>" &
			"<div id='jTdc'>"  & [_JSON TabDevCliente Yz] & "</div>" &
			"</div>"
			
			RETURN
			"<div>" &
			_css &
			"<div id='tt'></div>" &
			"<div class='wrap'>" &
			_head &
			_kpis &
			_funil &
			_perdidos &
			_evo &
			_hier &
			_geo &
			_dev &
			_tabela &
			"</div>" &
			_jsonContainers &
			[_JS Yz v2] &
			"</div>"
		displayFolder: HTML Yuzap
		lineageTag: 8966d27b-eedd-47e5-8b30-7fef92942f59

	/// Versao corrigida do _JS Yz. Bug original: 'class=\\''+momCls(...)+'\\'>'  quebra parse JS porque \\ + aspa simples fecha string. Corrigido com aspas duplas no HTML class.
	measure '_JS Yz Fixed' =
			SUBSTITUTE(
			    SUBSTITUTE(
			        [_JS Yz],
			        "sub:'MoM = <span class=\\''+momCls(K.momFat)+'\\'>'+(K.momFat||'-')+'</span>'",
			        "sub:'MoM = <span class=""'+momCls(K.momFat)+'"">'+(K.momFat||'-')+'</span>'"
			    ),
			    "sub:'MoM = <span class=\\''+momCls(K.momDev)+'\\'>'+(K.momDev||'-')+'</span>'",
			    "sub:'MoM = <span class=""'+momCls(K.momDev)+'"">'+(K.momDev||'-')+'</span>'"
			)
		displayFolder: HTML Yuzap
		lineageTag: f238f39d-a587-491d-a6a8-548cc07327b9

	/// Tabela detalhada dos clientes Yuzap COM DEVOLUCAO > 0. Inclui motivo principal (maior valor de dev), categoria, fat, dev, taxa dev, pedidos, peso devolvido.
	measure '_JSON TabDevCliente Yz' =
			VAR _yz =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            FILTER(
			                VALUES(F_Yuzap_Conversas[data.attr_cdigo_cliente]),
			                NOT(ISBLANK(F_Yuzap_Conversas[data.attr_cdigo_cliente])) &&
			                F_Yuzap_Conversas[data.attr_cdigo_cliente] <> ""
			            ),
			            "_nome",     CALCULATE(MAX(F_Yuzap_Conversas[Nome Contato]))
			        )
			    )
			VAR _com =
			    ADDCOLUMNS(
			        _yz,
			        "_cidade",      CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CIDADE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_atividade",   CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[ATIVIDADE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_clienteNome", CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[CLIENTE]), TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_fat",         CALCULATE([Faturamento Total], TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_pedidos",     CALCULATE([Total de Pedidos],  TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_dev",         CALCULATE([Total Devoluções (R$)], TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_pesoDev",     CALCULATE([Peso Total Devolvido], TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])),
			        "_motivoTop",
			            CALCULATE(
			                CONCATENATEX(
			                    TOPN(
			                        1,
			                        FILTER(
			                            VALUES(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]),
			                            NOT(ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO])) &&
			                            DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO] <> "" &&
			                            CALCULATE([Total Devoluções (R$)]) > 0
			                        ),
			                        CALCULATE([Total Devoluções (R$)]),
			                        DESC
			                    ),
			                    DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]
			                ),
			                TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			            ),
			        "_categoriaTop",
			            CALCULATE(
			                CONCATENATEX(
			                    TOPN(
			                        1,
			                        FILTER(
			                            VALUES(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO]),
			                            NOT(ISBLANK(DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO])) &&
			                            DCVVQ_VENDAGERALTELEVENDAS[TIPODEVOLUCAO] <> "" &&
			                            CALCULATE([Total Devoluções (R$)]) > 0
			                        ),
			                        CALCULATE([Total Devoluções (R$)]),
			                        DESC
			                    ),
			                    CALCULATE(MAX(DCVVQ_VENDAGERALTELEVENDAS[Categoria Devolução]))
			                ),
			                TREATAS({F_Yuzap_Conversas[data.attr_cdigo_cliente]}, DCVVQ_VENDAGERALTELEVENDAS[SEQCLIENTE])
			            )
			    )
			VAR _comDev = FILTER(_com, COALESCE([_dev], 0) > 0)
			VAR _ordenado = TOPN(220, _comDev, [_dev], DESC)
			RETURN
			"[" & CONCATENATEX(
			    _ordenado,
			    "{""codigo"":""" & SUBSTITUTE(SUBSTITUTE(F_Yuzap_Conversas[data.attr_cdigo_cliente], """""", ""), "\", "") &
			    """,""cliente"":"""   & SUBSTITUTE(SUBSTITUTE(COALESCE([_clienteNome], [_nome], "-"), """""", ""), "\", "") &
			    """,""cidade"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE([_cidade], "-"), """""", ""), "\", "") &
			    """,""atividade"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_atividade], "-"), """""", ""), "\", "") &
			    """,""motivo"":"""    & SUBSTITUTE(SUBSTITUTE(COALESCE([_motivoTop], "-"), """""", ""), "\", "") &
			    """,""categoria"":""" & SUBSTITUTE(SUBSTITUTE(COALESCE([_categoriaTop], "-"), """""", ""), "\", "") &
			    """,""fat"":"          & SUBSTITUTE(FORMAT(COALESCE([_fat], 0), "0.00"), ",", ".") &
			    ",""dev"":"          & SUBSTITUTE(FORMAT(COALESCE([_dev], 0), "0.00"), ",", ".") &
			    ",""pesoDev"":"      & SUBSTITUTE(FORMAT(COALESCE([_pesoDev], 0), "0.00"), ",", ".") &
			    ",""taxaDev"":"      & SUBSTITUTE(FORMAT(DIVIDE(COALESCE([_dev], 0), COALESCE([_fat], 0) + COALESCE([_dev], 0), 0) * 100, "0.00"), ",", ".") &
			    ",""pedidos"":"      & COALESCE([_pedidos], 0) &
			    "}",
			    ",",
			    [_dev], DESC
			) & "]"
		displayFolder: HTML Yuzap
		lineageTag: 1eae3b18-ebe5-48ff-a312-65b846c2bdfb

	/// Parte 1 do JS Yz v2 - acentos e ortografia corrigidos.
	measure '_JS Yz P1' =
			"(function () {
			  'use strict';
			  function rJ(id) { var e = document.getElementById(id); try { return JSON.parse((e && e.textContent) || 'null'); } catch (ex) { return null; } }
			  function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
			  function escT(v) { return esc(v).replace(/'/g,'&#39;'); }
			  function fN(v) { return (Number(v) || 0).toLocaleString('pt-BR'); }
			  function fA(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fN(v); }
			  function fM(v) { v = Number(v) || 0; return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2}); }
			  function fMK(v) { v = Number(v) || 0; if (Math.abs(v) >= 1e6) return 'R$ ' + (v/1e6).toFixed(2).replace('.',',') + ' M'; if (Math.abs(v) >= 1e3) return 'R$ ' + (v/1e3).toFixed(1).replace('.',',') + ' mil'; return fM(v); }
			  function fPct(v) { return (Number(v)||0).toFixed(2).replace('.',',') + '%'; }
			  function momCls(s) { if (!s || s === '--') return 'neu'; return s.indexOf('+') === 0 ? 'up' : (s.indexOf('-') === 0 ? 'down' : 'neu'); }
			  function svgDim(el, fbW, fbH) { var bb = el.getBoundingClientRect(); return [Math.round(bb.width) || fbW, Math.round(bb.height) || fbH]; }
			  function tagColor(str) {
			    if (!str) return {bg:'rgba(139,139,139,.12)',fg:'#5A5A5A'};
			    var h=0; for (var i=0;i<str.length;i++) h = ((h<<5)-h) + str.charCodeAt(i);
			    var palette = [{bg:'rgba(184,147,90,.15)',fg:'#8A6740'},{bg:'rgba(78,125,98,.15)',fg:'#3D6049'},{bg:'rgba(74,110,138,.15)',fg:'#3A5872'},{bg:'rgba(192,124,58,.15)',fg:'#995F2C'},{bg:'rgba(58,36,16,.12)',fg:'#3A2410'},{bg:'rgba(90,90,90,.15)',fg:'#5A5A5A'}];
			    return palette[Math.abs(h) % palette.length];
			  }
			  function statusBadge(s){ if(s==='Convertido') return {bg:'rgba(78,125,98,.18)',fg:'#3D6049'}; if(s==='Recorrente') return {bg:'rgba(184,147,90,.20)',fg:'#8A6740'}; return {bg:'rgba(160,72,72,.15)',fg:'#A04848'}; }
			  function catColor(c){ if(c && c.indexOf('Comercial')===0) return {bg:'rgba(74,110,138,.18)',fg:'#3A5872'}; if(c && c.indexOf('Qualidade')===0) return {bg:'rgba(160,72,72,.16)',fg:'#A04848'}; if(c && (c.indexOf('Logística')===0||c.indexOf('Logistica')===0||c.indexOf('Log')===0)) return {bg:'rgba(192,124,58,.18)',fg:'#995F2C'}; if(c && (c.indexOf('Indústria')===0||c.indexOf('Industria')===0||c.indexOf('Ind')===0)) return {bg:'rgba(78,125,98,.18)',fg:'#3D6049'}; return tagColor(c); }
			  var ttEl = document.getElementById('tt');
			  window.tip = function(e,h){ if (!ttEl) return; ttEl.innerHTML = h; ttEl.classList.add('on'); var ww=window.innerWidth, x=e.clientX+14; if(x+260>ww) x=ww-280; ttEl.style.left = x+'px'; ttEl.style.top = (e.clientY-36)+'px'; };
			  window.tipOff = function(){ ttEl && ttEl.classList.remove('on'); };
			  var kpiIcons = {
			    users: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg>"",
			    target: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg>"",
			    money: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg>"",
			    alert: ""<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.2'><path d='M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/><line x1='12' y1='9' x2='12' y2='13'/><line x1='12' y1='17' x2='12.01' y2='17'/></svg>""
			  };
			  function buildKPIs(){
			    var K=rJ('jKpi')||{}; var el=document.getElementById('kpiGrid'); if(!el) return;
			    var cards=[
			      {icon:'users',  label:'Clientes Identificados', val:fN(K.identificados||0), sub:'<span>'+fN(K.conversas||0)+' conversas no Yuzap</span>'},
			      {icon:'target', label:'% Conversão Yuzap → ERP', val:fPct(K.conversao||0),   sub:'<span>'+fN(K.convertidos||0)+' convertidos / '+fN(K.perdidos||0)+' perdidos</span>'},
			      {icon:'money',  label:'Faturamento Gerado',     val:fMK(K.fat||0),          sub:'MoM = <span class=""'+momCls(K.momFat)+'"">'+(K.momFat||'-')+'</span>'},
			      {icon:'alert',  label:'Taxa de Devolução',      val:fPct(K.taxaDev||0),     sub:'MoM = <span class=""'+momCls(K.momDev)+'"">'+(K.momDev||'-')+'</span>'}
			    ];
			    el.innerHTML=cards.map(function(c){ return ""<div class='kpi'><div class='kpi-top'><span class='kpi-label'>""+c.label+""</span><div class='kpi-icon'>""+kpiIcons[c.icon]+""</div></div><div class='kpi-val'>""+c.val+""</div><div class='kpi-sub'>""+c.sub+""</div></div>""; }).join('');
			  }
			  function renderFunil(){
			    var el=document.getElementById('funilBox'); if(!el) return;
			    var data=rJ('jFn')||[]; if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Number(data[0].val)||1;
			    el.innerHTML=data.map(function(d,i){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var pct=i===0?100:(v/(Number(data[0].val)||1))*100;
			      var pctTxt=pct.toFixed(1).replace('.',',')+'%';
			      var colors=['#1A1A1A','#4E7D62','#B8935A','#4A6E8A'];
			      var c=colors[i % colors.length];
			      var tt='<b>'+escT(d.nome)+'</b><br>'+escT(d.desc)+'<br>Total: '+fN(v)+'<br>'+pctTxt+' do topo do funil';
			      return ""<div class='funil-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='funil-head'><div class='funil-name'>""+esc(d.nome)+"" <span class='funil-desc'>""+esc(d.desc)+""</span></div><div class='funil-val'>""+fN(v)+"" <span class='funil-pct'>(""+pctTxt+"")</span></div></div><div class='funil-track'><div class='funil-fill' data-w='""+w+""' style='background:""+c+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.funil-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _perdPg=0, _perdPSize=20;
			  window.setPerdPg=function(dir){ var data=rJ('jPe')||[]; var maxPg=Math.max(0,Math.ceil(data.length/_perdPSize)-1); _perdPg=Math.max(0,Math.min(maxPg,_perdPg+dir)); renderPerdidos(); };
			  function renderPerdidos(){
			    var el=document.getElementById('perdidosBox'); if(!el) return;
			    var data=rJ('jPe')||[]; if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem clientes perdidos</div>""; return; }
			    var total=data.length, maxPg=Math.max(0,Math.ceil(total/_perdPSize)-1);
			    if(_perdPg>maxPg) _perdPg=maxPg;
			    var start=_perdPg*_perdPSize, end=Math.min(start+_perdPSize,total);
			    var page=data.slice(start,end);
			    var head=""<thead><tr><th class='th-name'>Cliente</th><th class='th-name'>Código</th><th class='th-name'>Telefone</th><th class='th-num'>Conversas</th><th class='th-name'>Último Label</th><th class='th-name'>Agente</th><th class='th-name'>Última Atividade</th><th class='th-num'>Dias</th></tr></thead>"";
			    var body=""<tbody>""+page.map(function(d){
			      var clr=tagColor(d.label);
			      var dias=Number(d.dias)||0;
			      var diasCls=dias>30?'pct-lo':(dias>7?'pct-md':'pct-hi');
			      return ""<tr><td class='td-name'>""+esc(d.nome)+""</td><td class='td-mono'>""+esc(d.codigo)+""</td><td class='td-mono'>""+esc(d.tel)+""</td><td class='td-num'>""+fN(d.conversas)+""</td><td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.label||'-')+""</span></td><td class='td-name'>""+esc(d.agente)+""</td><td class='td-name'>""+esc(d.data)+""</td><td class='td-num ""+diasCls+""'>""+fN(dias)+""</td></tr>"";
			    }).join('')+""</tbody>"";
			    var pager=""<div class='pager'><button ""+(_perdPg===0?'disabled':'')+"" onclick='setPerdPg(-1)'>‹ Anterior</button><span>Página ""+(_perdPg+1)+"" de ""+(maxPg+1)+"" - mostrando ""+(start+1)+""-""+end+"" de ""+total+"" perdidos</span><button ""+(_perdPg>=maxPg?'disabled':'')+"" onclick='setPerdPg(1)'>Próximo ›</button></div>"";
			    el.innerHTML=""<table class='tbl tbl-compact'>""+head+body+""</table>""+pager;
			  }"
		displayFolder: HTML Yuzap
		lineageTag: 13d11140-4a09-4838-abfd-a8a582d52129

	/// Parte 2 do JS Yz v2 - acentos e ortografia corrigidos. Legenda da rosca com fontes maiores.
	measure '_JS Yz P2' =
			"  var _modoEvo='val';
			  window.setModoEvo=function(m){ _modoEvo=m; document.querySelectorAll('#evoModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderEvolucao(); };
			  function renderEvolucao(){
			    var el=document.getElementById('svgEvo'); if(!el) return;
			    var d=svgDim(el,900,300); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var data=rJ('jEv')||[]; if(!data.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>""; return; }
			    var P={t:34,r:34,b:50,l:64};
			    var n=data.length;
			    var vals=data.map(function(r){ return Number(r[_modoEvo])||0; });
			    var mx=Math.max.apply(null,vals.concat([1]))*1.18;
			    var stepX=(W-P.l-P.r)/Math.max(1,n-1);
			    var fmtV = _modoEvo==='val'||_modoEvo==='dev'? fMK : (_modoEvo==='peso'? function(v){return fA(v)+' kg';} : fN);
			    var labels={val:'Faturamento',peso:'Peso',pedidos:'Pedidos',dev:'Devolução'};
			    var color = _modoEvo==='dev' ? '#A04848' : '#B8935A';
			    var svg='';
			    for(var i=0;i<=4;i++){
			      var y=P.t+(H-P.t-P.b)*i/4;
			      var v=mx*(1-i/4);
			      svg+=""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>"";
			      if(i<4) svg+=""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12px;font-family:Segoe UI,system-ui'>""+fA(v)+""</text>"";
			    }
			    var pts=data.map(function(r,i){ var x=P.l+i*stepX; var v=Number(r[_modoEvo])||0; var y=P.t+(H-P.t-P.b)*(1-v/mx); return {x:x,y:y,v:v,r:r}; });
			    var path = pts.map(function(p,i){ return (i===0?'M':'L')+p.x.toFixed(1)+' '+p.y.toFixed(1); }).join(' ');
			    var area = path + ' L '+pts[pts.length-1].x.toFixed(1)+' '+(H-P.b)+' L '+pts[0].x.toFixed(1)+' '+(H-P.b)+' Z';
			    var uid='ev'+Math.floor(Math.random()*99999);
			    svg+=""<defs><linearGradient id='""+uid+""' x1='0' y1='0' x2='0' y2='1'><stop offset='0%' stop-color='""+color+""' stop-opacity='.25'/><stop offset='100%' stop-color='""+color+""' stop-opacity='0'/></linearGradient></defs>"";
			    svg+=""<path d='""+area+""' fill='url(#""+uid+"")'/>"";
			    svg+=""<path d='""+path+""' fill='none' stroke='""+color+""' stroke-width='2.5'/>"";
			    pts.forEach(function(p){
			      var tt='<b>'+escT(p.r.mes)+'</b><br>Faturamento: '+fMK(p.r.val)+'<br>Peso: '+fA(p.r.peso)+' kg<br>Pedidos: '+fN(p.r.pedidos)+'<br>Devolução: '+fMK(p.r.dev);
			      svg+=""<circle cx='""+p.x.toFixed(1)+""' cy='""+p.y.toFixed(1)+""' r='4' fill='#fff' stroke='""+color+""' stroke-width='2' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg+=""<text x='""+p.x.toFixed(1)+""' y='""+(p.y-10).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:10.5px;font-weight:700;font-family:Segoe UI,system-ui;pointer-events:none'>""+fmtV(p.v)+""</text>"";
			    });
			    var labelStep=Math.max(1,Math.ceil(n/12));
			    pts.forEach(function(p,i){ if(i%labelStep!==0 && i!==n-1) return; svg+=""<text x='""+p.x.toFixed(1)+""' y='""+(H-P.b+18)+""' text-anchor='middle' fill='#5A5A5A' style='font-size:11.5px;font-family:Segoe UI,system-ui'>""+esc(p.r.mes)+""</text>""; });
			    svg+=""<text x='""+P.l+""' y='""+(P.t-10)+""' fill='#5A5A5A' style='font-size:11.5px;font-family:Segoe UI,system-ui;font-weight:600'>""+labels[_modoEvo]+""</text>"";
			    el.innerHTML=svg;
			  }
			  var _modoH='produto', _modoHM='rs';
			  window.setModoH=function(m){ _modoH=m; document.querySelectorAll('#hierToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.h===m); }); renderHier(); };
			  window.setModoHM=function(m){ _modoHM=m; document.querySelectorAll('#hierMToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderHier(); };
			  function renderHier(){
			    var el=document.getElementById('hierBox'); if(!el) return;
			    var src={produto:'jHp',vendedor:'jHv'};
			    var data=rJ(src[_modoH])||{rs:[],peso:[]};
			    var arr=(data[_modoHM]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:30px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var H=460;
			    var P={t:38,r:24,b:108,l:68};
			    var n=arr.length;
			    var containerW=el.clientWidth||900;
			    var availW=containerW-P.l-P.r;
			    var minBarW=30,maxBarW=56,defaultGap=18,maxGap=40;
			    var idealBarW=(availW-(n-1)*defaultGap)/Math.max(n,1);
			    var barW,gap,contentW,startX;
			    if(idealBarW>=maxBarW){ barW=maxBarW; var rem=availW-n*barW; gap=n>1?Math.min(maxGap,rem/(n-1)):0; var tw=n*barW+(n-1)*gap; startX=P.l+Math.max(0,(availW-tw)/2); contentW=containerW; }
			    else if(idealBarW>=minBarW){ barW=idealBarW; gap=defaultGap; startX=P.l; contentW=containerW; }
			    else { barW=minBarW; gap=defaultGap; startX=P.l; contentW=n*barW+(n-1)*gap+P.l+P.r; }
			    var W=Math.max(contentW,containerW);
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]))*1.14;
			    var fmtV=_modoHM==='rs'? fMK : function(v){return fA(v)+' kg';};
			    var lblFn=_modoHM==='rs'?'Faturamento':'Peso';
			    var uid='b'+Math.floor(Math.random()*99999);
			    var maxWC=barW<40?10:14;
			    var svg=""<defs><linearGradient id='bg""+uid+""' x1='0%' y1='0%' x2='0%' y2='100%'><stop offset='0%' stop-color='#B8935A' stop-opacity='1'/><stop offset='100%' stop-color='#1A1A1A' stop-opacity='1'/></linearGradient></defs>"";
			    for(var i=0;i<=4;i++){ var y=P.t+(H-P.t-P.b)*i/4; var v=mx*(1-i/4); svg+=""<line x1='""+P.l+""' x2='""+(W-P.r)+""' y1='""+y.toFixed(1)+""' y2='""+y.toFixed(1)+""' stroke='rgba(0,0,0,.06)' stroke-dasharray='3,4'/>""; if(i<4) svg+=""<text x='""+(P.l-6)+""' y='""+(y+4).toFixed(1)+""' text-anchor='end' fill='#8B8B8B' style='font-size:12.5px;font-family:Segoe UI,system-ui;font-weight:500'>""+fA(v)+""</text>""; }
			    arr.forEach(function(d,i){
			      var v=Number(d.val)||0;
			      var bh=Math.max(2,(v/mx)*(H-P.t-P.b));
			      var bx=startX+i*(barW+gap);
			      var by=H-P.b-bh;
			      var lx=bx+barW/2;
			      var sub = _modoH==='produto'? (d.grupo||'-') : (d.supervisor||'-');
			      var tt='<b>'+escT(d.nome)+'</b><br>'+lblFn+': '+fmtV(v)+'<br>'+(_modoHM==='rs'?'Peso: '+fA(d.peso||0)+' kg':'Faturamento: '+fMK(d.rs||0))+'<br>Clientes: '+fN(d.clientes||0)+'<br>'+(_modoH==='produto'?'Grupo: ':'Supervisor: ')+escT(sub);
			      svg+=""<rect class='vbar' x='""+bx.toFixed(1)+""' y='""+by.toFixed(1)+""' width='""+barW.toFixed(1)+""' height='""+bh.toFixed(1)+""' rx='3' fill='url(#bg""+uid+"")' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      svg+=""<text x='""+lx.toFixed(1)+""' y='""+(by-8).toFixed(1)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:700;font-variant-numeric:tabular-nums;font-family:Segoe UI,system-ui;pointer-events:none'>""+(_modoHM==='rs'?'R$ '+fA(v):fA(v))+""</text>"";
			      var words=d.nome.split(/\s+/);
			      var dw=words.slice(0,4).map(function(w){return w.length>maxWC?w.slice(0,maxWC-2)+'..':w;});
			      var ny=H-P.b+16;
			      dw.forEach(function(w,j){ svg+=""<text x='""+lx.toFixed(1)+""' y='""+(ny+j*14)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:11.5px;font-weight:500;font-family:Segoe UI,system-ui'>""+esc(w)+""</text>""; });
			    });
			    el.innerHTML=""<svg width='""+W+""' height='""+H+""' xmlns='http://www.w3.org/2000/svg'>""+svg+""</svg>"";
			  }
			  var _modoCd='rs';
			  window.setModoCd=function(m){ _modoCd=m; document.querySelectorAll('#cdModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderCidades(); };
			  function renderCidades(){
			    var el=document.getElementById('cidList'); if(!el) return;
			    var data=rJ('jCd')||{rs:[],peso:[]};
			    var arr=(data[_modoCd]||[]).slice(0,15);
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]));
			    var fmtV=_modoCd==='rs'?fMK:function(v){return fA(v)+' kg';};
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+' / '+escT(d.uf||'-')+'</b><br>'+(_modoCd==='rs'?'Faturamento':'Peso')+': '+fmtV(v)+'<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+"" <span class='bar-sub'>""+esc(d.uf||'')+""</span></div><div class='bar-val'>""+fmtV(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _modoAtv='rs';
			  window.setModoAtv=function(m){ _modoAtv=m; document.querySelectorAll('#atvModoToggle button').forEach(function(b){ b.classList.toggle('on', b.dataset.m===m); }); renderAtividades(); };
			  function renderAtividades(){
			    var el=document.getElementById('atvList'); if(!el) return;
			    var data=rJ('jAtv')||{rs:[],peso:[]};
			    var arr=(data[_modoAtv]||[]).slice(0,12);
			    if(!arr.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,arr.map(function(d){return Number(d.val)||0;}).concat([1]));
			    var fmtV=_modoAtv==='rs'?fMK:function(v){return fA(v)+' kg';};
			    el.innerHTML=arr.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var tt='<b>'+escT(d.nome)+'</b><br>'+(_modoAtv==='rs'?'Faturamento':'Peso')+': '+fmtV(v)+'<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+""</div><div class='bar-val'>""+fmtV(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  function renderRoscaCat(){
			    var el=document.getElementById('svgRoscaCat'); if(!el) return;
			    var d=svgDim(el,420,300); var W=d[0],H=d[1];
			    el.setAttribute('viewBox','0 0 '+W+' '+H);
			    var arr=(rJ('jMix')||[]).filter(function(x){return (Number(x.val)||0)>0;});
			    if(!arr.length){ el.innerHTML=""<text x='""+(W/2)+""' y='""+(H/2)+""' text-anchor='middle' fill='#999'>Sem devoluções</text>""; return; }
			    var total=arr.reduce(function(s,x){return s+(Number(x.val)||0);},0); if(total<=0) total=1;
			    var colors={Comercial:'#4A6E8A',Qualidade:'#A04848',Logistica:'#C07C3A','Logística':'#C07C3A',Industria:'#4E7D62','Indústria':'#4E7D62',Administrativo:'#5A5A5A',Fiscal:'#8A6740'};
			    var fallback=['#1A1A1A','#B8935A','#4E7D62','#C07C3A','#4A6E8A','#5A5A5A'];
			    var cx=W*0.32, cy=H/2;
			    var r=Math.min(W*0.26,H*0.40), ri=r*0.58;
			    var start=-Math.PI/2;
			    var svg='';
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var ang=(v/total)*Math.PI*2;
			      var end=start+ang;
			      var la=ang>Math.PI?1:0;
			      var x1=cx+r*Math.cos(start), y1=cy+r*Math.sin(start);
			      var x2=cx+r*Math.cos(end),   y2=cy+r*Math.sin(end);
			      var xi1=cx+ri*Math.cos(end), yi1=cy+ri*Math.sin(end);
			      var xi2=cx+ri*Math.cos(start), yi2=cy+ri*Math.sin(start);
			      var dPath='M '+x1.toFixed(2)+' '+y1.toFixed(2)+' A '+r.toFixed(2)+' '+r.toFixed(2)+' 0 '+la+' 1 '+x2.toFixed(2)+' '+y2.toFixed(2)+' L '+xi1.toFixed(2)+' '+yi1.toFixed(2)+' A '+ri.toFixed(2)+' '+ri.toFixed(2)+' 0 '+la+' 0 '+xi2.toFixed(2)+' '+yi2.toFixed(2)+' Z';
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[d2.nome]||fallback[i%fallback.length];
			      var tt='<b>'+escT(d2.nome)+'</b><br>Devolução: '+fMK(v)+'<br>'+pct+'% do total<br>Tipos: '+fN(d2.qtdTipos||0)+'<br>Clientes: '+fN(d2.clientes||0);
			      svg+=""<path class='donut-slice' d='""+dPath+""' fill='""+color+""' stroke='#FFFFFF' stroke-width='2' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'/>"";
			      start=end;
			    });
			    svg+=""<text x='""+cx+""' y='""+(cy-2)+""' text-anchor='middle' fill='#1A1A1A' style='font-size:22px;font-weight:700;font-family:Segoe UI,system-ui'>""+fMK(total)+""</text>"";
			    svg+=""<text x='""+cx+""' y='""+(cy+16)+""' text-anchor='middle' fill='#8B8B8B' style='font-size:11.5px;font-weight:600;letter-spacing:1.6px;font-family:Segoe UI,system-ui'>DEVOLUÇÃO YUZAP</text>"";
			    var lx=W*0.60;
			    var step=52;
			    var ly=Math.max(28,(H-arr.length*step)/2+12);
			    arr.forEach(function(d2,i){
			      var v=Number(d2.val)||0;
			      var pct=(v/total*100).toFixed(1).replace('.',',');
			      var color=colors[d2.nome]||fallback[i%fallback.length];
			      var y=ly+i*step;
			      svg+=""<rect x='""+lx+""' y='""+(y-12)+""' width='15' height='15' rx='3' fill='""+color+""'/>"";
			      svg+=""<text x='""+(lx+24)+""' y='""+y+""' fill='#1A1A1A' style='font-size:16px;font-weight:700;font-family:Segoe UI,system-ui'>""+esc(d2.nome)+""</text>"";
			      svg+=""<text x='""+(lx+24)+""' y='""+(y+18)+""' style='font-size:13.5px;font-family:Segoe UI,system-ui'><tspan fill='#5A5A5A'>""+fMK(v)+""</tspan> <tspan fill='#B8935A' font-weight='700'>""+pct+""%</tspan></text>"";
			    });
			    el.innerHTML=svg;
			  }"
		displayFolder: HTML Yuzap
		lineageTag: 6c2fda92-66d1-4803-b0ea-8601cfa3bcf3

	/// Parte 3 do JS Yz v2 - acentos e ortografia corrigidos. renderTopMotivos + renderTabela com aba devcliente + renderAll sem renderPorLabel + dataHash sem jLb + IIFE close.
	measure '_JS Yz P3' =
			"  function renderTopMotivos(){
			    var el=document.getElementById('topMotBox'); if(!el) return;
			    var data=(rJ('jMot')||[]).slice(0,10);
			    if(!data.length){ el.innerHTML=""<div style='padding:10px;color:#8B8B8B'>Sem dados</div>""; return; }
			    var mx=Math.max.apply(null,data.map(function(d){return Number(d.val)||0;}).concat([1]));
			    el.innerHTML=data.map(function(d){
			      var v=Number(d.val)||0, w=(v/mx)*100;
			      var clr=catColor(d.categoria);
			      var tt='<b>'+escT(d.nome)+'</b><br>Categoria: '+escT(d.categoria)+'<br>Devolução: '+fMK(v)+'<br>Peso: '+fA(d.peso||0)+' kg<br>Clientes: '+fN(d.clientes||0);
			      return ""<div class='bar-row' onmousemove=\""tip(event,'""+tt+""')\"" onmouseleave='tipOff()'><div class='bar-head'><div class='bar-name'>""+esc(d.nome)+"" <span class='tag-badge tag-mini' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(d.categoria||'-')+""</span></div><div class='bar-val'>""+fMK(v)+""</div></div><div class='bar-track'><div class='bar-fill' data-w='""+w+""'></div></div></div>"";
			    }).join('');
			    setTimeout(function(){ el.querySelectorAll('.bar-fill').forEach(function(f){ f.style.width=f.dataset.w+'%'; }); }, 80);
			  }
			  var _aba='cliente';
			  window.setAba=function(aba){ _aba=aba; document.querySelectorAll('#abasTabs .tab').forEach(function(t){ t.classList.toggle('on', t.dataset.aba===aba); }); renderTabela(); };
			  function renderTabela(){
			    var el=document.getElementById('tabBox'); if(!el) return;
			    var data, cols;
			    if(_aba==='cliente'){ data=rJ('jTc')||[]; cols=[{k:'codigo',t:'Código',cls:'mono'},{k:'cliente',t:'Cliente',cls:'name'},{k:'cidade',t:'Cidade',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'label',t:'Últ. Label',cls:'tag'},{k:'status',t:'Status',cls:'status'},{k:'conversas',t:'Conv.',cls:'num',fmt:fN},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'dev',t:'Devolução R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct},{k:'diasUltCompra',t:'Dias Últ. Compra',cls:'num',fmt:function(v){var n=Number(v); return n<0?'-':fN(n);}}]; }
			    else if(_aba==='produto'){ data=rJ('jTp')||[]; cols=[{k:'produto',t:'Produto',cls:'name'},{k:'grupo',t:'Grupo',cls:'tag'},{k:'subgrupo',t:'Subgrupo',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='vendedor'){ data=rJ('jTv')||[]; cols=[{k:'vendedor',t:'Vendedor',cls:'name'},{k:'supervisor',t:'Supervisor',cls:'tag'},{k:'gerente',t:'Gerente',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolução R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else if(_aba==='cidade'){ data=rJ('jTcd')||[]; cols=[{k:'cidade',t:'Cidade',cls:'name'},{k:'uf',t:'UF',cls:'tag'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'peso',t:'Peso (kg)',cls:'num',fmt:fA},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN},{k:'clientes',t:'Clientes',cls:'num',fmt:fN},{k:'dev',t:'Devolução R$',cls:'num',fmt:fMK},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct}]; }
			    else { data=rJ('jTdc')||[]; cols=[{k:'codigo',t:'Código',cls:'mono'},{k:'cliente',t:'Cliente',cls:'name'},{k:'cidade',t:'Cidade',cls:'name'},{k:'atividade',t:'Atividade',cls:'tag'},{k:'motivo',t:'Motivo Principal',cls:'name'},{k:'categoria',t:'Categoria',cls:'cat'},{k:'fat',t:'Faturamento',cls:'num',fmt:fMK,bar:true},{k:'dev',t:'Devolução R$',cls:'num',fmt:fMK,bar:true},{k:'pesoDev',t:'Peso Dev (kg)',cls:'num',fmt:fA},{k:'taxaDev',t:'Taxa Dev %',cls:'num',fmt:fPct},{k:'pedidos',t:'Pedidos',cls:'num',fmt:fN}]; }
			    if(!data.length){ el.innerHTML=""<div style='padding:20px;color:#8B8B8B;text-align:center'>Sem dados</div>""; return; }
			    var maxNum={};
			    cols.forEach(function(c){ if(c.cls==='num' && c.bar){ maxNum[c.k]=Math.max.apply(null,data.map(function(d){return Number(d[c.k])||0;}).concat([1])); } });
			    var head=""<thead><tr>""+cols.map(function(c){return ""<th class='th-""+c.cls+""'>""+c.t+""</th>"";}).join('')+""</tr></thead>"";
			    var body=""<tbody>""+data.map(function(d){
			      return ""<tr>""+cols.map(function(c){
			        var v=d[c.k]; var text=c.fmt?c.fmt(v):esc(v);
			        if(c.cls==='num' && c.bar){ var n=Number(v)||0; var pct=Math.max(0,(n/maxNum[c.k])*100); return ""<td class='td-num'><div class='cell-val'>""+text+""</div><div class='cell-bar'><div class='cell-fill' style='width:""+pct.toFixed(1)+""%'></div></div></td>""; }
			        if(c.cls==='tag'){ var clr=tagColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr.bg+"";color:""+clr.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='cat'){ var clr2=catColor(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr2.bg+"";color:""+clr2.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='status'){ var clr3=statusBadge(v); return ""<td class='td-tag'><span class='tag-badge' style='background:""+clr3.bg+"";color:""+clr3.fg+""'>""+esc(v||'-')+""</span></td>""; }
			        if(c.cls==='mono'){ return ""<td class='td-mono'>""+esc(v)+""</td>""; }
			        return ""<td class='td-""+c.cls+""'>""+text+""</td>"";
			      }).join('')+""</tr>"";
			    }).join('')+""</tbody>"";
			    el.innerHTML=""<table class='tbl'>""+head+body+""</table>"";
			  }
			  function renderAll(){
			    if(!document.getElementById('kpiGrid')) return false;
			    try { buildKPIs(); renderFunil(); renderPerdidos(); renderEvolucao(); renderHier(); renderCidades(); renderAtividades(); renderRoscaCat(); renderTopMotivos(); renderTabela(); return true; }
			    catch(e){ console.error(e); return false; }
			  }
			  var _prevHash='';
			  function dataHash(){ return ['jKpi','jFn','jPe','jEv','jHp','jHv','jCd','jAtv','jMix','jMot','jTc','jTp','jTv','jTcd','jTdc'].map(function(id){ var e=document.getElementById(id); if(!e) return ''; return e.textContent.length+'|'+e.textContent.slice(0,20); }).join('~'); }
			  setInterval(function(){ var h=dataHash(); if(h!==_prevHash){ _prevHash=h; renderAll(); } }, 350);
			  var rt;
			  window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(renderAll,120); });
			  function tryRender(a){ a=a||0; if(renderAll()) return; if(a<25) setTimeout(function(){ tryRender(a+1); }, 100); }
			  if(document.readyState==='loading'){ document.addEventListener('DOMContentLoaded', function(){ tryRender(); }); } else { tryRender(); }
			  window.addEventListener('load', function(){ tryRender(); });
			})();
