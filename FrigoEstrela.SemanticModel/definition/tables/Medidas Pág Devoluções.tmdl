table 'Medidas Pág Devoluções'
	lineageTag: 4d5b5bc1-61c5-4e12-947e-5b31ab48072a

	measure 'Taxa de Devolução (R$)' = ```
			
			DIVIDE(
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO]),
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRVENDA]) + 
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[VLRDEVOLUCAO])
			)
			```
