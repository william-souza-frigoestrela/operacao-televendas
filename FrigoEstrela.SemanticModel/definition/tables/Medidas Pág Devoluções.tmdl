		lineageTag: 97c20cb1-7119-4d58-9d92-67e990d600d2

	measure 'Taxa de Devolução (Peso)' = ```
			
			DIVIDE(
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[PESODEVOLVIDO]),
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[PESOVENDA]) + 
			    SUM(DCVVQ_VENDAGERALTELEVENDAS[PESODEVOLVIDO])
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e9591ac6-d377-49f0-b624-3a6d84f4e4b0

