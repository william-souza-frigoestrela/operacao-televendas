			  function renderAll(){
			    if(!document.getElementById('svgF')){return false;}
			    try{
			      rebind();
			      if(window.bT)window.bT();
			      if(window.rF)window.rF();
			      if(window.rM)window.rM();
			      if(window.rA)window.rA();
			      if(window.bH)window.bH();
			      if(window.rS)window.rS();
			      return true;
			    }catch(e){return false;}
			  }
			  function tryRender(attempts){
			    attempts=attempts||0;
			    if(renderAll())return;
			    if(attempts<20)setTimeout(function(){tryRender(attempts+1);},100);
			  }
			  tryRender();
			  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){tryRender();});}
			  window.addEventListener('load',function(){tryRender();});
			  setInterval(function(){
			    var el=document.getElementById('svgF');
			    if(el&&!el.innerHTML.trim()){tryRender();}
			  },800);
			  document.addEventListener('click',function(e){if(!e.target.closest('.dd'))document.querySelectorAll('.dd-l.on').forEach(function(el){el.classList.remove('on');});});
			})();
