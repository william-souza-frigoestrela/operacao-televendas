			    window.bH=function(){var el=document.getElementById('hT');if(!el)return;if(!B.length){el.innerHTML=""<div style='color:#999;text-align:center;padding:20px'>Sem dados</div>"";return;}var sB=B.slice().sort(function(a,b){return (Number(b.cnt)||0)-(Number(a.cnt)||0);});var mx=Math.max.apply(null,sB.map(function(d){return Number(d.cnt)||0;}).concat([1]));el.innerHTML=sB.map(function(d){var v=Number(d.cnt)||0;var w=(v/mx)*100;return ""<div><div class='hb-h'><div class='hb-n' title='""+esc(d.tab)+""'>""+esc(d.tab)+""</div><div class='hb-c'>""+fN(v)+""</div></div><div class='hb-tr'><div class='hb-fl' data-w='""+w+""'></div></div></div>"";}).join(String());setTimeout(function(){document.querySelectorAll('.hb-fl').forEach(function(e){e.style.width=e.dataset.w+'%';});},80);};
			    window.rS=function(){var el=document.getElementById('svgS');if(!el)return;var bb=el.getBoundingClientRect();var W=Math.round(bb.width)||310,H=Math.round(bb.height)||190;if(W<50||H<30){setTimeout(function(){window.rS();},150);return;}el.setAttribute('viewBox','0 0 '+W+' '+H);if(!S.length){el.innerHTML=""<text x='""+Math.round(W/2)+""' y='""+Math.round(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>"";return;}var P={t:26,r:8,b:54,l:50};var vals=S.map(function(d){return Number(d.cnt)||0;});var mx=Math.max.apply(null,vals.concat([1]))*1.18;var CW=W-P.l-P.r,CH=H-P.t-P.b;var gw=CW/S.length,bg=Math.max(4,gw*0.12),bw=gw-bg*2;var svg=gridAxes(W,H,P,mx,function(v){return fA2(v,'mailing');});S.forEach(function(d,i){var v=Number(d.cnt)||0;var h=(v/mx)*CH;var x=P.l+i*gw+bg,y=P.t+CH-h;var c=SC[d.status]||'#1A1A1A';var sp=String(d.status||String()).split(' ');var sl1=esc(sp[0]||String());var sl2=esc(sp.slice(1).join(' ')||String());svg+=""<g class='bg-r' onmousemove=\""tip(event,'<b>""+esc(d.status)+""</b><br>""+fN(v)+"" chamadas')\"" onmouseleave='tipOff()'><rect class='br' x='""+x+""' y='""+y+""' width='""+bw+""' height='""+h+""' fill='""+c+""' rx='3'/><text class='axv' x='""+(x+bw/2)+""' y='""+(y-5)+""' text-anchor='middle' font-size='9'>""+fN(v)+""</text><text class='axl' x='""+(P.l+i*gw+gw/2)+""' y='""+(H-34)+""' text-anchor='middle' font-size='8.5'>""+sl1+""</text>""+(sl2?""<text class='axl' x='""+(P.l+i*gw+gw/2)+""' y='""+(H-22)+""' text-anchor='middle' font-size='8.5'>""+sl2+""</text>"":String())+""</g>"";});el.innerHTML=svg;};
