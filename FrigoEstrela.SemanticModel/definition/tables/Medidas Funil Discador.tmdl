			    window.rM=function(){var btnP=document.getElementById('mP-b'),btnC=document.getElementById('mC-b');if(!btnP||!btnC)return;var k1=btnP.dataset.v,k2=btnC.dataset.v;var el=document.getElementById('svgM');if(!el)return;var bb=el.getBoundingClientRect();var W=Math.round(bb.width)||600,H=Math.round(bb.height)||165;if(W<50||H<30){setTimeout(function(){window.rM();},150);return;}el.setAttribute('viewBox','0 0 '+W+' '+H);if(!M.length){el.innerHTML=""<text x='""+Math.round(W/2)+""' y='""+Math.round(H/2)+""' text-anchor='middle' fill='#999'>Sem dados</text>"";return;}var P={t:26,r:16,b:32,l:50};var all=[];M.forEach(function(d){all.push(Number(d[k1])||0,Number(d[k2])||0);});var mx=Math.max.apply(null,all.concat([1]))*1.18;var CW=W-P.l-P.r,CH=H-P.t-P.b;var gw=CW/M.length,bg=10,bw=(gw-bg*2-3)/2;var svg=gridAxes(W,H,P,mx,function(v){return fA2(v,k1);});M.forEach(function(d,i){var xb=P.l+i*gw+bg;var v1=Number(d[k1])||0,v2=Number(d[k2])||0;var h1=(v1/mx)*CH,h2=(v2/mx)*CH;var x1=xb,y1=P.t+CH-h1,x2=xb+bw+3,y2=P.t+CH-h2;svg+=""<g class='bg-r' onmousemove=\""tip(event,'<b>""+esc(d.mes)+""</b><br>""+ML[k1]+"": ""+fV(k1,v1)+""<br>""+ML[k2]+"": ""+fV(k2,v2)+""')\"" onmouseleave='tipOff()'><rect class='br' x='""+x1+""' y='""+y1+""' width='""+bw+""' height='""+h1+""' fill='#1A1A1A' rx='3'/><rect class='br' x='""+x2+""' y='""+y2+""' width='""+bw+""' height='""+h2+""' fill='#B8935A' rx='3'/><text class='axv' x='""+(x1+bw/2)+""' y='""+(y1-5)+""' text-anchor='middle'>""+fV(k1,v1)+""</text><text class='axv' x='""+(x2+bw/2)+""' y='""+(y2-5)+""' text-anchor='middle' fill='#B8935A'>""+fV(k2,v2)+""</text><text class='axl' x='""+(P.l+i*gw+gw/2)+""' y='""+(H-10)+""' text-anchor='middle'>""+esc(d.mes)+""</text></g>"";});el.innerHTML=svg;};
